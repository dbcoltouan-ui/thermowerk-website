---
import Layout from '../layouts/Layout.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import { getPage, getSingleton, urlFor } from '../lib/sanity';

const data = await getPage('impressumPage');
const siteSettings = await getSingleton('siteSettings');
const logoUrl = siteSettings?.logo?.asset ? urlFor(siteSettings.logo).url() : '/img/logo.png';
const logoAlt = siteSettings?.logoAlt || 'Thermowerk';

// Fallback-Werte (1:1 aus Original)
const pageTitle = data?.pageTitle || 'Impressum - Thermowerk';
const pageDescription = data?.pageDescription || 'Impressum der Gebäudetechnik Coltouan / Thermowerk, Neftenbach.';
const headline = data?.headline || 'Impressum';
const companyName = data?.companyName || 'Gebäudetechnik Coltouan';
const address = data?.address || 'Rankstrasse 18\n8413 Neftenbach\nSchweiz';
const representativePerson = data?.representativePerson || 'Coltouan Beniamin-Daniel';
const uid = data?.uid || 'CHE-489.162.528';
const mwst = data?.mwst || 'CHE-489.162.528 MWST';
const phone = data?.phone || '+41 76 504 03 68';
const email = data?.email || 'db.coltouan@gmail.com';
const web = data?.web || 'thermowerk.ch';
const sourceText = data?.sourceText || 'Impressum erstellt durch:';
const sourceLink = data?.sourceLink || 'https://impressum-generator-schweiz.ch/';
const sourceLinkText = data?.sourceLinkText || 'Impressum Generator Schweiz';

const defaultSections = [
  { title: '1. Inhalte', content: 'Trotz sorgfältiger inhaltlicher Kontrolle übernehmen wir keine Gewähr für die Aktualität, Vollständigkeit und Richtigkeit der bereitgestellten Informationen. Jegliche Haftungsansprüche gegen uns, die sich auf Schäden materieller oder ideeller Art beziehen – verursacht durch die Nutzung oder Nichtnutzung der dargebotenen Inhalte bzw. durch Nutzung fehlerhafter und unvollständiger Informationen – sind grundsätzlich ausgeschlossen.' },
  { title: '2. Externe Links', content: 'Unsere Webseite enthält Links zu externen Websites Dritter, auf deren Inhalte wir keinen Einfluss haben. Deshalb übernehmen wir für diese fremden Inhalte auch keine Gewähr. Für die Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter oder Betreiber der Seiten verantwortlich.' },
  { title: '3. Urheberrecht', content: 'Die durch die Seitenbetreiber erstellten Inhalte und Werke auf dieser Website unterliegen dem schweizerischen Urheberrecht. Beiträge Dritter sind als solche gekennzeichnet. Die Vervielfältigung, Bearbeitung, Verbreitung und jede Art der Verwertung ausserhalb der Grenzen des Urheberrechts bedürfen unserer schriftlichen Zustimmung.' },
  { title: '4. Änderungen und Irrtümer', content: 'Wir behalten uns ausdrücklich vor, Teile der Seiten oder das gesamte Angebot jederzeit zu ändern, zu ergänzen, zu löschen oder die Veröffentlichung zeitweise oder endgültig einzustellen. Sollten einzelne Formulierungen oder Darstellungen dieses Haftungsausschlusses unwirksam sein, bleiben die übrigen Bestimmungen davon unberührt.' },
];
const sections = data?.sections && data.sections.length > 0 ? data.sections : defaultSections;
---
<Layout title={pageTitle} description={pageDescription}>
  <Topbar />
  <!-- Header mit Links zur Startseite -->
  <header class="header" id="header">
    <div class="header-inner">
      <a href="/">
        <img src={logoUrl} alt={logoAlt} class="logo-img">
      </a>
      <button class="menu-toggle" id="menuToggle" aria-label="Menü öffnen">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="nav" id="mainNav">
        <div class="nav-dropdown">
          <a href="/#services" class="nav-dropdown-trigger">Leistungen
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" style="margin-left:4px;"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <div class="nav-dropdown-menu">
            <a href="/#why">Wärmepumpen</a>
            <a href="/#klima">Klimaanlagen</a>
          </div>
        </div>
        <a href="/#services" class="mobile-menu-link">Leistungen</a>
        <a href="/#about">Über Uns</a>
        <a href="/#wpsm">Förderung</a>
        <a href="/#calculator">Kostenrechner</a>
        <a href="/#contact" class="btn btn-primary">Beratung anfragen</a>
        <a href="tel:+41765040368" class="btn btn-stoerung mobile-only">Störung melden</a>
      </nav>
    </div>
  </header>

  <!-- Hero-Hintergrund -->
  <div class="impressum-hero">
    <div class="impressum-hero-bg">
      <img src="/img/hero-desktop.jpeg" alt="" />
    </div>
    <div class="impressum-hero-overlay"></div>
  </div>

  <main class="impressum-page">
    <div class="container">
      <div class="impressum-content">
        <h1>{headline}</h1>

        <address set:html={companyName + '<br />' + address.replace(/\n/g, '<br />')} />

        <h2>Vertretungsberechtigte Personen</h2>
        <p>{representativePerson}</p>

        <h2>Handelsregister</h2>
        <p>
          UID: {uid}<br />
          MWST-Nummer: {mwst}
        </p>

        <h2>Kontakt</h2>
        <p>
          Telefon: <a href={`tel:${phone.replace(/\s/g, '')}`}>{phone}</a><br />
          E-Mail: <a href={`mailto:${email}`}>{email}</a><br />
          Web: <a href={`https://${web}`}>{web}</a>
        </p>

        <h2>Haftungsausschluss</h2>

        {sections.map((section: any) => (
          <div class="legal-item">
            <h3>{section.title}</h3>
            <p>{section.content}</p>
          </div>
        ))}

        <p class="impressum-source">
          {sourceText} <a href={sourceLink} target="_blank" rel="noopener">{sourceLinkText}</a>
        </p>
      </div>
    </div>
  </main>
  <Footer />

  <style is:global>
    /* Hero-Hintergrund fixiert */
    .impressum-hero {
      position: fixed;
      inset: 0;
      z-index: 0;
    }
    .impressum-hero-bg {
      position: absolute;
      inset: 0;
    }
    .impressum-hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 15% center;
    }
    .impressum-hero-overlay {
      position: absolute;
      inset: 0;
      background: rgba(27, 42, 74, 0.55);
    }

    /* Hauptinhalt */
    .impressum-page {
      position: relative;
      z-index: 1;
      padding-top: calc(var(--topbar-height) + var(--header-height) + clamp(48px, 7svh, 72px));
      padding-bottom: clamp(60px, 10svh, 100px);
      min-height: 80vh;
    }
    .impressum-content {
      max-width: 760px;
      margin: 0 auto;
      background: rgba(255, 255, 255, 0.78);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 6px;
      padding: clamp(36px, 5svh, 56px) clamp(32px, 4vw, 56px);
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12);
    }
    .impressum-content h1 {
      font-family: var(--font-heading);
      font-size: clamp(32px, 4.5vw, 48px);
      color: var(--navy);
      margin-bottom: clamp(28px, 4svh, 40px);
    }
    .impressum-content address {
      font-style: normal;
      font-size: clamp(15px, 1.7vw, 17px);
      line-height: 1.8;
      color: var(--dark);
      margin-bottom: clamp(28px, 4svh, 40px);
    }
    .impressum-content h2 {
      font-family: var(--font-heading);
      font-size: clamp(20px, 2.5vw, 24px);
      color: var(--navy);
      margin-top: clamp(28px, 4svh, 40px);
      margin-bottom: clamp(8px, 1.5svh, 12px);
      text-align: left;
    }
    .impressum-content p {
      font-size: clamp(14px, 1.6vw, 16px);
      color: var(--mid-gray);
      line-height: 1.7;
    }
    .impressum-content a {
      color: var(--navy);
      font-weight: 600;
      transition: color 0.2s;
    }
    .impressum-content a:hover {
      color: var(--red);
    }
    .legal-item {
      margin-top: clamp(20px, 3svh, 28px);
    }
    .legal-item h3 {
      font-family: var(--font-heading);
      font-size: clamp(16px, 1.8vw, 18px);
      color: var(--dark);
      margin-bottom: clamp(6px, 1svh, 8px);
    }
    .impressum-source {
      margin-top: clamp(40px, 6svh, 56px);
      font-size: clamp(12px, 1.3vw, 13px);
      color: var(--mid-gray);
    }
    .impressum-source a {
      font-weight: 500;
    }
    /* Footer über Hintergrund */
    .footer {
      position: relative;
      z-index: 1;
    }

    @media (max-width: 968px) {
      .impressum-page {
        padding-top: calc(var(--header-height) + clamp(32px, 5svh, 48px));
      }
      .impressum-content {
        padding: clamp(28px, 4svh, 40px) clamp(20px, 3vw, 32px);
      }
      .impressum-content h2 {
        text-align: left;
      }
    }
  </style>

  <!-- Mobile Menu Script -->
  <script is:inline>
    var menuToggle = document.getElementById('menuToggle');
    var mainNav = document.getElementById('mainNav');
    if (menuToggle && mainNav) {
      menuToggle.addEventListener('click', function() {
        mainNav.classList.toggle('open');
        menuToggle.classList.toggle('active');
        document.body.classList.toggle('menu-open');
      });
      mainNav.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
          mainNav.classList.remove('open');
          menuToggle.classList.remove('active');
          document.body.classList.remove('menu-open');
        });
      });
    }
    /* Header scroll shadow */
    var headerEl = document.getElementById('header');
    if (headerEl) {
      headerEl.classList.add('scrolled');
    }
    /* Topbar-Alignment wie auf Startseite */
    function alignTopbar() {
      var nav = document.querySelector('.nav');
      var ctaBtn = document.querySelector('.nav .btn-primary');
      if (nav) {
        var navLeft = nav.getBoundingClientRect().left;
        document.documentElement.style.setProperty('--nav-left', navLeft + 'px');
      }
      if (ctaBtn) {
        document.documentElement.style.setProperty('--cta-btn-width', ctaBtn.offsetWidth + 'px');
      }
    }
    window.addEventListener('load', alignTopbar);
    window.addEventListener('resize', alignTopbar);
    document.fonts.ready.then(alignTopbar);
  </script>
</Layout>

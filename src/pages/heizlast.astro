---
// Heizlast-Rechner — Hauptseite (Phase 10 / Block 3)
// v2-Port: nutzt HeizlastLayout (umbenannt aus V2) und die neue
// Komponenten-Suite in src/components/heizlast-v2/. State + lib bleiben
// unveraendert.
import HeizlastLayout from '../layouts/HeizlastLayout.astro';
import Section1Gebaeude from '../components/heizlast-v2/sections/Section1Gebaeude.astro';
import Section2Heizlast from '../components/heizlast-v2/sections/Section2Heizlast.astro';
import Section3Warmwasser from '../components/heizlast-v2/sections/Section3Warmwasser.astro';
import Section4Zuschlaege from '../components/heizlast-v2/sections/Section4Zuschlaege.astro';
import Section5aDiagramm from '../components/heizlast-v2/sections/Section5aDiagramm.astro';
import Section5Speicher from '../components/heizlast-v2/sections/Section5Speicher.astro';
import Section6Projekt from '../components/heizlast-v2/sections/Section6Projekt.astro';
import LoginModal from '../components/heizlast-v2/LoginModal.astro';
import ProjectsModal from '../components/heizlast-v2/ProjectsModal.astro';
import ExportModal from '../components/heizlast-v2/ExportModal.astro';
import PrintCover from '../components/heizlast-v2/PrintCover.astro';
---
<HeizlastLayout
  title="Heizlast-Rechner | Thermowerk"
  description="Professionelle Heizlast- und Wärmepumpen-Auslegung nach FWS, SIA und VDI."
>
  <PrintCover />

  {/* Topbar (inline — Layout liefert nur Scope + Stripe) */}
  <header class="topbar">
    <div class="topbar__brand-row">
      <a class="brand" href="/" aria-label="Thermowerk — Startseite">
        <img class="brand__logo" src="/img/logo.png" alt="Thermowerk" width="180" height="36" />
      </a>
      <span class="brand__sub" data-hz-brand-sub>Heizlast-Rechner</span>
    </div>
    <div class="topbar__action-row">
      <span class="project-tag">
        <span class="project-tag__label">Projekt</span>
        <span class="project-tag__value" data-hz-sum="projectName">–</span>
      </span>
      <div class="actions">
        <button class="btn btn--ghost" type="button" id="hz-login-trigger">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
            <polyline points="10 17 15 12 10 7"/>
            <line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          <span data-hz-login-label>Anmelden</span>
        </button>
      </div>
    </div>
  </header>

  <Section1Gebaeude />
  <Section2Heizlast />
  <Section3Warmwasser />
  <Section4Zuschlaege />
  <Section5aDiagramm />
  <Section5Speicher />
  <Section6Projekt />

  <LoginModal />
  <ProjectsModal />
  <ExportModal />
</HeizlastLayout>

<script>
  // ============================================================
  // Heizlast-Rechner — Glue-JS (v2)
  // ------------------------------------------------------------
  // 1. Boot-Reihenfolge (storage -> bindings -> sync)
  // 2. Override-Globals
  // 3. Zimmer-Liste (Section 1)
  // 4. Sanierungs-Liste (Section 2)
  // 5. Perioden-Listen (Verbrauch / Messung / Bstd)
  // 6. Method-Toggles (exklusives <details name="heizlast-method">)
  // 7. Gate-Sync (details.open <-> hidden checkbox)
  // 8. WW-Panes
  // 9. Compute-Subscriber -> KPIs + Summary + Status-Badge + Notes-Dot
  // 10. Save / Load / Export / Login / Modals
  // 11. beforeunload-Warnung
  // ============================================================
  import {
    heizlastState,
    uiState,
    isDirty,
    addRaum,
    removeRaum,
    updateRaum,
    sumRaumFlaechenNetto,
    raumFlaeche,
    addVerbrauchPeriode,
    removeVerbrauchPeriode,
    updateVerbrauchPeriode,
    addMessungPeriode,
    removeMessungPeriode,
    updateMessungPeriode,
    addBstdPeriode,
    removeBstdPeriode,
    updateBstdPeriode,
  } from '../lib/heizlast/state.ts';
  import { heizlastCompute } from '../lib/heizlast/compute.ts';
  import {
    bootFromStorage,
    subscribeAutoSave,
    hardReset,
  } from '../lib/heizlast/storage.ts';
  import { bootBindings, syncDomFromState } from '../lib/heizlast/bindings.ts';
  import { clearOverride, resolveDefault } from '../lib/heizlast/state.ts';
  import {
    SANIERUNGS_MASSNAHMEN,
    BAUPERIODEN,
    BRENNWERTE,
  } from '../lib/heizlast/constants.ts';
  import {
    listProjects,
    loadProject,
    saveProject,
    deleteProject,
    probeAuth,
  } from '../lib/heizlast/projects.ts';
  import { runExport, defaultFilename, type ExportPart } from '../lib/heizlast/export.ts';
  import { projectList, projectListLoaded, replaceState } from '../lib/heizlast/state.ts';

  // ------------------------------------------------------------
  // 1. Boot-Reihenfolge
  // ------------------------------------------------------------
  bootFromStorage();
  subscribeAutoSave();
  bootBindings();
  syncDomFromState();

  // ------------------------------------------------------------
  // 2. Override-Globals (fuer OverrideField-Reset)
  // ------------------------------------------------------------
  (window as any).__hzClearOverride = (path: string) => {
    clearOverride(path);
  };
  (window as any).__hzResolveDefault = (path: string): string | null => {
    const v = resolveDefault(heizlastState.get(), path);
    return v == null ? null : String(v);
  };

  // OverrideField-Reset-Button: Klick -> Default in Input schreiben,
  // ohne setOverride(true) zu triggern (Events sind synthetisch).
  if (!(window as any).__hzOvrResetBound) {
    (window as any).__hzOvrResetBound = true;
    document.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement | null;
      if (!t || typeof t.closest !== 'function') return;
      const btn = t.closest('[data-hz-override-reset]') as HTMLElement | null;
      if (!btn) return;
      const wrapper = btn.closest('[data-hz-override-field]') as HTMLElement | null;
      if (!wrapper) return;
      const path = wrapper.getAttribute('data-hz-override-field');
      if (!path) return;
      (window as any).__hzClearOverride(path);
      const def = (window as any).__hzResolveDefault(path);
      const input = wrapper.querySelector<HTMLInputElement>('input[data-hz-bind]');
      if (input && def != null) {
        input.value = String(def);
        // Synthetische Events — bindings.ts erkennt sie und ruft NICHT setOverride.
        input.dispatchEvent(new Event('input', { bubbles: true }));
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  }

  // Auth-Status pruefen
  probeAuth().then((ok) => { uiState.setKey('isAuthenticated', ok); }).catch(() => {});

  // ------------------------------------------------------------
  // 3. Helpers
  // ------------------------------------------------------------
  function fmt(n: number | null | undefined, d = 2): string {
    if (n == null || !isFinite(n)) return '–';
    return n.toLocaleString('de-CH', { minimumFractionDigits: d, maximumFractionDigits: d });
  }
  function fmtInt(n: number | null | undefined): string {
    if (n == null || !isFinite(n)) return '–';
    return Math.round(n).toLocaleString('de-CH');
  }
  function escapeHtml(s: string): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) => (({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    } as any)[c] as string));
  }
  const SVG_REMOVE = '<svg class="icon--sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>';

  // ------------------------------------------------------------
  // 4. Zimmer-Liste (Section 1)
  // ------------------------------------------------------------
  const zimmerPanel = document.querySelector('[data-hz-zimmer-panel]') as HTMLElement | null;
  const raumList = document.querySelector('[data-hz-raum-list]') as HTMLElement | null;
  const zimmerMeta = document.querySelector('[data-hz-zimmer-meta]') as HTMLElement | null;
  const zimmerSumBeheizt = document.querySelector('[data-hz-zimmer-sum="beheizt"]') as HTMLElement | null;
  const zimmerSumUnbeheizt = document.querySelector('[data-hz-zimmer-sum="unbeheizt"]') as HTMLElement | null;
  const zimmerSumNetto = document.querySelector('[data-hz-zimmer-sum="netto"]') as HTMLElement | null;

  function renderZimmer() {
    if (!raumList) return;
    const s = heizlastState.get();
    const raeume = s.gebaeude.raeume || [];
    if (raeume.length === 0) {
      raumList.innerHTML = '<tr><td colspan="7" style="padding: 12px; color: var(--ink-400); font-size: 13px; text-align: center;">Noch keine Zimmer erfasst.</td></tr>';
    } else {
      raumList.innerHTML = raeume.map((r) => {
        const a = raumFlaeche(r);
        const hatDirekt = r.flaecheDirekt != null && r.flaecheDirekt > 0;
        const beheizt = r.beheizt !== false;
        const laengeVal = r.laenge == null ? '' : r.laenge;
        const breiteVal = r.breite == null ? '' : r.breite;
        const direktVal = r.flaecheDirekt == null ? '' : r.flaecheDirekt;
        return `
          <tr data-raum-id="${escapeHtml(r.id)}">
            <td><input class="input" type="text" placeholder="z. B. Wohnzimmer" data-raum-field="name" value="${escapeHtml(r.name)}" /></td>
            <td class="col-num"><input class="input" type="number" step="0.1" min="0" data-raum-field="laenge" value="${laengeVal}" /></td>
            <td class="col-num"><input class="input" type="number" step="0.1" min="0" data-raum-field="breite" value="${breiteVal}" /></td>
            <td class="col-num-direct"><input class="input" type="number" step="0.1" min="0" data-raum-field="flaecheDirekt" value="${direktVal}" /></td>
            <td class="col-area"><strong>${a > 0 ? fmt(a, 1) + ' m²' : '–'}</strong>${hatDirekt ? ' <span class="chip" style="margin-left:4px;">direkt</span>' : ''}</td>
            <td class="col-chk"><label class="switch" style="justify-content: center;"><input type="checkbox" data-raum-field="beheizt" ${beheizt ? 'checked' : ''} /><span class="switch__track"></span></label></td>
            <td class="col-act"><button type="button" class="btn btn--ghost" aria-label="Entfernen" data-raum-remove style="padding: 0; width: 28px; height: 28px;">${SVG_REMOVE}</button></td>
          </tr>
        `;
      }).join('');
    }
    const agg = sumRaumFlaechenNetto(raeume);
    if (zimmerSumBeheizt) zimmerSumBeheizt.textContent = fmt(agg.beheizt, 1) + ' m²';
    if (zimmerSumUnbeheizt) zimmerSumUnbeheizt.textContent = fmt(agg.unbeheizt, 1) + ' m²';
    if (zimmerSumNetto) zimmerSumNetto.textContent = fmt(agg.netto, 1) + ' m²';
    if (zimmerMeta) {
      const n = raeume.length;
      zimmerMeta.textContent = n === 1 ? '1 Raum' : `${n} Räume`;
    }
  }

  function parseRaumNumber(value: string): number | null {
    if (value === '' || value == null) return null;
    const n = Number(value);
    if (!isFinite(n) || n < 0) return null;
    return n;
  }

  // Zimmer-Aktionen (Event-Delegation)
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;

    // Toggle Zimmer-Panel
    const toggleBtn = t.closest('[data-hz-action="toggle-zimmer"]') as HTMLElement | null;
    if (toggleBtn && zimmerPanel) {
      const isHidden = zimmerPanel.classList.contains('is-hidden');
      zimmerPanel.classList.toggle('is-hidden', !isHidden);
      toggleBtn.setAttribute('aria-expanded', String(isHidden));
      return;
    }

    // Close Zimmer-Panel
    if (t.closest('[data-hz-action="close-zimmer"]') && zimmerPanel) {
      zimmerPanel.classList.add('is-hidden');
      const tb = document.querySelector('[data-hz-action="toggle-zimmer"]');
      if (tb) tb.setAttribute('aria-expanded', 'false');
      return;
    }

    // Apply Zimmer -> EBF
    if (t.closest('[data-hz-action="apply-zimmer"]')) {
      const s = heizlastState.get();
      const agg = sumRaumFlaechenNetto(s.gebaeude.raeume || []);
      if (agg.netto > 0) {
        heizlastState.setKey('gebaeude', { ...s.gebaeude, ebf: Math.round(agg.netto * 10) / 10 });
      }
      if (zimmerPanel) zimmerPanel.classList.add('is-hidden');
      const tb = document.querySelector('[data-hz-action="toggle-zimmer"]');
      if (tb) tb.setAttribute('aria-expanded', 'false');
      return;
    }

    // Add Zimmer
    if (t.closest('[data-hz-action="add-raum"]')) {
      addRaum('');
      return;
    }

    // Remove Zimmer
    const rm = t.closest('[data-raum-remove]') as HTMLElement | null;
    if (rm) {
      const row = rm.closest('[data-raum-id]') as HTMLElement | null;
      if (row) removeRaum(row.getAttribute('data-raum-id')!);
    }
  });

  document.addEventListener('input', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const row = t.closest('[data-raum-id]') as HTMLElement | null;
    if (!row) return;
    const field = t.getAttribute('data-raum-field');
    const id = row.getAttribute('data-raum-id');
    if (!id || !field) return;
    if (field === 'beheizt') return;
    const value = (t as HTMLInputElement).value;
    if (field === 'name') updateRaum(id, { name: value });
    else if (field === 'laenge') updateRaum(id, { laenge: parseRaumNumber(value) });
    else if (field === 'breite') updateRaum(id, { breite: parseRaumNumber(value) });
    else if (field === 'flaecheDirekt') updateRaum(id, { flaecheDirekt: parseRaumNumber(value) });
  });
  document.addEventListener('change', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const row = t.closest('[data-raum-id]') as HTMLElement | null;
    if (!row) return;
    const field = t.getAttribute('data-raum-field');
    if (field !== 'beheizt') return;
    const id = row.getAttribute('data-raum-id');
    if (!id) return;
    updateRaum(id, { beheizt: (t as HTMLInputElement).checked });
  });

  // ------------------------------------------------------------
  // 5. Sanierungs-Liste (Section 2)
  // ------------------------------------------------------------
  const sanListEl = document.querySelector('[data-hz-sanierung-list]') as HTMLElement | null;

  function renderSanierung() {
    if (!sanListEl) return;
    const s = heizlastState.get();
    const items = s.heizlast.sanierungMassnahmen || [];
    if (items.length === 0) {
      sanListEl.innerHTML = '<p class="hz-muted" style="font-style:italic;font-size:13px;color:var(--ink-400);margin:4px 0;">Noch keine Massnahme gewählt.</p>';
      return;
    }
    sanListEl.innerHTML = items.map((m) => {
      const datum = m.datum || '';
      const zeitpunkt = m.zeitpunkt || 'geplant';
      return `
        <div class="measure-row" data-san-id="${escapeHtml(m.id)}">
          <span>${escapeHtml(m.label)}</span>
          <div class="input-group">
            <input class="input" type="number" step="1" min="0" max="100" data-san-field="einsparungProzent" value="${m.einsparungProzent}" />
            <span class="input-group__unit">%</span>
          </div>
          <select class="select" data-san-field="zeitpunkt">
            <option value="geplant" ${zeitpunkt === 'geplant' ? 'selected' : ''}>geplant</option>
            <option value="vergangen" ${zeitpunkt === 'vergangen' ? 'selected' : ''}>vergangen</option>
          </select>
          <button type="button" class="btn btn--ghost" aria-label="Entfernen" data-san-remove style="padding:0;width:28px;height:28px;justify-self:end;">${SVG_REMOVE}</button>
        </div>
      `;
    }).join('');
  }

  // Add Sanierung: erste noch nicht verwendete Preset-Massnahme hinzufuegen
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const btn = t.closest('[data-hz-action="add-sanierung"]') as HTMLElement | null;
    if (!btn) return;
    const s = heizlastState.get();
    const used = new Set(s.heizlast.sanierungMassnahmen.map((m) => m.id));
    const next = SANIERUNGS_MASSNAHMEN.find((p) => !used.has(p.id));
    if (!next) return;
    heizlastState.setKey('heizlast', {
      ...s.heizlast,
      sanierungActive: true,
      sanierungMassnahmen: [
        ...s.heizlast.sanierungMassnahmen,
        {
          id: next.id,
          label: next.label,
          einsparungProzent: next.default,
          datum: null as null,
          zeitpunkt: 'geplant' as const,
        },
      ],
    });
    isDirty.set(true);
  });

  document.addEventListener('input', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const row = t.closest('[data-san-id]') as HTMLElement | null;
    if (!row) return;
    const id = row.getAttribute('data-san-id');
    const field = t.getAttribute('data-san-field');
    if (!id || field !== 'einsparungProzent') return;
    const value = Number((t as HTMLInputElement).value) || 0;
    const s = heizlastState.get();
    const next = s.heizlast.sanierungMassnahmen.map((m) =>
      m.id === id ? { ...m, einsparungProzent: value } : m,
    );
    heizlastState.setKey('heizlast', { ...s.heizlast, sanierungMassnahmen: next });
    isDirty.set(true);
  });
  document.addEventListener('change', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const row = t.closest('[data-san-id]') as HTMLElement | null;
    if (!row) return;
    const id = row.getAttribute('data-san-id');
    const field = t.getAttribute('data-san-field');
    if (!id || field !== 'zeitpunkt') return;
    const val = (t as HTMLSelectElement).value as 'vergangen' | 'geplant';
    const s = heizlastState.get();
    const next = s.heizlast.sanierungMassnahmen.map((m) =>
      m.id === id ? { ...m, zeitpunkt: val } : m,
    );
    heizlastState.setKey('heizlast', { ...s.heizlast, sanierungMassnahmen: next });
    isDirty.set(true);
  });
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const rm = t.closest('[data-san-remove]') as HTMLElement | null;
    if (!rm) return;
    const row = rm.closest('[data-san-id]') as HTMLElement | null;
    if (!row) return;
    const id = row.getAttribute('data-san-id');
    if (!id) return;
    const s = heizlastState.get();
    const next = s.heizlast.sanierungMassnahmen.filter((m) => m.id !== id);
    heizlastState.setKey('heizlast', { ...s.heizlast, sanierungMassnahmen: next });
    isDirty.set(true);
  });

  // ------------------------------------------------------------
  // 6. Perioden-Listen (Verbrauch / Messung / Bstd)
  // ------------------------------------------------------------
  const verbrauchList = document.querySelector('[data-hz-periods-list="verbrauch"]') as HTMLElement | null;
  const messungList = document.querySelector('[data-hz-periods-list="messung"]') as HTMLElement | null;
  const bstdList = document.querySelector('[data-hz-periods-list="bstd"]') as HTMLElement | null;

  const brennwerteArr = Object.entries(BRENNWERTE).map(([id, b]: any) => ({
    id, label: b.label, einheit: b.verbrauchEinheit,
  }));
  function brennwertOptionsHtml(selected: string): string {
    return brennwerteArr.map((b) =>
      `<option value="${escapeHtml(b.id)}"${b.id === selected ? ' selected' : ''}>${escapeHtml(b.label)}</option>`,
    ).join('');
  }
  function brennwertEinheit(id: string): string {
    const b = brennwerteArr.find((x) => x.id === id);
    return b ? b.einheit : '';
  }

  function renderVerbrauchPerioden() {
    if (!verbrauchList) return;
    const s = heizlastState.get();
    const perioden = s.heizlast.verbrauch.perioden || [];
    if (perioden.length === 0) {
      verbrauchList.innerHTML = '<p class="hz-muted" style="font-style:italic;font-size:13px;color:var(--ink-400);margin:4px 0;">Noch keine Periode. Einzelwert B<sub>a</sub> wird als Jahres-Fallback genutzt.</p>';
      return;
    }
    verbrauchList.innerHTML = perioden.map((p: any) => {
      const et = p.energietraeger || s.heizlast.verbrauch.energietraeger || 'oel';
      return `
        <div class="period period-consumption" data-vp-id="${escapeHtml(p.id)}">
          <input class="input" type="date" data-p-field="vonDatum" value="${escapeHtml(p.vonDatum || '')}" />
          <input class="input" type="date" data-p-field="bisDatum" value="${escapeHtml(p.bisDatum || '')}" />
          <select class="select" data-p-field="energietraeger">${brennwertOptionsHtml(et)}</select>
          <div class="input-group">
            <input class="input" type="number" step="any" min="0" data-p-field="wert" value="${p.wert ?? ''}" />
            <span class="input-group__unit">${escapeHtml(brennwertEinheit(et))}</span>
          </div>
          <button type="button" class="btn btn--ghost" aria-label="Entfernen" data-vp-remove style="padding:0;width:28px;height:28px;justify-self:end;">${SVG_REMOVE}</button>
        </div>
      `;
    }).join('');
  }

  function renderMessungPerioden() {
    if (!messungList) return;
    const perioden = heizlastState.get().heizlast.messung.perioden || [];
    if (perioden.length === 0) {
      messungList.innerHTML = '<p class="hz-muted" style="font-style:italic;font-size:13px;color:var(--ink-400);margin:4px 0;">Noch keine Periode. Jahres-Fallback wird verwendet.</p>';
      return;
    }
    messungList.innerHTML = perioden.map((p: any) => `
      <div class="period period-meter" data-mp-id="${escapeHtml(p.id)}">
        <input class="input" type="date" data-p-field="vonDatum" value="${escapeHtml(p.vonDatum || '')}" />
        <input class="input" type="date" data-p-field="bisDatum" value="${escapeHtml(p.bisDatum || '')}" />
        <div class="input-group">
          <input class="input" type="number" step="any" min="0" data-p-field="standAnfang" value="${p.standAnfang ?? ''}" />
          <span class="input-group__unit">kWh</span>
        </div>
        <div class="input-group">
          <input class="input" type="number" step="any" min="0" data-p-field="wertKWh" value="${p.wertKWh ?? ''}" title="Differenz zum Endstand" />
          <span class="input-group__unit">kWh</span>
        </div>
        <button type="button" class="btn btn--ghost" aria-label="Entfernen" data-mp-remove style="padding:0;width:28px;height:28px;justify-self:end;">${SVG_REMOVE}</button>
      </div>
    `).join('');
  }

  function renderBstdPerioden() {
    if (!bstdList) return;
    const perioden = heizlastState.get().heizlast.bstd.perioden || [];
    if (perioden.length === 0) {
      bstdList.innerHTML = '<p class="hz-muted" style="font-style:italic;font-size:13px;color:var(--ink-400);margin:4px 0;">Noch keine Periode.</p>';
      return;
    }
    bstdList.innerHTML = perioden.map((p: any) => `
      <div class="period period-bstd" data-bp-id="${escapeHtml(p.id)}">
        <input class="input" type="date" data-p-field="vonDatum" value="${escapeHtml(p.vonDatum || '')}" />
        <input class="input" type="date" data-p-field="bisDatum" value="${escapeHtml(p.bisDatum || '')}" />
        <div class="input-group">
          <input class="input" type="number" step="any" min="0" data-p-field="nennleistungKw" value="${p.nennleistungKw ?? ''}" />
          <span class="input-group__unit">kW</span>
        </div>
        <div class="input-group">
          <input class="input" type="number" step="any" min="0" data-p-field="stunden" value="${p.stunden ?? ''}" />
          <span class="input-group__unit">h</span>
        </div>
        <button type="button" class="btn btn--ghost" aria-label="Entfernen" data-bp-remove style="padding:0;width:28px;height:28px;justify-self:end;">${SVG_REMOVE}</button>
      </div>
    `).join('');
  }

  // Add-Period Buttons (alle drei)
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const btn = t.closest('[data-hz-action="add-period"]') as HTMLElement | null;
    if (!btn) return;
    const kind = btn.getAttribute('data-period-kind');
    if (kind === 'verbrauch') addVerbrauchPeriode();
    else if (kind === 'messung') addMessungPeriode();
    else if (kind === 'bstd') addBstdPeriode();
  });

  // Perioden-Input-Handler
  document.addEventListener('input', (ev) => {
    const t = ev.target as HTMLInputElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const field = t.getAttribute('data-p-field');
    if (!field) return;
    // Verbrauch
    const vp = t.closest('[data-vp-id]') as HTMLElement | null;
    if (vp) {
      const id = vp.getAttribute('data-vp-id')!;
      const raw = t.value;
      const patch: any = {};
      if (field === 'wert') patch.wert = parseFloat(raw) || 0;
      else patch[field] = raw;
      updateVerbrauchPeriode(id, patch);
      return;
    }
    // Messung
    const mp = t.closest('[data-mp-id]') as HTMLElement | null;
    if (mp) {
      const id = mp.getAttribute('data-mp-id')!;
      const raw = t.value;
      const patch: any = {};
      if (field === 'wertKWh' || field === 'standAnfang') patch[field] = parseFloat(raw) || 0;
      else patch[field] = raw;
      updateMessungPeriode(id, patch);
      return;
    }
    // Bstd
    const bp = t.closest('[data-bp-id]') as HTMLElement | null;
    if (bp) {
      const id = bp.getAttribute('data-bp-id')!;
      const raw = t.value;
      const patch: any = {};
      if (field === 'stunden' || field === 'nennleistungKw') patch[field] = parseFloat(raw) || 0;
      else patch[field] = raw;
      updateBstdPeriode(id, patch);
    }
  });
  document.addEventListener('change', (ev) => {
    const t = ev.target as HTMLSelectElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const field = t.getAttribute('data-p-field');
    if (field !== 'energietraeger') return;
    const vp = t.closest('[data-vp-id]') as HTMLElement | null;
    if (!vp) return;
    updateVerbrauchPeriode(vp.getAttribute('data-vp-id')!, { energietraeger: t.value } as any);
  });

  // Perioden-Remove
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const vpBtn = t.closest('[data-vp-remove]') as HTMLElement | null;
    if (vpBtn) {
      const row = vpBtn.closest('[data-vp-id]') as HTMLElement | null;
      if (row) removeVerbrauchPeriode(row.getAttribute('data-vp-id')!);
      return;
    }
    const mpBtn = t.closest('[data-mp-remove]') as HTMLElement | null;
    if (mpBtn) {
      const row = mpBtn.closest('[data-mp-id]') as HTMLElement | null;
      if (row) removeMessungPeriode(row.getAttribute('data-mp-id')!);
      return;
    }
    const bpBtn = t.closest('[data-bp-remove]') as HTMLElement | null;
    if (bpBtn) {
      const row = bpBtn.closest('[data-bp-id]') as HTMLElement | null;
      if (row) removeBstdPeriode(row.getAttribute('data-bp-id')!);
    }
  });

  // ------------------------------------------------------------
  // 7. Method-Toggles (exklusive <details name="heizlast-method">)
  // ------------------------------------------------------------
  // Browser erzwingt Exklusivitaet durch name-Attribut. Wir spiegeln den Zustand
  // auf methodsEnabled.
  document.querySelectorAll<HTMLDetailsElement>('details[name="heizlast-method"]').forEach((det) => {
    det.addEventListener('toggle', () => {
      const method = det.getAttribute('data-hz-method') as 'verbrauch' | 'messung' | 'bstd' | 'override' | null;
      if (!method) return;
      const s = heizlastState.get();
      const newEnabled = {
        verbrauch: method === 'verbrauch' && det.open,
        messung: method === 'messung' && det.open,
        bstd: method === 'bstd' && det.open,
        override: method === 'override' && det.open,
      };
      // Wenn nichts offen ist, lassen wir den letzten Zustand stehen (Bauperiode-Fallback).
      const anyOpen = Object.values(newEnabled).some((v) => v);
      if (anyOpen) {
        heizlastState.setKey('heizlast', { ...s.heizlast, methodsEnabled: newEnabled });
        isDirty.set(true);
      }
    });
  });

  // ------------------------------------------------------------
  // 8. Gate-Sync (details.open <-> hidden checkbox)
  // ------------------------------------------------------------
  // Gate traegt <details data-hz-gate-path> mit innerer <input type="checkbox"
  // data-hz-gate-input>. bindings.ts haelt die Checkbox am State; wir spiegeln
  // den Wert in details.open + .gate__state-Text.
  function syncGates() {
    document.querySelectorAll<HTMLDetailsElement>('details[data-hz-gate-path]').forEach((det) => {
      const cb = det.querySelector<HTMLInputElement>('[data-hz-gate-input]');
      if (!cb) return;
      if (det.open !== cb.checked) det.open = cb.checked;
      const stateEl = det.querySelector('[data-hz-gate-state]');
      if (stateEl) stateEl.textContent = cb.checked ? 'Ja' : 'Nein';
    });
  }
  // Klick auf Gate-Summary: toggelt Checkbox (und damit State).
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const summary = t.closest('.gate__head') as HTMLElement | null;
    if (!summary) return;
    const det = summary.closest('details[data-hz-gate-path]') as HTMLDetailsElement | null;
    if (!det) return;
    const cb = det.querySelector<HTMLInputElement>('[data-hz-gate-input]');
    if (!cb) return;
    // Browser wird details.open gleich umschalten — wir spiegeln das in die Checkbox.
    // Da das toggle-Event erst nach click feuert, verwenden wir requestAnimationFrame.
    requestAnimationFrame(() => {
      if (cb.checked !== det.open) {
        cb.checked = det.open;
        cb.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });

  // Addon-Gate (Sanierung): dasselbe Prinzip, aber data-hz-addon-input.
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t || typeof t.closest !== 'function') return;
    const summary = t.closest('.addon__head') as HTMLElement | null;
    if (!summary) return;
    const det = summary.closest('details[data-hz-addon]') as HTMLDetailsElement | null;
    if (!det) return;
    const cb = det.querySelector<HTMLInputElement>('[data-hz-addon-input]');
    if (!cb) return;
    requestAnimationFrame(() => {
      if (cb.checked !== det.open) {
        cb.checked = det.open;
        cb.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });
  function syncAddons() {
    document.querySelectorAll<HTMLDetailsElement>('details[data-hz-addon]').forEach((det) => {
      const cb = det.querySelector<HTMLInputElement>('[data-hz-addon-input]');
      if (!cb) return;
      if (det.open !== cb.checked) det.open = cb.checked;
    });
  }

  // ------------------------------------------------------------
  // 9. WW-Panes
  // ------------------------------------------------------------
  function syncWwPanes() {
    const method = heizlastState.get().warmwasser.method;
    document.querySelectorAll<HTMLElement>('[data-hz-ww-pane]').forEach((el) => {
      const isActive = el.getAttribute('data-hz-ww-pane') === method;
      if (isActive) el.setAttribute('data-active', 'true');
      else el.removeAttribute('data-active');
    });
  }

  // ------------------------------------------------------------
  // 10. Notes: roter Dot wenn Text vorhanden
  // ------------------------------------------------------------
  function syncNotes() {
    const n = heizlastState.get().notizen;
    document.querySelectorAll<HTMLElement>('.notes[data-hz-note-slot]').forEach((el) => {
      const key = el.getAttribute('data-hz-note-slot') as keyof typeof n;
      const note = n[key];
      const has = !!(note && note.text && note.text.length > 0);
      el.classList.toggle('has-content', has);
    });
  }

  // ------------------------------------------------------------
  // 11. Compute-Subscriber -> KPIs + Summary
  // ------------------------------------------------------------
  function ampelFromPlausi(wm2: number | null): 'gruen' | 'gelb' | 'rot' {
    if (wm2 == null) return 'gelb';
    if (wm2 < 25 || wm2 > 180) return 'rot';
    if (wm2 < 40 || wm2 > 140) return 'gelb';
    return 'gruen';
  }
  function ampelLabel(a: 'gruen' | 'gelb' | 'rot'): string {
    return a === 'gruen' ? 'plausibel' : a === 'gelb' ? 'grenzwertig' : 'unplausibel';
  }
  function labelBauperiode(id: string): string {
    const p = BAUPERIODEN.find((b) => b.id === id);
    return p ? p.label : id;
  }
  function labelTyp(id: string): string {
    return (({ efh: 'Einfamilienhaus', mfh: 'Mehrfamilienhaus', buero: 'Büro / Gewerbe' } as any)[id]) || id;
  }
  function labelLage(id: string): string {
    return (({ mittelland: 'Mittelland (≤ 800 m)', hoehe: 'Höhenlage (> 800 m)' } as any)[id]) || id;
  }
  function labelStatus(id: string): string {
    return (({
      arbeit: 'In Arbeit',
      offeriert: 'Offeriert',
      bestellt: 'Bestellt',
      abgeschlossen: 'Abgeschlossen',
      archiv: 'Archiv',
    } as any)[id]) || id;
  }
  function labelMethode(s: any): string {
    const e = s.heizlast.methodsEnabled;
    if (e?.override) return 'Direkteingabe';
    if (e?.bstd) return 'Betriebsstunden';
    if (e?.messung) return 'Zählermessung';
    if (e?.verbrauch) return 'Brennstoffverbrauch';
    return 'Bauperiode (Fallback)';
  }

  function setKpi(key: string, value: string, attrs?: Record<string, string>) {
    document.querySelectorAll(`[data-kpi="${key}"]`).forEach((el) => {
      el.textContent = value;
    });
    if (attrs) {
      document.querySelectorAll(`[data-kpi="${key}"]`).forEach((el) => {
        // Attribute auf dem unmittelbaren Ziel-Element setzen — falls es ein
        // direkter .result-hero__stat-Container ist, landen sie dort; sonst
        // klettern wir eine Ebene hoch.
        const target = (el.closest('[data-hz-plausi]') as HTMLElement | null) || (el as HTMLElement);
        Object.entries(attrs).forEach(([k, v]) => target.setAttribute(k, v));
      });
    }
  }
  function setSum(key: string, value: string) {
    document.querySelectorAll(`[data-hz-sum="${key}"]`).forEach((el) => {
      el.textContent = value;
    });
  }

  function renderAll() {
    const s = heizlastState.get();
    const r = heizlastCompute.get();

    // Methoden-Sums (fuer method__status)
    const vpCount = s.heizlast.verbrauch.perioden.length;
    const mpCount = s.heizlast.messung.perioden.length;
    const bpCount = s.heizlast.bstd.perioden.length;
    setSum('verbrauchPerioden', vpCount === 0 ? 'Einzelwert Bₐ' : vpCount === 1 ? '1 Periode' : `${vpCount} Perioden`);
    setSum('messungPerioden', mpCount === 0 ? 'keine Perioden' : mpCount === 1 ? '1 Periode' : `${mpCount} Perioden`);
    setSum('bstdPerioden', bpCount === 0 ? 'keine Perioden' : bpCount === 1 ? '1 Periode' : `${bpCount} Perioden`);
    setSum('overrideStatus', s.heizlast.override.qhl > 0 ? fmt(s.heizlast.override.qhl) + ' kW' : 'nicht verwendet');

    // qhlVerbrauch (Rohwert aus Verbrauchsmethode)
    setKpi('qhlVerbrauch', fmt(r.qhlRaw?.value));
    setKpi('qhlRaw', fmt(r.qhlRaw?.value));
    setKpi('qhlKorr', fmt(r.qhlKorr?.value));

    // vwuAbzugWirkung: kW-Aequivalent des Warmwasser-Abzugs (fuer Inline-Result)
    const vAbz = Number(s.heizlast.verbrauch.vwuAbzug) || 0;
    // Grobe Abschaetzung: 200 L/d bei 45 K ΔT ~ 0.42 kW; proportional skalieren
    const vAbzKw = (vAbz / 200) * 0.42;
    setSum('vwuAbzugWirkung', vAbz > 0 ? fmt(vAbzKw, 2) : '0.00');

    // Plausi + Ampel
    const ampel = ampelFromPlausi(r.plausi?.value ?? null);
    setKpi('plausi', fmt(r.plausi?.value, 1), {
      'data-ampel': ampel,
      'title': 'Spezifische Heizleistung — ' + ampelLabel(ampel),
    });

    // Weitere KPIs
    setKpi('qw', fmt(r.qw?.value));
    setKpi('qoff', fmt(r.qoff?.value));
    setKpi('tvoll', fmtInt(r.tvoll));
    setKpi('qwwTag', fmt(r.qwwTagVal?.value));
    setKpi('vwu', fmtInt(r.vwu?.value));

    // Qas = Pool + Lueftung
    const qasPool = Number(s.zuschlaege.qasPool) || 0;
    const qasLueftung = Number(s.zuschlaege.qasLueftung) || 0;
    const qasEff = qasPool + qasLueftung;
    if (Math.abs((Number(s.zuschlaege.qas) || 0) - qasEff) > 0.001) {
      heizlastState.setKey('zuschlaege', { ...s.zuschlaege, qas: qasEff });
    }
    setKpi('qas', fmt(qasEff));

    setKpi('qh', fmt(r.qh?.value));
    setKpi('wwSpeicher', fmtInt(r.wwSpeicherGerundet));
    setKpi('puffer', fmtInt(r.pufferGerundet));

    // Sanierungs-Status (Inline)
    const sanItems = s.heizlast.sanierungMassnahmen || [];
    setSum('sanierungStatus', sanItems.length === 0
      ? 'keine Massnahmen'
      : sanItems.length === 1 ? '1 Massnahme' : `${sanItems.length} Massnahmen`);
    const delta = (r.sanierungDelta?.value ?? 0) * 100;
    setSum('sanierungDelta', sanItems.length === 0 ? '0' : fmt(delta, 1));

    // Summary (Section 6)
    setSum('projectName', s.projectName || '–');
    setSum('customerName', s.customerName || '–');
    setSum('address', s.address || '–');
    setSum('gebaeudeTypLage', `${labelTyp(s.gebaeude.typ)} · ${labelLage(s.gebaeude.lage)}`);
    setSum('bauperiodeEbf', `${labelBauperiode(s.gebaeude.bauperiode)} · ${fmt(s.gebaeude.ebf, 0)} m²`);
    setSum('tvoll', fmtInt(r.tvoll));
    setSum('methode', labelMethode(s));
    // Rohwerte / Empfehlungen
    setSum('wwSpeicherRoh', fmtInt(r.wwSpeicherRoh?.value ?? null) + ' L');
    setSum('pufferRoh', fmtInt(r.pufferRoh?.value ?? null) + ' L');
    setSum('wwSpeicher', fmtInt(r.wwSpeicherGerundet));
    setSum('puffer', fmtInt(r.pufferGerundet));

    // Status-Badge (Section 6)
    document.querySelectorAll<HTMLElement>('[data-hz-sum="projectStatus"]').forEach((el) => {
      el.textContent = labelStatus(s.status);
      el.setAttribute('data-status', s.status);
    });

    // Listen
    renderZimmer();
    renderSanierung();
    renderVerbrauchPerioden();
    renderMessungPerioden();
    renderBstdPerioden();

    // Gates + Panes + Notes
    syncGates();
    syncAddons();
    syncWwPanes();
    syncNotes();
  }

  renderAll();
  heizlastCompute.subscribe(() => renderAll());
  heizlastState.subscribe(() => renderAll());

  // ------------------------------------------------------------
  // 12. Save-Buttons / Status
  // ------------------------------------------------------------
  const saveCloudBtns = Array.from(document.querySelectorAll('[data-hz-action="save-cloud"]')) as HTMLButtonElement[];
  const saveCloudNewBtns = Array.from(document.querySelectorAll('[data-hz-action="save-cloud-new"]')) as HTMLButtonElement[];
  const openProjectsBtns = Array.from(document.querySelectorAll('[data-hz-action="open-projects"]')) as HTMLButtonElement[];
  const statusEl = document.querySelector('[data-hz-save-status]') as HTMLElement | null;
  const statusLabel = document.querySelector('[data-hz-save-label]') as HTMLElement | null;

  function setStatus(tone: 'ok' | 'busy' | 'err' | 'idle', text: string) {
    if (statusEl) statusEl.setAttribute('data-tone', tone);
    if (statusLabel) statusLabel.textContent = text;
  }

  function refreshCloudButtons(auth: boolean) {
    saveCloudBtns.forEach((b) => { b.disabled = !auth; });
    saveCloudNewBtns.forEach((b) => { b.disabled = !auth; });
    openProjectsBtns.forEach((b) => { b.disabled = !auth; });
    const loginLabel = document.querySelector('[data-hz-login-label]') as HTMLElement | null;
    if (loginLabel) loginLabel.textContent = auth ? 'Abmelden' : 'Anmelden';
  }

  // Modal-Refs VOR uiState.subscribe, sonst TDZ in refreshLoginView().
  // (uiState.subscribe feuert die Callback sofort beim Registrieren.)
  const loginModal = document.getElementById('hz-login-modal') as HTMLElement | null;
  const projectsModal = document.getElementById('hz-projects-modal') as HTMLElement | null;
  const exportModal = document.getElementById('hz-export-modal') as HTMLElement | null;

  let lastCloudSaveSeen: number | null = null;
  uiState.subscribe((u) => {
    refreshCloudButtons(u.isAuthenticated);
    document.body.classList.toggle('is-auth', u.isAuthenticated);
    if (u.syncInFlight) setStatus('busy', 'Synchronisiere …');
    else if (u.lastError) setStatus('err', u.lastError);
    else if (u.lastCloudSave) setStatus('ok', 'In Cloud gespeichert.');
    else setStatus('idle', 'Bereit.');
    if (u.lastCloudSave && u.lastCloudSave !== lastCloudSaveSeen && !u.syncInFlight && !u.lastError) {
      lastCloudSaveSeen = u.lastCloudSave;
    }
    refreshLoginView();
  });

  isDirty.subscribe((dirty) => {
    if (dirty) {
      setTimeout(() => {
        uiState.setKey('lastLocalSave', Date.now());
        isDirty.set(false);
      }, 600);
    }
  });

  function computedSummary() {
    const summary = heizlastCompute.get().summary;
    return {
      qhl: summary.qhlKw,
      qh: summary.qhKw,
      ebf: heizlastState.get().gebaeude.ebf,
    };
  }

  document.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const save = t.closest('[data-hz-action="save-cloud"]') as HTMLButtonElement | null;
    if (save && !save.disabled) {
      try { await saveProject({ asNew: false, computed: computedSummary() }); }
      catch (err) { console.warn('save failed:', err); }
      return;
    }
    const saveNew = t.closest('[data-hz-action="save-cloud-new"]') as HTMLButtonElement | null;
    if (saveNew && !saveNew.disabled) {
      try { await saveProject({ asNew: true, computed: computedSummary() }); }
      catch (err) { console.warn('save-as-new failed:', err); }
    }
  });

  // ------------------------------------------------------------
  // 13. Modal-Infrastruktur
  // ------------------------------------------------------------
  // Modal-Refs wurden oben (vor uiState.subscribe) bereits deklariert.

  let lastTrigger: HTMLElement | null = null;

  function openModal(el: HTMLElement | null, trigger?: HTMLElement | null): void {
    if (!el) return;
    if (trigger) lastTrigger = trigger;
    el.hidden = false;
    document.body.classList.add('hz-modal-open');
    setTimeout(() => {
      const focusable = el.querySelector<HTMLElement>(
        'input:not([type="hidden"]):not([disabled]), select:not([disabled]), textarea:not([disabled]), button:not([disabled])',
      );
      focusable?.focus();
    }, 30);
  }
  function closeModal(el: HTMLElement | null): void {
    if (!el) return;
    el.hidden = true;
    const anyOpen =
      (loginModal && !loginModal.hidden) ||
      (projectsModal && !projectsModal.hidden) ||
      (exportModal && !exportModal.hidden);
    if (!anyOpen) document.body.classList.remove('hz-modal-open');
    if (lastTrigger) { lastTrigger.focus(); lastTrigger = null; }
  }

  document.addEventListener('keydown', (ev) => {
    if (ev.key !== 'Escape') return;
    if (loginModal && !loginModal.hidden) closeModal(loginModal);
    if (projectsModal && !projectsModal.hidden) closeModal(projectsModal);
    if (exportModal && !exportModal.hidden) closeModal(exportModal);
  });

  // Focus-Trap (Tab/Shift+Tab zyklisiert im .modal)
  function getVisibleModal(): HTMLElement | null {
    if (loginModal && !loginModal.hidden) return loginModal;
    if (projectsModal && !projectsModal.hidden) return projectsModal;
    if (exportModal && !exportModal.hidden) return exportModal;
    return null;
  }
  document.addEventListener('keydown', (ev) => {
    if (ev.key !== 'Tab') return;
    const modal = getVisibleModal();
    if (!modal) return;
    const card = modal.querySelector('.modal') || modal;
    const focusables = Array.from(
      card.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([type="hidden"]):not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ),
    ).filter((el) => el.offsetParent !== null || el === document.activeElement);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (ev.shiftKey) {
      if (active === first || !card.contains(active)) { ev.preventDefault(); last.focus(); }
    } else {
      if (active === last || !card.contains(active)) { ev.preventDefault(); first.focus(); }
    }
  });

  // Dismiss via [data-hz-modal-dismiss] oder Klick auf Backdrop
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const dismiss = t.closest('[data-hz-modal-dismiss]') as HTMLElement | null;
    if (dismiss) {
      const modal = dismiss.closest('.modal-backdrop') as HTMLElement | null;
      if (modal) closeModal(modal);
      return;
    }
    // Backdrop-Click (ausserhalb von .modal)
    const backdrop = (t as HTMLElement).matches?.('.modal-backdrop') ? (t as HTMLElement) : null;
    if (backdrop) closeModal(backdrop);
  });

  // ------------------------------------------------------------
  // 13a. Login-Modal
  // ------------------------------------------------------------
  const loginForm = document.getElementById('hz-login-form') as HTMLFormElement | null;
  const loginPassword = document.getElementById('f-login-pw') as HTMLInputElement | null;
  const loginSubmit = document.getElementById('hz-login-submit') as HTMLButtonElement | null;
  const loginError = document.getElementById('hz-login-error') as HTMLElement | null;
  const logoutSubmit = document.getElementById('hz-logout-submit') as HTMLButtonElement | null;
  const logoutError = document.getElementById('hz-logout-error') as HTMLElement | null;

  function showError(el: HTMLElement | null, msg: string) {
    if (!el) return;
    el.textContent = msg;
    el.hidden = false;
  }
  function hideError(el: HTMLElement | null) {
    if (!el) return;
    el.hidden = true;
    el.textContent = '';
  }
  function refreshLoginView() {
    if (!loginModal) return;
    const authed = uiState.get().isAuthenticated;
    loginModal.querySelectorAll<HTMLElement>('[data-hz-login-view]').forEach((el) => {
      const view = el.getAttribute('data-hz-login-view');
      el.hidden = (view === 'signin' ? authed : !authed);
    });
  }

  if (loginForm && loginPassword) {
    loginForm.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      hideError(loginError);
      const pw = loginPassword.value;
      if (!pw) { showError(loginError, 'Bitte Passwort eingeben.'); return; }
      if (loginSubmit) { loginSubmit.disabled = true; loginSubmit.textContent = 'Prüfe …'; }
      try {
        const resp = await fetch('/api/heizlast-auth', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: pw }),
        });
        const data = await resp.json().catch(() => ({}));
        if (!resp.ok || !data.success) throw new Error(data.error || 'Anmeldung fehlgeschlagen');
        uiState.setKey('isAuthenticated', true);
        loginPassword.value = '';
        closeModal(loginModal);
      } catch (err: any) {
        showError(loginError, err?.message || 'Anmeldung fehlgeschlagen');
      } finally {
        if (loginSubmit) { loginSubmit.disabled = false; loginSubmit.textContent = 'Anmelden'; }
      }
    });
  }
  // Login-Button (Anmelden-Button im Modal oeffnet das Form; Submit-Click loest submit aus)
  if (loginSubmit) {
    loginSubmit.addEventListener('click', () => {
      if (loginForm) loginForm.requestSubmit();
    });
  }

  if (logoutSubmit) {
    logoutSubmit.addEventListener('click', async () => {
      hideError(logoutError);
      logoutSubmit.disabled = true;
      logoutSubmit.textContent = 'Melde ab …';
      try {
        const resp = await fetch('/api/heizlast-auth', { method: 'DELETE', credentials: 'same-origin' });
        if (!resp.ok) throw new Error('Abmelden fehlgeschlagen');
        uiState.setKey('isAuthenticated', false);
        projectList.set([]);
        projectListLoaded.set(false);
        closeModal(loginModal);
      } catch (err: any) {
        showError(logoutError, err?.message || 'Abmelden fehlgeschlagen');
      } finally {
        logoutSubmit.disabled = false;
        logoutSubmit.textContent = 'Abmelden';
      }
    });
  }

  const loginTrigger = document.getElementById('hz-login-trigger');
  if (loginTrigger) {
    loginTrigger.addEventListener('click', () => {
      refreshLoginView();
      openModal(loginModal, loginTrigger);
    });
  }

  // ------------------------------------------------------------
  // 13b. Projekte-Modal
  // ------------------------------------------------------------
  const projectsListEl = document.getElementById('hz-projects-list');
  const projectsCountEl = document.getElementById('hz-projects-count');
  const projectsRefreshBtn = document.getElementById('hz-projects-refresh');

  function setProjectsState(name: 'loading' | 'empty' | 'error' | 'list', msg?: string) {
    if (!projectsModal) return;
    const body = projectsModal.querySelector('[data-hz-projects-state]');
    if (body) body.setAttribute('data-hz-projects-state', name);
    if (name === 'error' && msg) {
      const err = projectsModal.querySelector('#hz-projects-error');
      if (err) err.textContent = msg;
    }
  }

  function renderProjectsList(items: any[]) {
    if (!projectsListEl) return;
    if (projectsCountEl) {
      projectsCountEl.textContent = items.length === 1 ? '1 Projekt' : items.length + ' Projekte';
    }
    if (!items.length) { setProjectsState('empty'); return; }
    const activeId = heizlastState.get().projectId || '';
    projectsListEl.innerHTML = items.map((p) => {
      const name = escapeHtml(p.projectName || 'Unbenannt');
      const cust = p.customerName ? escapeHtml(p.customerName) : '';
      const addr = p.address ? escapeHtml(p.address) : '';
      const status = p.status || 'arbeit';
      const updated = p.updatedAt
        ? new Date(p.updatedAt).toLocaleString('de-CH', { dateStyle: 'short', timeStyle: 'short' })
        : '–';
      const qhl = p.qhl != null ? fmt(p.qhl) + ' kW' : '–';
      const qh = p.qh != null ? fmt(p.qh) + ' kW' : '–';
      const ebf = p.ebf != null ? fmt(p.ebf, 0) + ' m²' : '–';
      return `
        <div class="project-card" data-project-id="${escapeHtml(p._id)}"${p._id === activeId ? ' data-active="true"' : ''}>
          <div class="project-card__main">
            <h3 class="project-card__title">
              ${name}
              <span class="status-badge" data-status="${escapeHtml(status)}">${escapeHtml(labelStatus(status))}</span>
            </h3>
            ${cust ? `<p class="project-card__sub">${cust}${addr ? ' · ' + addr : ''}</p>` : (addr ? `<p class="project-card__sub">${addr}</p>` : '')}
            <p class="project-card__meta">
              <span>EBF <strong>${ebf}</strong></span>
              <span>Qhl <strong>${qhl}</strong></span>
              <span>Qh <strong>${qh}</strong></span>
              <span>Aktualisiert <strong>${updated}</strong></span>
            </p>
          </div>
          <div class="project-card__actions">
            <button type="button" class="btn" data-project-action="load" data-project-id="${escapeHtml(p._id)}">Laden</button>
            <button type="button" class="btn btn--danger-ghost" data-project-action="delete" data-project-id="${escapeHtml(p._id)}">Löschen</button>
          </div>
        </div>
      `;
    }).join('');
    setProjectsState('list');
  }

  async function reloadProjects() {
    setProjectsState('loading');
    try {
      const items = await listProjects();
      renderProjectsList(items);
    } catch (err: any) {
      if ((err?.message || '').toLowerCase().includes('nicht autorisiert')) {
        setProjectsState('error', 'Bitte zuerst anmelden.');
      } else {
        setProjectsState('error', err?.message || 'Fehler beim Laden.');
      }
    }
  }

  if (projectsRefreshBtn) {
    projectsRefreshBtn.addEventListener('click', () => { reloadProjects(); });
  }

  document.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-project-action]') as HTMLElement | null;
    if (!btn) return;
    const action = btn.getAttribute('data-project-action');
    const id = btn.getAttribute('data-project-id');
    if (!action || !id) return;
    if (action === 'load') {
      try {
        await loadProject(id);
        closeModal(projectsModal);
        setStatus('ok', 'Projekt geladen.');
      } catch (err: any) {
        alert('Laden fehlgeschlagen: ' + (err?.message || 'unbekannter Fehler'));
      }
    } else if (action === 'delete') {
      if (!confirm('Dieses Projekt dauerhaft aus der Cloud löschen?')) return;
      try {
        await deleteProject(id);
        renderProjectsList(projectList.get());
      } catch (err: any) {
        alert('Löschen fehlgeschlagen: ' + (err?.message || 'unbekannter Fehler'));
      }
    }
  });

  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-hz-action="open-projects"]') as HTMLButtonElement | null;
    if (!btn || btn.disabled) return;
    openModal(projectsModal, btn);
    reloadProjects();
  });

  // ------------------------------------------------------------
  // 13c. Export-Modal
  // ------------------------------------------------------------
  const exportForm = document.getElementById('hz-export-form') as HTMLFormElement | null;
  const exportFilename = document.getElementById('f-export-name') as HTMLInputElement | null;

  function openExportModal(trigger: HTMLElement | null) {
    if (exportFilename) exportFilename.value = defaultFilename();
    openModal(exportModal, trigger);
  }

  if (exportForm) {
    exportForm.addEventListener('submit', (ev) => {
      ev.preventDefault();
      const formatEl = exportForm.querySelector<HTMLInputElement>('input[name="export-fmt"]:checked');
      const format = (formatEl?.value === 'json' ? 'json' : 'pdf') as 'pdf' | 'json';
      const parts: Record<ExportPart, boolean> = {
        cover: true,
        objekt: true,
        resultate: true,
        diagramm: true,
        plausi: false,
        formeln: false,
        notizenBereiche: true,
        notizenProjekt: true,
      };
      // Checkboxen lesen: name="part-<key>"
      const mapping: Record<string, ExportPart> = {
        'part-cover': 'cover',
        'part-objekt': 'objekt',
        'part-resultate': 'resultate',
        'part-diagramm': 'diagramm',
        'part-plausi': 'plausi',
        'part-formeln': 'formeln',
        'part-notizenBereiche': 'notizenBereiche',
        'part-notizenProjekt': 'notizenProjekt',
      };
      Object.entries(mapping).forEach(([cbName, partKey]) => {
        const cb = exportForm.querySelector<HTMLInputElement>(`input[name="${cbName}"]`);
        if (cb) parts[partKey] = cb.checked;
      });
      const filename = exportFilename?.value.trim() || defaultFilename();
      try {
        runExport({ format, parts, filename });
        closeModal(exportModal);
      } catch (err: any) {
        console.warn('Export failed:', err);
        alert('Export fehlgeschlagen: ' + (err?.message || 'unbekannter Fehler'));
      }
    });
  }

  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-hz-action="export"]') as HTMLElement | null;
    if (!btn) return;
    openExportModal(btn);
  });

  // Neues Projekt mit Confirm-Dialog (Block I: Export-Angebot bei Dirty)
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-hz-action="new-project"]') as HTMLButtonElement | null;
    if (!btn) return;
    const u = uiState.get();
    const dirty = isDirty.get();
    if (u.isAuthenticated && dirty) {
      const ok = confirm('Neues Projekt starten? Es gibt ungespeicherte Änderungen.\n\nOK = Neues Projekt\nAbbrechen = erst speichern / exportieren');
      if (!ok) {
        const ok2 = confirm('Vor dem Verwerfen als PDF oder JSON exportieren?');
        if (ok2) openExportModal(btn);
        return;
      }
    } else {
      if (!confirm('Neues Projekt starten? Aktuelle Eingaben gehen verloren.')) return;
    }
    hardReset();
    setStatus('idle', 'Neues Projekt.');
  });

  // ------------------------------------------------------------
  // 14. beforeunload — Warnung bei ungespeicherten Cloud-Aenderungen
  // ------------------------------------------------------------
  window.addEventListener('beforeunload', (ev) => {
    const u = uiState.get();
    if (u.isAuthenticated && isDirty.get() && !u.syncInFlight) {
      ev.preventDefault();
      (ev as BeforeUnloadEvent).returnValue = '';
    }
  });
</script>

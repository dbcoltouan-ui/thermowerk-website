---
// Heizlast-Rechner — Hauptseite (Phase 4)
// Long-Scroll mit sieben Sektionen. State wird clientseitig via Nano Stores
// verwaltet (src/lib/heizlast/state.ts) und automatisch in localStorage
// zwischengespeichert.
import HeizlastLayout from '../layouts/HeizlastLayout.astro';
import LeistungsDiagramm from '../components/heizlast/LeistungsDiagramm.astro';
import Section1Gebaeude from '../components/heizlast/sections/Section1Gebaeude.astro';
import Section2Heizlast from '../components/heizlast/sections/Section2Heizlast.astro';
import Section3Warmwasser from '../components/heizlast/sections/Section3Warmwasser.astro';
import Section4Zuschlaege from '../components/heizlast/sections/Section4Zuschlaege.astro';
import Section6Speicher from '../components/heizlast/sections/Section6Speicher.astro';
import Section7Projekt from '../components/heizlast/sections/Section7Projekt.astro';
import LoginModal from '../components/heizlast/LoginModal.astro';
import ProjectsModal from '../components/heizlast/ProjectsModal.astro';
import ExportModal from '../components/heizlast/ExportModal.astro';
import PrintCover from '../components/heizlast/PrintCover.astro';
---
<HeizlastLayout
  title="Heizlast-Rechner | Thermowerk"
  description="Professionelle Heizlast- und Wärmepumpen-Auslegung nach FWS, SIA und VDI."
>
  <PrintCover />
  <Section1Gebaeude />
  <Section2Heizlast />
  <Section3Warmwasser />
  <Section4Zuschlaege />
  <LeistungsDiagramm />
  <Section6Speicher />
  <Section7Projekt />

  <LoginModal />
  <ProjectsModal />
  <ExportModal />
</HeizlastLayout>

<script>
  // ============================================================
  // Heizlast-Rechner — Glue-JS
  // ------------------------------------------------------------
  // 1. bootFromStorage() + subscribeAutoSave() + bootBindings()
  // 2. Render dynamischer Listen (Zimmer, Sanierung, Personen-Einheiten)
  // 3. Wire Toggle-Aktivierung (M2-Methoden + WW-Pane-Umschaltung)
  // 4. Compute-Subscriber -> [data-kpi] + [data-hz-sum] + Ampel + Status
  // 5. Speichern/Laden-Buttons
  // ============================================================
  import {
    heizlastState,
    uiState,
    isDirty,
    addRaum,
    removeRaum,
    updateRaum,
    sumRaumFlaechen,
    sumRaumFlaechenNetto,
    raumFlaeche,
  } from '../lib/heizlast/state.ts';
  import { heizlastCompute } from '../lib/heizlast/compute.ts';
  import {
    bootFromStorage,
    subscribeAutoSave,
    hardReset,
  } from '../lib/heizlast/storage.ts';
  import { bootBindings, syncDomFromState } from '../lib/heizlast/bindings.ts';
  import { clearOverride, resolveDefault } from '../lib/heizlast/state.ts';
  import {
    SANIERUNGS_MASSNAHMEN,
    BAUPERIODEN,
  } from '../lib/heizlast/constants.ts';
  import {
    listProjects,
    loadProject,
    saveProject,
    deleteProject,
    probeAuth,
  } from '../lib/heizlast/projects.ts';
  import { runExport, defaultFilename, type ExportPart } from '../lib/heizlast/export.ts';
  import { projectList, projectListLoaded, replaceState } from '../lib/heizlast/state.ts';

  // ------------------------------------------------------------
  // 1. Boot-Reihenfolge
  // ------------------------------------------------------------
  bootFromStorage();           // localStorage -> Store
  subscribeAutoSave();         // Store -> localStorage (debounced)
  bootBindings();              // DOM <-> Store
  syncDomFromState();          // Initial-Sync falls Boot ohne Store-Change

  // Phase 9 / Block A: Globals fuer OverrideField-Reset-Button.
  // OverrideField.astro ruft diese beim Klick auf den Reset-Pfeil auf.
  (window as any).__hzClearOverride = (path: string) => {
    clearOverride(path);
  };
  (window as any).__hzResolveDefault = (path: string): string | null => {
    const v = resolveDefault(heizlastState.get(), path);
    return v == null ? null : String(v);
  };

  // Auth-Status pruefen (setzt uiState.isAuthenticated).
  probeAuth().then((ok) => { uiState.setKey('isAuthenticated', ok); }).catch(() => {});

  // ------------------------------------------------------------
  // 2. Helpers
  // ------------------------------------------------------------
  function fmt(n: number | null | undefined, d = 2): string {
    if (n == null || !isFinite(n)) return '—';
    return n.toLocaleString('de-CH', { minimumFractionDigits: d, maximumFractionDigits: d });
  }
  function fmtInt(n: number | null | undefined): string {
    if (n == null || !isFinite(n)) return '—';
    return Math.round(n).toLocaleString('de-CH');
  }
  function escapeHtml(s: string): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) => (({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    } as any)[c] as string));
  }

  // ------------------------------------------------------------
  // 3. Zimmer-Liste (EBF-Helper)
  // ------------------------------------------------------------
  const raumList = document.getElementById('hz-raum-list');
  const raumSumEl = document.getElementById('hz-raum-sum-value');
  const raumSumDetailEl = document.getElementById('hz-raum-sum-detail');
  const raumAddBtn = document.getElementById('hz-raum-add');

  function renderRaumList() {
    if (!raumList) return;
    const s = heizlastState.get();
    const raeume = s.gebaeude.raeume || [];
    if (raeume.length === 0) {
      raumList.innerHTML = '<p class="hz-muted hz-raum-empty">Noch keine Zimmer erfasst.</p>';
    } else {
      raumList.innerHTML = raeume.map((r) => {
        const a = raumFlaeche(r);
        const hatDirekt = r.flaecheDirekt != null && r.flaecheDirekt > 0;
        const beheizt = r.beheizt !== false;
        const unbeheizt = !beheizt;
        const laengeVal = r.laenge == null ? '' : r.laenge;
        const breiteVal = r.breite == null ? '' : r.breite;
        const direktVal = r.flaecheDirekt == null ? '' : r.flaecheDirekt;
        // Placeholder: zeigt L×B Berechnung wenn verfügbar
        const lbCalc = (r.laenge != null && r.breite != null && r.laenge > 0 && r.breite > 0)
          ? fmt(r.laenge * r.breite, 1)
          : 'm²';
        const direktPlaceholder = hatDirekt ? '' : lbCalc;
        return `
          <div class="hz-raum-row" data-raum-id="${r.id}" data-direkt="${hatDirekt}" data-beheizt="${beheizt}">
            <input type="text" placeholder="z. B. Wohnzimmer" data-raum-field="name" value="${escapeHtml(r.name)}" />
            <input type="number" step="0.1" min="0" placeholder="m" data-raum-field="laenge" value="${laengeVal}" />
            <input type="number" step="0.1" min="0" placeholder="m" data-raum-field="breite" value="${breiteVal}" />
            <input type="number" step="0.1" min="0" placeholder="${direktPlaceholder}" data-raum-field="flaecheDirekt" value="${direktVal}" />
            <span class="hz-raum-flaeche${a > 0 ? '' : ''}">${a > 0 ? fmt(a, 1) + ' m²' : '—'}</span>
            <div class="hz-raum-unbeheizt" title="Nicht beheizt — zählt nicht in Netto-EBF">
              <input type="checkbox" data-raum-field="unbeheizt" ${unbeheizt ? 'checked' : ''} />
            </div>
            <button type="button" class="hz-raum-remove" aria-label="Entfernen" data-raum-remove>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
            </button>
          </div>
        `;
      }).join('');
    }
    const agg = sumRaumFlaechenNetto(raeume);
    if (raumSumEl) raumSumEl.textContent = fmt(agg.netto, 1);
    if (raumSumDetailEl) {
      raumSumDetailEl.textContent = agg.unbeheizt > 0
        ? `(unbeheizt: ${fmt(agg.unbeheizt, 1)} m² abgezogen)`
        : '';
    }
    // H: Netto-Summe immer direkt in EBF schreiben (kein Live-Modus-Toggle mehr)
    if (agg.netto > 0) {
      if (Math.abs(s.gebaeude.ebf - agg.netto) > 0.05) {
        heizlastState.setKey('gebaeude', { ...s.gebaeude, ebf: agg.netto });
      }
    }
  }

  if (raumAddBtn) raumAddBtn.addEventListener('click', () => addRaum(''));

  function parseRaumNumber(value: string): number | null {
    if (value === '' || value == null) return null;
    const n = Number(value);
    if (!isFinite(n) || n < 0) return null;
    return n;
  }

  // Event-Delegation fuer Raum-Inputs
  document.addEventListener('input', (ev) => {
    const t = ev.target as HTMLElement;
    if (!t || typeof t.closest !== 'function') return;
    const row = t.closest('.hz-raum-row') as HTMLElement | null;
    if (!row) return;
    const id = row.getAttribute('data-raum-id');
    const field = t.getAttribute('data-raum-field');
    if (!id || !field) return;
    if (field === 'unbeheizt') return; // change-Handler kümmert sich
    const value = (t as HTMLInputElement).value;
    if (field === 'name') updateRaum(id, { name: value });
    else if (field === 'laenge') updateRaum(id, { laenge: parseRaumNumber(value) });
    else if (field === 'breite') updateRaum(id, { breite: parseRaumNumber(value) });
    else if (field === 'flaecheDirekt') updateRaum(id, { flaecheDirekt: parseRaumNumber(value) });
  });
  document.addEventListener('change', (ev) => {
    const t = ev.target as HTMLElement;
    if (!t || typeof t.closest !== 'function') return;
    const row = t.closest('.hz-raum-row') as HTMLElement | null;
    if (!row) return;
    const id = row.getAttribute('data-raum-id');
    const field = t.getAttribute('data-raum-field');
    if (!id || field !== 'unbeheizt') return;
    const checked = (t as HTMLInputElement).checked;
    // "Unbeheizt" checked = room is NOT heated → beheizt = false
    updateRaum(id, { beheizt: !checked });
  });
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement;
    if (!t || typeof t.closest !== 'function') return;
    const btn = t.closest('[data-raum-remove]') as HTMLElement | null;
    if (!btn) return;
    const row = btn.closest('.hz-raum-row') as HTMLElement | null;
    if (!row) return;
    const id = row.getAttribute('data-raum-id');
    if (id) removeRaum(id);
  });

  // ------------------------------------------------------------
  // 4. Sanierungs-Liste
  // ------------------------------------------------------------
  const sanList = document.getElementById('hz-san-list');
  const sanSelect = document.getElementById('hz-san-select') as HTMLSelectElement | null;
  const sanAddBtn = document.getElementById('hz-san-add');

  function renderSanList() {
    if (!sanList) return;
    const s = heizlastState.get();
    const items = s.heizlast.sanierungMassnahmen || [];
    if (items.length === 0) {
      sanList.innerHTML = '<p class="hz-muted hz-san__empty">Noch keine Massnahme gewählt.</p>';
      return;
    }
    sanList.innerHTML = items.map((m) => `
      <div class="hz-san__row" data-san-id="${m.id}">
        <span class="hz-san__row-label">${escapeHtml(m.label)}</span>
        <div class="hz-field__input-with-unit" style="max-width: 140px;">
          <input type="number" step="1" min="0" max="100" data-san-field="einsparungProzent" value="${m.einsparungProzent}" />
          <span class="hz-field__unit">%</span>
        </div>
        <button type="button" class="hz-san__remove" aria-label="Entfernen" data-san-remove>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
        </button>
      </div>
    `).join('');
  }

  if (sanAddBtn && sanSelect) {
    sanAddBtn.addEventListener('click', () => {
      const val = sanSelect.value;
      if (!val) return;
      const preset = SANIERUNGS_MASSNAHMEN.find((m) => m.id === val);
      if (!preset) return;
      const s = heizlastState.get();
      if (s.heizlast.sanierungMassnahmen.some((m) => m.id === preset.id)) return;
      const next = [...s.heizlast.sanierungMassnahmen, {
        id: preset.id,
        label: preset.label,
        einsparungProzent: preset.default,
      }];
      heizlastState.setKey('heizlast', { ...s.heizlast, sanierungMassnahmen: next, sanierungActive: true });
      isDirty.set(true);
      sanSelect.value = '';
    });
  }

  document.addEventListener('input', (ev) => {
    const t = ev.target as HTMLElement;
    if (!t || typeof t.closest !== 'function') return;
    const row = t.closest('.hz-san__row') as HTMLElement | null;
    if (!row) return;
    const id = row.getAttribute('data-san-id');
    const field = t.getAttribute('data-san-field');
    if (!id || field !== 'einsparungProzent') return;
    const value = Number((t as HTMLInputElement).value) || 0;
    const s = heizlastState.get();
    const next = s.heizlast.sanierungMassnahmen.map((m) =>
      m.id === id ? { ...m, einsparungProzent: value } : m,
    );
    heizlastState.setKey('heizlast', { ...s.heizlast, sanierungMassnahmen: next });
    isDirty.set(true);
  });
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement;
    if (!t || typeof t.closest !== 'function') return;
    const btn = t.closest('[data-san-remove]') as HTMLElement | null;
    if (!btn) return;
    const row = btn.closest('.hz-san__row') as HTMLElement | null;
    if (!row) return;
    const id = row.getAttribute('data-san-id');
    if (!id) return;
    const s = heizlastState.get();
    const next = s.heizlast.sanierungMassnahmen.filter((m) => m.id !== id);
    heizlastState.setKey('heizlast', { ...s.heizlast, sanierungMassnahmen: next });
    isDirty.set(true);
  });

  // ------------------------------------------------------------
  // 5. Personen-Einheiten (WW-Methode "personen")
  // ------------------------------------------------------------
  const peList = document.getElementById('hz-pe-list');
  const peAddBtn = document.getElementById('hz-pe-add');

  function renderPeList() {
    if (!peList) return;
    const s = heizlastState.get();
    const items = s.warmwasser.personen || [];
    if (items.length === 0) {
      peList.innerHTML = '<p class="hz-muted hz-pe-empty">Noch keine Einheit erfasst.</p>';
      return;
    }
    peList.innerHTML = items.map((p, idx) => `
      <div class="hz-pe-row" data-pe-idx="${idx}">
        <input type="text" placeholder="z. B. Wohnung 1" data-pe-field="label" value="" />
        <div class="hz-field__input-with-unit">
          <input type="number" step="1" min="0" data-pe-field="anf" value="${p.anf || ''}" />
          <span class="hz-field__unit">m²</span>
        </div>
        <div class="hz-field__input-with-unit">
          <input type="number" step="1" min="0" data-pe-field="vwui" value="${p.vwui || ''}" />
          <span class="hz-field__unit">l/P/d</span>
        </div>
        <button type="button" class="hz-pe-remove" aria-label="Entfernen" data-pe-remove>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
        </button>
      </div>
    `).join('');
  }

  if (peAddBtn) {
    peAddBtn.addEventListener('click', () => {
      const s = heizlastState.get();
      const next = [...s.warmwasser.personen, { anf: 120, vwui: 40 }];
      heizlastState.setKey('warmwasser', { ...s.warmwasser, personen: next });
      isDirty.set(true);
    });
  }

  document.addEventListener('input', (ev) => {
    const t = ev.target as HTMLElement;
    if (!t || typeof t.closest !== 'function') return;
    const row = t.closest('.hz-pe-row') as HTMLElement | null;
    if (!row) return;
    const idxRaw = row.getAttribute('data-pe-idx');
    const field = t.getAttribute('data-pe-field');
    if (idxRaw == null) return;
    const idx = Number(idxRaw);
    const value = (t as HTMLInputElement).value;
    const s = heizlastState.get();
    const next = s.warmwasser.personen.map((p, i) => {
      if (i !== idx) return p;
      if (field === 'anf') return { ...p, anf: Number(value) || 0 };
      if (field === 'vwui') return { ...p, vwui: Number(value) || 0 };
      return p;
    });
    heizlastState.setKey('warmwasser', { ...s.warmwasser, personen: next });
    isDirty.set(true);
  });
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement;
    if (!t || typeof t.closest !== 'function') return;
    const btn = t.closest('[data-pe-remove]') as HTMLElement | null;
    if (!btn) return;
    const row = btn.closest('.hz-pe-row') as HTMLElement | null;
    if (!row) return;
    const idxRaw = row.getAttribute('data-pe-idx');
    if (idxRaw == null) return;
    const idx = Number(idxRaw);
    const s = heizlastState.get();
    const next = s.warmwasser.personen.filter((_, i) => i !== idx);
    heizlastState.setKey('warmwasser', { ...s.warmwasser, personen: next });
    isDirty.set(true);
  });

  // ------------------------------------------------------------
  // 6. M2-Methodenwahl: Paket C / Block D — Radio-Tab-UI
  //    Drei Radios (verbrauch / bstd / override) steuern Panel-Sichtbarkeit
  //    und schreiben methodsEnabled in den State.
  //    Bauperiode läuft immer als Fallback.
  // ------------------------------------------------------------
  function activeMethodFromState(s: ReturnType<typeof heizlastState.get>): string {
    const e = s.heizlast.methodsEnabled;
    if (e && e.override) return 'override';
    if (e && (e.bstd || e.messung)) return 'bstd';
    return 'verbrauch';
  }

  function syncMethodPanels(s: ReturnType<typeof heizlastState.get>) {
    const activeMethod = activeMethodFromState(s);
    // Sync radio selection
    const radios = document.querySelectorAll<HTMLInputElement>('input[name="hz-method-radio"]');
    radios.forEach((radio) => {
      radio.checked = radio.value === activeMethod;
    });
    // Show/hide panels
    document.querySelectorAll('[data-method-panel]').forEach((el) => {
      const panel = el as HTMLElement;
      const isActive = panel.getAttribute('data-method-panel') === activeMethod;
      panel.hidden = !isActive;
    });
  }

  // Radio-Change: User wählt Methode → State aktualisieren
  document.addEventListener('change', (ev) => {
    const t = ev.target as HTMLElement;
    if (!t || (t as HTMLInputElement).name !== 'hz-method-radio') return;
    const val = (t as HTMLInputElement).value;
    const s = heizlastState.get();
    const newEnabled = {
      verbrauch: val === 'verbrauch',
      bstd: val === 'bstd',
      messung: val === 'bstd', // Messung ist Alternative im bstd-Panel
      override: val === 'override',
    };
    heizlastState.setKey('heizlast', { ...s.heizlast, methodsEnabled: newEnabled });
    isDirty.set(true);
  });

  // ------------------------------------------------------------
  // 7. WW-Panes (nur aktive Methode sichtbar)
  // ------------------------------------------------------------
  function syncWwPanes() {
    const s = heizlastState.get();
    const method = s.warmwasser.method;
    document.querySelectorAll('[data-ww-pane]').forEach((el) => {
      const isActive = el.getAttribute('data-ww-pane') === method;
      el.classList.toggle('is-active', isActive);
    });
  }

  // ------------------------------------------------------------
  // 8. Compute-Subscriber -> KPIs + Zusammenfassung
  // ------------------------------------------------------------
  function ampelFromPlausi(wm2: number | null): 'gruen' | 'gelb' | 'rot' {
    if (wm2 == null) return 'gelb';
    if (wm2 < 25 || wm2 > 180) return 'rot';
    if (wm2 < 40 || wm2 > 140) return 'gelb';
    return 'gruen';
  }
  function ampelLabel(a: 'gruen' | 'gelb' | 'rot'): string {
    return a === 'gruen' ? 'plausibel' : a === 'gelb' ? 'grenzwertig' : 'unplausibel';
  }
  function labelBauperiode(id: string): string {
    const p = BAUPERIODEN.find((b) => b.id === id);
    return p ? p.label : id;
  }
  function labelTyp(id: string): string {
    return (({ efh: 'Einfamilienhaus', mfh: 'Mehrfamilienhaus', buero: 'Büro / Gewerbe' } as any)[id]) || id;
  }
  function labelLage(id: string): string {
    return (({ mittelland: 'Mittelland (<800 m)', hoehe: 'ab 800 m ü. M.' } as any)[id]) || id;
  }
  function labelStatus(id: string): string {
    return (({
      arbeit: 'In Arbeit',
      offeriert: 'Offeriert',
      bestellt: 'Bestellt',
      abgeschlossen: 'Abgeschlossen',
      archiv: 'Archiv',
    } as any)[id]) || id;
  }

  function setKpi(key: string, value: string, attrs?: Record<string, string>) {
    document.querySelectorAll(`[data-kpi="${key}"]`).forEach((el) => {
      const valEl = el.querySelector('.hz-kpi__value') || el;
      valEl.textContent = value;
      if (attrs) {
        Object.entries(attrs).forEach(([k, v]) => el.setAttribute(k, v));
      }
    });
  }
  function setSum(key: string, value: string) {
    document.querySelectorAll(`[data-hz-sum="${key}"]`).forEach((el) => {
      el.textContent = value;
    });
  }

  function renderAll() {
    const s = heizlastState.get();
    const r = heizlastCompute.get();

    // KPI-Kacheln
    setKpi('tvoll', fmtInt(r.tvoll));
    setKpi('qhlRaw', fmt(r.qhlRaw?.value));
    setKpi('qhlKorr', fmt(r.qhlKorr?.value));
    const ampel = ampelFromPlausi(r.plausi?.value ?? null);
    setKpi('plausi', fmt(r.plausi?.value, 1), {
      'data-ampel': ampel,
      'title': 'Spezifische Heizleistung — ' + ampelLabel(ampel),
    });
    setKpi('qw', fmt(r.qw?.value));
    setKpi('qwwTag', fmt(r.qwwTagVal?.value));
    setKpi('vwu', fmtInt(r.vwu?.value));
    setKpi('qoff', fmt(r.qoff?.value));
    // G: Qas = Pool + Lüftung; automatisch summiert und in State zurückgeschrieben
    const qasPool = Number(s.zuschlaege.qasPool) || 0;
    const qasLueftung = Number(s.zuschlaege.qasLueftung) || 0;
    const qasEff = qasPool + qasLueftung;
    if (Math.abs((Number(s.zuschlaege.qas) || 0) - qasEff) > 0.001) {
      heizlastState.setKey('zuschlaege', { ...s.zuschlaege, qas: qasEff });
    }
    setKpi('qas', fmt(qasEff));
    setKpi('qh', fmt(r.qh?.value));
    setKpi('wwSpeicher', fmtInt(r.wwSpeicherGerundet));
    setKpi('puffer', fmtInt(r.pufferGerundet));

    // Zusammenfassung (Section 7)
    setSum('projectName', s.projectName || '—');
    setSum('customerName', s.customerName || '—');
    setSum('address', s.address || '—');
    setSum('status', labelStatus(s.status));
    setSum('typ', labelTyp(s.gebaeude.typ));
    setSum('lage', labelLage(s.gebaeude.lage));
    setSum('bauperiode', labelBauperiode(s.gebaeude.bauperiode));
    setSum('ebf', fmt(s.gebaeude.ebf, 0));
    setSum('tvoll', fmtInt(r.tvoll));
    setSum('qhl', fmt(r.qhlKorr?.value));
    setSum('qw', fmt(r.qw?.value));
    setSum('qoff', fmt(r.qoff?.value));
    setSum('qas', fmt(qasEff));
    setSum('qh', fmt(r.qh?.value));
    setSum('wwSpeicher', fmtInt(r.wwSpeicherGerundet));
    setSum('puffer', fmtInt(r.pufferGerundet));
    // Phase 9 / Block J: Rohwerte separat fuer "Berechnungswert X - Empfehlung Y"
    setSum('wwSpeicherRoh', fmtInt(r.wwSpeicherRoh?.value ?? null));
    setSum('pufferRoh', fmtInt(r.pufferRoh?.value ?? null));

    // Listen
    renderRaumList();
    renderSanList();
    renderPeList();

    // Panes / Methoden
    syncWwPanes();

    // Block D: Body-Klasse gated den sichtbaren Sperrzeit-Block in Section 4.
    document.body.classList.toggle('hz-sperrzeit-on', !!s.zuschlaege.sperrzeitActive);

    // B: WW-Content sichtbar/versteckt je nach warmwasser.active
    document.body.classList.toggle('hz-ww-off', !s.warmwasser.active);
    // WW-Speicher-Karte folgt ebenfalls (Section 6 hat .hz-ww-storage)

    // C: Puffer-Block sichtbar wenn pufferActive
    document.body.classList.toggle('hz-puffer-on', !!s.speicher.pufferActive);

    // D: Methoden-Panels — aktive Panel einblenden, andere ausblenden
    syncMethodPanels(s);
  }

  renderAll();
  heizlastCompute.subscribe(() => renderAll());
  heizlastState.subscribe(() => renderAll());

  // ------------------------------------------------------------
  // 9. Speichern/Laden-Buttons
  // ------------------------------------------------------------
  const saveCloudBtns = Array.from(document.querySelectorAll('[data-hz-action="save-cloud"]')) as HTMLButtonElement[];
  const saveCloudNewBtns = Array.from(document.querySelectorAll('[data-hz-action="save-cloud-new"]')) as HTMLButtonElement[];
  const openProjectsBtns = Array.from(document.querySelectorAll('[data-hz-action="open-projects"]')) as HTMLButtonElement[];
  const loginBtn = document.querySelector('[data-hz-action="login"]') as HTMLButtonElement | null;
  // Phase 9 / Block I: Neues-Projekt-Button wird via Event-Delegation gehandhabt (siehe unten)
  // Alias fuer die (alten) Einzel-Listener
  const saveCloudBtn = saveCloudBtns[0] || null;
  const saveCloudNewBtn = saveCloudNewBtns[0] || null;
  const openProjectsBtn = openProjectsBtns[0] || null;
  const statusEl = document.querySelector('[data-hz-save-status]') as HTMLElement | null;
  const statusText = document.querySelector('[data-hz-save-status-text]') as HTMLElement | null;
  const saveLocalEl = document.querySelector('[data-hz-save-local]') as HTMLElement | null;
  // Phase 9 / Block I: "Letzte Cloud-Speicherung"-Anzeige entfernt — Status-Pill reicht.

  function setStatus(tone: 'ok' | 'busy' | 'err' | 'idle', text: string) {
    if (statusEl) {
      if (tone === 'idle') statusEl.removeAttribute('data-tone');
      else statusEl.setAttribute('data-tone', tone);
    }
    if (statusText) statusText.textContent = text;
  }
  function fmtTime(ms: number | null): string {
    if (!ms) return '—';
    const d = new Date(ms);
    return d.toLocaleString('de-CH', { dateStyle: 'short', timeStyle: 'short' });
  }
  function refreshCloudButtons(auth: boolean) {
    saveCloudBtns.forEach((b) => { b.disabled = !auth; });
    saveCloudNewBtns.forEach((b) => { b.disabled = !auth; });
    openProjectsBtns.forEach((b) => { b.disabled = !auth; });
    const loginLabel = document.querySelector('[data-hz-login-label]') as HTMLElement | null;
    if (loginLabel) loginLabel.textContent = auth ? 'Abmelden' : 'Anmelden';
  }

  let lastCloudSaveSeen: number | null = null;
  uiState.subscribe((u) => {
    refreshCloudButtons(u.isAuthenticated);
    if (u.syncInFlight) setStatus('busy', 'Synchronisiere …');
    else if (u.lastError) setStatus('err', u.lastError);
    else if (u.lastCloudSave) setStatus('ok', 'In Cloud gespeichert.');
    else setStatus('idle', 'Bereit.');
    if (saveLocalEl) saveLocalEl.textContent = fmtTime(u.lastLocalSave);
    // Flash-Animation nur bei neuem Cloud-Save
    if (u.lastCloudSave && u.lastCloudSave !== lastCloudSaveSeen && !u.syncInFlight && !u.lastError) {
      lastCloudSaveSeen = u.lastCloudSave;
      if (statusEl) {
        statusEl.classList.remove('is-flash');
        // Reflow erzwingen, damit Animation neu startet
        void (statusEl as HTMLElement).offsetWidth;
        statusEl.classList.add('is-flash');
        setTimeout(() => statusEl.classList.remove('is-flash'), 1500);
      }
    }
  });

  // Nach jeder Aenderung: Timestamp "zuletzt lokal gespeichert" aktualisieren (analog zum Debounce in storage.ts).
  isDirty.subscribe((dirty) => {
    if (dirty) {
      setTimeout(() => {
        uiState.setKey('lastLocalSave', Date.now());
        isDirty.set(false);
      }, 600);
    }
  });

  function computedSummary() {
    const summary = heizlastCompute.get().summary;
    return {
      qhl: summary.qhlKw,
      qh: summary.qhKw,
      ebf: heizlastState.get().gebaeude.ebf,
    };
  }

  // Save-Cloud-Buttons (Header + Section 7) per Delegation
  document.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const save = t.closest('[data-hz-action="save-cloud"]') as HTMLButtonElement | null;
    if (save && !save.disabled) {
      try { await saveProject({ asNew: false, computed: computedSummary() }); }
      catch (err) { console.warn('save failed:', err); }
      return;
    }
    const saveNew = t.closest('[data-hz-action="save-cloud-new"]') as HTMLButtonElement | null;
    if (saveNew && !saveNew.disabled) {
      try { await saveProject({ asNew: true, computed: computedSummary() }); }
      catch (err) { console.warn('save-as-new failed:', err); }
    }
  });

  // ------------------------------------------------------------
  // 10. Modal-Infrastruktur (Login / Projekte / Export)
  // ------------------------------------------------------------
  const loginModal = document.getElementById('hz-login-modal') as HTMLElement | null;
  const projectsModal = document.getElementById('hz-projects-modal') as HTMLElement | null;
  const exportModal = document.getElementById('hz-export-modal') as HTMLElement | null;

  let lastTrigger: HTMLElement | null = null;

  function openModal(el: HTMLElement | null, trigger?: HTMLElement | null): void {
    if (!el) return;
    if (trigger) lastTrigger = trigger;
    el.hidden = false;
    document.body.classList.add('hz-modal-open');
    // erstes fokussierbares Element im Card-Body fokussieren
    setTimeout(() => {
      const focusable = el.querySelector<HTMLElement>(
        'input:not([type="hidden"]):not([disabled]), select:not([disabled]), textarea:not([disabled]), button:not([disabled])',
      );
      focusable?.focus();
    }, 30);
  }

  function closeModal(el: HTMLElement | null): void {
    if (!el) return;
    el.hidden = true;
    const anyOpen =
      (loginModal && !loginModal.hidden) ||
      (projectsModal && !projectsModal.hidden) ||
      (exportModal && !exportModal.hidden);
    if (!anyOpen) document.body.classList.remove('hz-modal-open');
    if (lastTrigger) { lastTrigger.focus(); lastTrigger = null; }
  }

  function closeAllModals(): void {
    if (loginModal) loginModal.hidden = true;
    if (projectsModal) projectsModal.hidden = true;
    if (exportModal) exportModal.hidden = true;
    document.body.classList.remove('hz-modal-open');
  }

  // Generic: ESC schliesst das offene Modal.
  document.addEventListener('keydown', (ev) => {
    if (ev.key !== 'Escape') return;
    if (loginModal && !loginModal.hidden) { closeModal(loginModal); uiState.setKey('authModalOpen', false); }
    if (projectsModal && !projectsModal.hidden) { closeModal(projectsModal); uiState.setKey('projectsModalOpen', false); }
    if (exportModal && !exportModal.hidden) { closeModal(exportModal); uiState.setKey('exportModalOpen', false); }
  });

  // Focus-Trap: Tab bleibt im offenen Modal-Card (erstes <-> letztes fokussierbares Element).
  function getVisibleModal(): HTMLElement | null {
    if (loginModal && !loginModal.hidden) return loginModal;
    if (projectsModal && !projectsModal.hidden) return projectsModal;
    if (exportModal && !exportModal.hidden) return exportModal;
    return null;
  }
  document.addEventListener('keydown', (ev) => {
    if (ev.key !== 'Tab') return;
    const modal = getVisibleModal();
    if (!modal) return;
    const card = modal.querySelector('.hz-modal__card') || modal;
    const focusables = Array.from(
      card.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([type="hidden"]):not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ),
    ).filter((el) => el.offsetParent !== null || el === document.activeElement);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (ev.shiftKey) {
      if (active === first || !card.contains(active)) {
        ev.preventDefault();
        last.focus();
      }
    } else {
      if (active === last || !card.contains(active)) {
        ev.preventDefault();
        first.focus();
      }
    }
  });

  // Generic: Klick auf [data-hz-modal-dismiss] oder Backdrop schliesst.
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const dismiss = t.closest('[data-hz-modal-dismiss]') as HTMLElement | null;
    if (!dismiss) return;
    const modal = dismiss.closest('.hz-modal') as HTMLElement | null;
    if (!modal) return;
    closeModal(modal);
    if (modal.id === 'hz-login-modal') uiState.setKey('authModalOpen', false);
    if (modal.id === 'hz-projects-modal') uiState.setKey('projectsModalOpen', false);
    if (modal.id === 'hz-export-modal') uiState.setKey('exportModalOpen', false);
  });

  // ------------------------------------------------------------
  // 10a. Login-Modal
  // ------------------------------------------------------------
  const loginForm = document.getElementById('hz-login-form') as HTMLFormElement | null;
  const loginPassword = document.getElementById('hz-login-password') as HTMLInputElement | null;
  const loginSubmit = document.getElementById('hz-login-submit') as HTMLButtonElement | null;
  const loginError = document.getElementById('hz-login-error') as HTMLElement | null;
  const logoutSubmit = document.getElementById('hz-logout-submit') as HTMLButtonElement | null;
  const logoutError = document.getElementById('hz-logout-error') as HTMLElement | null;

  function showError(el: HTMLElement | null, msg: string) {
    if (!el) return;
    el.textContent = msg;
    el.hidden = false;
  }
  function hideError(el: HTMLElement | null) {
    if (!el) return;
    el.hidden = true;
    el.textContent = '';
  }

  function refreshLoginView() {
    if (!loginModal) return;
    const authed = uiState.get().isAuthenticated;
    const signin = loginModal.querySelector('[data-hz-login-view="signin"]') as HTMLElement | null;
    const signout = loginModal.querySelector('[data-hz-login-view="signout"]') as HTMLElement | null;
    if (signin) signin.hidden = authed;
    if (signout) signout.hidden = !authed;
  }

  if (loginForm && loginPassword && loginSubmit) {
    loginForm.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      hideError(loginError);
      const pw = loginPassword.value;
      if (!pw) { showError(loginError, 'Bitte Passwort eingeben.'); return; }
      loginSubmit.disabled = true;
      loginSubmit.textContent = 'Pruefe …';
      try {
        const resp = await fetch('/api/heizlast-auth', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: pw }),
        });
        const data = await resp.json().catch(() => ({}));
        if (!resp.ok || !data.success) {
          throw new Error(data.error || 'Anmeldung fehlgeschlagen');
        }
        uiState.setKey('isAuthenticated', true);
        uiState.setKey('authModalOpen', false);
        loginPassword.value = '';
        closeModal(loginModal);
      } catch (err: any) {
        showError(loginError, err?.message || 'Anmeldung fehlgeschlagen');
      } finally {
        loginSubmit.disabled = false;
        loginSubmit.textContent = 'Anmelden';
      }
    });
  }

  if (logoutSubmit) {
    logoutSubmit.addEventListener('click', async () => {
      hideError(logoutError);
      logoutSubmit.disabled = true;
      logoutSubmit.textContent = 'Melde ab …';
      try {
        const resp = await fetch('/api/heizlast-auth', {
          method: 'DELETE',
          credentials: 'same-origin',
        });
        if (!resp.ok) throw new Error('Abmelden fehlgeschlagen');
        uiState.setKey('isAuthenticated', false);
        projectList.set([]);
        projectListLoaded.set(false);
        closeModal(loginModal);
      } catch (err: any) {
        showError(logoutError, err?.message || 'Abmelden fehlgeschlagen');
      } finally {
        logoutSubmit.disabled = false;
        logoutSubmit.textContent = 'Abmelden';
      }
    });
  }

  if (loginBtn) loginBtn.addEventListener('click', () => {
    refreshLoginView();
    uiState.setKey('authModalOpen', true);
    openModal(loginModal, loginBtn);
  });
  const loginHeader = document.getElementById('hz-login-trigger');
  if (loginHeader) {
    loginHeader.addEventListener('click', () => {
      refreshLoginView();
      uiState.setKey('authModalOpen', true);
      openModal(loginModal, loginHeader);
    });
  }

  // Body-Klasse `is-auth` spiegelt uiState.isAuthenticated (CSS-Hook fuer Cloud-Features).
  uiState.subscribe((u) => {
    document.body.classList.toggle('is-auth', u.isAuthenticated);
    // Login-Header-Button: Label + Icon-Aria
    const headerLabel = document.querySelector('#hz-login-trigger span') as HTMLElement | null;
    if (headerLabel) headerLabel.textContent = u.isAuthenticated ? 'Abmelden' : 'Anmelden';
    refreshLoginView();
  });

  // ------------------------------------------------------------
  // 10b. Projekte-Modal
  // ------------------------------------------------------------
  const projectsListEl = document.getElementById('hz-projects-list');
  const projectsCountEl = document.getElementById('hz-projects-count');
  const projectsRefreshBtn = document.getElementById('hz-projects-refresh');

  function setProjectsState(name: 'loading' | 'empty' | 'error' | 'list', msg?: string) {
    if (!projectsModal) return;
    projectsModal.querySelectorAll('[data-hz-projects-state]').forEach((el) => {
      (el as HTMLElement).hidden = el.getAttribute('data-hz-projects-state') !== name;
    });
    if (projectsListEl) projectsListEl.hidden = name !== 'list';
    if (name === 'error' && msg) {
      const msgEl = projectsModal.querySelector('[data-hz-projects-error-message]');
      if (msgEl) msgEl.textContent = msg;
    }
  }

  function renderProjectsList(items: any[]) {
    if (!projectsListEl) return;
    if (projectsCountEl) {
      projectsCountEl.textContent = items.length === 1
        ? '1 Projekt' : items.length + ' Projekte';
    }
    if (!items.length) { setProjectsState('empty'); return; }
    const activeId = heizlastState.get().projectId || '';
    projectsListEl.innerHTML = items.map((p) => {
      const name = escapeHtml(p.projectName || 'Unbenannt');
      const cust = p.customerName ? escapeHtml(p.customerName) : '';
      const addr = p.address ? escapeHtml(p.address) : '';
      const status = p.status || 'arbeit';
      const updated = p.updatedAt
        ? new Date(p.updatedAt).toLocaleString('de-CH', { dateStyle: 'short', timeStyle: 'short' })
        : '—';
      const qhl = p.qhl != null ? fmt(p.qhl) + ' kW' : '—';
      const qh = p.qh != null ? fmt(p.qh) + ' kW' : '—';
      const ebf = p.ebf != null ? fmt(p.ebf, 0) + ' m²' : '—';
      return `
        <div class="hz-project-row" data-project-id="${escapeHtml(p._id)}"${p._id === activeId ? ' data-active="true"' : ''}>
          <div class="hz-project-row__main">
            <h3 class="hz-project-row__title">
              ${name}
              <span class="hz-badge" data-status="${status}">${escapeHtml(labelStatus(status))}</span>
            </h3>
            ${cust ? `<p class="hz-project-row__customer">${cust}${addr ? ' · ' + addr : ''}</p>` : (addr ? `<p class="hz-project-row__customer">${addr}</p>` : '')}
            <p class="hz-project-row__meta">
              <span>EBF <strong>${ebf}</strong></span>
              <span>Qhl <strong>${qhl}</strong></span>
              <span>Qh <strong>${qh}</strong></span>
              <span>Aktualisiert <strong>${updated}</strong></span>
            </p>
          </div>
          <div class="hz-project-row__actions">
            <button type="button" class="hz-project-row__btn" data-project-action="load" data-project-id="${escapeHtml(p._id)}">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M19 12l-7 7-7-7"/></svg>
              Laden
            </button>
            <button type="button" class="hz-project-row__btn hz-project-row__btn--danger" data-project-action="delete" data-project-id="${escapeHtml(p._id)}">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
              Loeschen
            </button>
          </div>
        </div>
      `;
    }).join('');
    setProjectsState('list');
  }

  async function reloadProjects() {
    setProjectsState('loading');
    try {
      const items = await listProjects();
      renderProjectsList(items);
    } catch (err: any) {
      if ((err?.message || '').toLowerCase().includes('nicht autorisiert')) {
        setProjectsState('error', 'Bitte zuerst anmelden.');
      } else {
        setProjectsState('error', err?.message || 'Fehler beim Laden.');
      }
    }
  }

  if (projectsRefreshBtn) {
    projectsRefreshBtn.addEventListener('click', () => { reloadProjects(); });
  }

  // Row-Actions (Laden / Loeschen) — Event-Delegation
  document.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-project-action]') as HTMLElement | null;
    if (!btn) return;
    const action = btn.getAttribute('data-project-action');
    const id = btn.getAttribute('data-project-id');
    if (!action || !id) return;
    if (action === 'load') {
      try {
        await loadProject(id);
        uiState.setKey('projectsModalOpen', false);
        closeModal(projectsModal);
        setStatus('ok', 'Projekt geladen.');
      } catch (err: any) {
        alert('Laden fehlgeschlagen: ' + (err?.message || 'unbekannter Fehler'));
      }
    } else if (action === 'delete') {
      if (!confirm('Dieses Projekt dauerhaft aus der Cloud loeschen?')) return;
      try {
        await deleteProject(id);
        renderProjectsList(projectList.get());
      } catch (err: any) {
        alert('Loeschen fehlgeschlagen: ' + (err?.message || 'unbekannter Fehler'));
      }
    }
  });

  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-hz-action="open-projects"]') as HTMLButtonElement | null;
    if (!btn || btn.disabled) return;
    uiState.setKey('projectsModalOpen', true);
    openModal(projectsModal, btn);
    reloadProjects();
  });

  // ------------------------------------------------------------
  // 10c. Export-Modal
  // ------------------------------------------------------------
  const exportForm = document.getElementById('hz-export-form') as HTMLFormElement | null;
  const exportFilename = document.getElementById('hz-export-filename') as HTMLInputElement | null;
  const exportError = document.getElementById('hz-export-error') as HTMLElement | null;

  function openExportModal(trigger: HTMLElement | null) {
    if (exportFilename) exportFilename.value = defaultFilename();
    uiState.setKey('exportModalOpen', true);
    openModal(exportModal, trigger);
  }

  if (exportForm) {
    exportForm.addEventListener('submit', (ev) => {
      ev.preventDefault();
      hideError(exportError);
      const formatEl = exportForm.querySelector<HTMLInputElement>('input[name="hz-export-format"]:checked');
      const format = (formatEl?.value === 'json' ? 'json' : 'pdf') as 'pdf' | 'json';
      const parts: Record<ExportPart, boolean> = {
        cover: true, objekt: true, resultate: true, diagramm: true,
        formeln: false, grundlagen: true,
        notizenBereiche: true, notizenProjekt: true, plausi: true,
      };
      exportForm.querySelectorAll<HTMLInputElement>('[data-export-part]').forEach((cb) => {
        const key = cb.getAttribute('data-export-part') as ExportPart;
        parts[key] = cb.checked;
      });
      const filename = exportFilename?.value.trim() || defaultFilename();
      try {
        runExport({ format, parts, filename });
        closeModal(exportModal);
        uiState.setKey('exportModalOpen', false);
      } catch (err: any) {
        showError(exportError, err?.message || 'Export fehlgeschlagen');
      }
    });
  }

  // Export-Trigger: jeder [data-hz-action="export"] oeffnet das Export-Modal
  // (Header-Button + ggf. Section-7-Button).
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-hz-action="export"]') as HTMLElement | null;
    if (!btn) return;
    openExportModal(btn);
  });

  // Neues Projekt: einfacher Confirm-Dialog
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-hz-action="new-project"]') as HTMLButtonElement | null;
    if (!btn) return;
    if (!confirm('Neues Projekt starten? Aktuelle Eingaben gehen verloren.')) return;
    hardReset();
    setStatus('idle', 'Neues Projekt.');
  });

  // Daten löschen (K): clears localStorage state mit Bestätigung
  document.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement | null;
    if (!t) return;
    const btn = t.closest('[data-hz-action="delete-data"]') as HTMLButtonElement | null;
    if (!btn) return;
    if (!confirm('Alle Eingaben löschen und auf Standardwerte zurücksetzen?')) return;
    hardReset();
    setStatus('idle', 'Daten gelöscht.');
  });

  // Phase 9 / Block I: beforeunload-Warnung, wenn ungespeicherte Aenderungen in der Cloud stehen
  window.addEventListener('beforeunload', (ev) => {
    const u = uiState.get();
    if (u.isAuthenticated && isDirty.get() && !u.syncInFlight) {
      ev.preventDefault();
      // Spec: returnValue leer setzen reicht, Browser zeigt Standardtext
      (ev as BeforeUnloadEvent).returnValue = '';
    }
  });
</script>

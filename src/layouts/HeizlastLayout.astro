---
// Eigenes Layout fuer den Heizlast-Rechner
// Schlanker Header (Logo + Login), minimaler Footer, keine Site-Navigation.
// CSS-Tokens sind konsistent zu src/layouts/Layout.astro, aber gekapselt
// damit diese Seite unabhaengig vom Marketing-Layout gepflegt werden kann.

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Heizlast-Rechner | Thermowerk',
  description = 'Professionelle Heizlast- und Waermepumpen-Auslegung nach FWS, SIA und VDI fuer Thermowerk.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Outfit:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" type="image/png" href="/img/favicon.png" />
  <style is:global>
    /* =========================================================
       THERMOWERK HEIZLAST — DESIGN-TOKENS (gekapselt per :where)
       ========================================================= */
    :root {
      --hz-navy: #1B2A4A;
      --hz-navy-light: #243658;
      --hz-navy-dark: #111D33;
      --hz-red: #D93025;
      --hz-red-soft: #FBEAE8;
      --hz-white: #FFFFFF;
      --hz-off-white: #F7F8FA;
      --hz-light-gray: #EEF0F4;
      --hz-mid-gray: #6B7280;
      --hz-dark: #1A1A1A;
      --hz-border: #E2E5EB;
      --hz-blue-tint: #E8EDF5;
      --hz-blue-tint-strong: #D8E0EE;
      --hz-success: #1F8A4C;
      --hz-warn: #B7791F;

      --hz-font-heading: 'Outfit', 'Helvetica Neue', Arial, sans-serif;
      --hz-font-body: 'DM Sans', 'Helvetica Neue', Arial, sans-serif;
      --hz-font-mono: 'DM Sans', ui-monospace, 'SFMono-Regular', Menlo, monospace;

      --hz-radius-sm: 2px;
      --hz-radius-md: 2px;
      --hz-radius-lg: 2px;

      --hz-shadow-sm: 0 1px 2px rgba(17, 29, 51, 0.05);
      --hz-shadow-md: 0 8px 24px rgba(17, 29, 51, 0.08);
      --hz-shadow-hero: 0 24px 60px rgba(17, 29, 51, 0.18);

      --hz-transition: 180ms ease;
      --hz-header-height: 72px;

      /* Phase 9 / Block M1 — fluide Container-Breite und Abstände.
         Container skaliert mit dem Viewport, aber nie über 960 px.
         Das sorgt auf breiten Bildschirmen (1440–1920 px) fuer ruhige
         Raender links/rechts. */
      --hz-container-max: min(92vw, 960px);
      --hz-gap-section: clamp(56px, 8svh, 88px);
      --hz-gap-row: clamp(16px, 2.2vw, 28px);
      --hz-gap-card: clamp(10px, 1.4vw, 18px);
    }

    /* Reset, nur fuer den Heizlast-Scope aktiv */
    .hz-scope, .hz-scope *, .hz-scope *::before, .hz-scope *::after {
      box-sizing: border-box;
    }

    .hz-scope {
      font-family: var(--hz-font-body);
      color: var(--hz-dark);
      background: var(--hz-white);
      /* Phase 9 / Block M1 — leicht fluide Body-Schrift */
      font-size: clamp(15.5px, 0.35vw + 14.8px, 17px);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .hz-scope a { color: inherit; text-decoration: none; }
    .hz-scope img { max-width: 100%; display: block; }
    .hz-scope button { font: inherit; cursor: pointer; }
    .hz-scope input, .hz-scope select, .hz-scope textarea { font: inherit; color: inherit; }

    /* Typografie */
    .hz-scope h1, .hz-scope h2, .hz-scope h3, .hz-scope h4 {
      font-family: var(--hz-font-heading);
      color: var(--hz-navy);
      line-height: 1.2;
      font-weight: 700;
    }
    .hz-scope h1 { font-size: clamp(32px, 4.4vw, 46px); letter-spacing: -0.01em; }
    .hz-scope h2 { font-size: clamp(24px, 3vw, 34px); letter-spacing: -0.005em; }
    .hz-scope h3 { font-size: clamp(18px, 2vw, 22px); font-weight: 600; }
    .hz-scope h4 { font-size: 17px; font-weight: 600; }
    .hz-scope p  { font-size: 16px; line-height: 1.65; color: var(--hz-dark); }

    /* Utility */
    .hz-container { max-width: var(--hz-container-max); margin: 0 auto; padding: 0 clamp(16px, 3vw, 24px); width: 100%; }
    .hz-scope, body { overflow-x: hidden; }
    .hz-scope *, .hz-scope *::before, .hz-scope *::after { max-width: 100%; }
    .hz-scope input, .hz-scope select, .hz-scope textarea, .hz-scope button {
      max-width: 100%;
    }

    /* Phase 9 / Block M2 — 12-Spalten-Grid als Utility.
       `.hz-row` ist die Grid-Basis, `.hz-col-*` spannen eine bestimmte
       Zahl von Spalten. Auf Mobile wird jede Spalte full-width. */
    .hz-row {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: var(--hz-gap-row, clamp(16px, 2.2vw, 28px));
      align-items: start;
    }
    .hz-col-3  { grid-column: span 3; }
    .hz-col-4  { grid-column: span 4; }
    .hz-col-6  { grid-column: span 6; }
    .hz-col-8  { grid-column: span 8; }
    .hz-col-12 { grid-column: span 12; }
    @media (max-width: 720px) {
      .hz-row { gap: 12px; }
      .hz-col-3, .hz-col-4, .hz-col-6, .hz-col-8, .hz-col-12 { grid-column: span 12; }
    }

    /* Phase 9 / Block M2 — intrinsische Feldbreiten.
       Zahl+Einheit-Felder sowie numerische Inputs bekommen eine
       sichtbare Maximalbreite, damit auf Desktop (1440 px) rechts
       Freiraum entsteht. Text-Inputs bleiben volle Breite. Selects
       werden ebenfalls begrenzt, damit Dropdowns nicht unproportional
       breit werden. Ueber `[data-size]` laesst sich jede Zelle fein-
       justieren. Mobile-Default bleibt full-width via Phase-8-Regel. */
    :root {
      --hz-input-max-number: 240px;
      --hz-input-max-select: 320px;
      --hz-input-max-unit: 220px;
    }
    .hz-scope .hz-field__input-with-unit { max-width: var(--hz-input-max-unit); }
    .hz-scope .hz-field:not([data-size]) > .hz-field__input[type="number"] { max-width: var(--hz-input-max-number); }
    .hz-scope .hz-field:not([data-size]) > select.hz-field__input { max-width: var(--hz-input-max-select); }
    .hz-scope .hz-field[data-size="xs"] .hz-field__input,
    .hz-scope .hz-field[data-size="xs"] .hz-field__input-with-unit { max-width: 120px; }
    .hz-scope .hz-field[data-size="sm"] .hz-field__input,
    .hz-scope .hz-field[data-size="sm"] .hz-field__input-with-unit { max-width: 180px; }
    .hz-scope .hz-field[data-size="md"] .hz-field__input,
    .hz-scope .hz-field[data-size="md"] .hz-field__input-with-unit { max-width: 280px; }
    .hz-scope .hz-field[data-size="lg"] .hz-field__input,
    .hz-scope .hz-field[data-size="lg"] .hz-field__input-with-unit { max-width: 420px; }
    .hz-scope .hz-field[data-size="full"] .hz-field__input,
    .hz-scope .hz-field[data-size="full"] .hz-field__input-with-unit { max-width: 100%; }
    @media (max-width: 720px) {
      .hz-scope .hz-field__input-with-unit,
      .hz-scope .hz-field .hz-field__input,
      .hz-scope .hz-field[data-size] .hz-field__input,
      .hz-scope .hz-field[data-size] .hz-field__input-with-unit {
        max-width: 100%;
      }
    }
    .hz-stack > * + * { margin-top: 12px; }
    .hz-muted { color: var(--hz-mid-gray); }
    .hz-kicker {
      font-family: var(--hz-font-heading);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--hz-red);
    }

    /* Buttons */
    .hz-btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: var(--hz-font-heading); font-weight: 600; font-size: 15px;
      padding: 10px 20px; border-radius: var(--hz-radius-sm); border: 2px solid transparent;
      transition: all var(--hz-transition); line-height: 1; white-space: nowrap;
    }
    .hz-btn-primary { background: var(--hz-red); color: var(--hz-white); border-color: var(--hz-red); }
    .hz-btn-primary:hover { background: #B71C1C; border-color: #B71C1C; }
    .hz-btn-ghost { background: transparent; color: var(--hz-navy); border-color: var(--hz-border); }
    .hz-btn-ghost:hover { border-color: var(--hz-navy); background: var(--hz-off-white); }
    .hz-btn-dark { background: var(--hz-navy); color: var(--hz-white); border-color: var(--hz-navy); }
    .hz-btn-dark:hover { background: var(--hz-navy-light); border-color: var(--hz-navy-light); }

    /* Header */
    .hz-topbar {
      position: sticky; top: 0; z-index: 40;
      min-height: var(--hz-header-height);
      background: var(--hz-white);
      border-bottom: 1px solid var(--hz-border);
      display: flex; align-items: center;
    }
    .hz-topbar__inner {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: clamp(12px, 2vw, 20px);
      width: 100%; max-width: var(--hz-container-max); margin: 0 auto;
      padding: 10px clamp(12px, 3vw, 24px);
    }
    .hz-brand {
      display: inline-flex; align-items: center; gap: 10px;
      flex: 0 0 auto;
    }
    .hz-brand__logo { height: 30px; width: auto; }

    /* Header-Projekt-Info (Mitte) */
    .hz-topbar__project {
      min-width: 0;
      display: flex; flex-direction: column; justify-content: center;
      line-height: 1.25;
      padding: 0 clamp(8px, 2vw, 18px);
      border-left: 1px solid var(--hz-border);
      border-right: 1px solid var(--hz-border);
    }
    .hz-topbar__project-name {
      font-family: var(--hz-font-heading); font-weight: 700; color: var(--hz-navy);
      font-size: 15px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .hz-topbar__project-meta {
      font-family: var(--hz-font-body); font-weight: 400; color: var(--hz-mid-gray);
      font-size: 12.5px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* Header-Aktionen (rechts) */
    .hz-topbar__actions {
      display: inline-flex; align-items: center; gap: 8px;
      flex: 0 0 auto;
    }
    .hz-topbar__actions .hz-btn-icon {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--hz-font-heading); font-weight: 600; font-size: 14px;
      padding: 8px 14px;
      border-radius: var(--hz-radius-sm);
      border: 1px solid var(--hz-border); background: var(--hz-white); color: var(--hz-navy);
      transition: all var(--hz-transition); white-space: nowrap; line-height: 1;
    }
    .hz-topbar__actions .hz-btn-icon:hover { border-color: var(--hz-navy); background: var(--hz-off-white); }
    .hz-topbar__actions .hz-btn-icon:disabled {
      opacity: 0.45; cursor: not-allowed; border-color: var(--hz-border); background: var(--hz-white);
    }
    .hz-topbar__actions .hz-btn-icon--primary {
      background: var(--hz-red); border-color: var(--hz-red); color: var(--hz-white);
    }
    .hz-topbar__actions .hz-btn-icon--primary:hover:not(:disabled) { background: #B71C1C; border-color: #B71C1C; }
    .hz-topbar__actions .hz-btn-icon--primary:disabled { background: var(--hz-light-gray); border-color: var(--hz-light-gray); color: var(--hz-mid-gray); }
    .hz-topbar__actions svg { flex: 0 0 auto; }

    /* Footer */
    .hz-footer {
      margin-top: auto;
      background: var(--hz-navy);
      color: rgba(255,255,255,0.78);
      font-size: 13.5px;
      padding: 24px 0;
    }
    .hz-footer__inner {
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
      flex-wrap: wrap;
    }
    .hz-footer a { color: rgba(255,255,255,0.9); border-bottom: 1px solid rgba(255,255,255,0.25); }
    .hz-footer a:hover { color: var(--hz-white); border-bottom-color: var(--hz-white); }

    /* Main */
    .hz-main { flex: 1 1 auto; }

    /* Responsive — globale Regeln */
    @media (max-width: 640px) {
      .hz-scope { font-size: 15.5px; }
      .hz-scope h1 { font-size: clamp(26px, 7vw, 32px); }
      .hz-scope h2 { font-size: clamp(21px, 5.6vw, 26px); }
      .hz-scope h3 { font-size: 17px; }
      .hz-container { padding: 0 16px; }
      .hz-section { padding: 36px 0 !important; }
      .hz-section--first { padding-top: 24px !important; }
      .hz-btn { font-size: 14.5px; padding: 9px 16px; }
      .hz-grid-2, .hz-grid-3 { grid-template-columns: 1fr !important; }
      .hz-field__input { font-size: 16px; /* verhindert iOS-Zoom */ }
      /* Texte/Panes bleiben immer innerhalb des Containers */
      .hz-scope p, .hz-scope span, .hz-scope label, .hz-scope dt, .hz-scope dd,
      .hz-scope small, .hz-scope li { word-wrap: break-word; overflow-wrap: anywhere; }
      .hz-scope input, .hz-scope select, .hz-scope textarea { width: 100%; min-width: 0; }
      .hz-field__input-with-unit { width: 100%; }
    }
    @media (max-width: 390px) {
      .hz-container { padding: 0 14px; }
    }

    /* Responsive — Header */
    @media (max-width: 900px) {
      .hz-topbar__project-meta { font-size: 12px; }
      .hz-topbar__actions .hz-btn-icon span { display: none; }
      .hz-topbar__actions .hz-btn-icon { padding: 8px 10px; }
    }
    @media (max-width: 640px) {
      :root { --hz-header-height: 60px; }
      .hz-topbar__inner {
        grid-template-columns: auto 1fr auto;
        gap: 8px;
        padding: 8px clamp(10px, 4vw, 16px);
      }
      /* Phase 9 / Block M — Logo-Proportionen stabiler auf Mobile */
      .hz-brand__logo { height: 32px; width: auto; }
      .hz-topbar__project {
        padding: 0 8px;
      }
      .hz-topbar__project-name { font-size: 13.5px; }
      .hz-topbar__project-meta { font-size: 11.5px; }
      .hz-topbar__actions { gap: 4px; }
      .hz-topbar__actions .hz-btn-icon {
        padding: 7px;
        min-width: 34px; min-height: 34px;
        justify-content: center;
      }
    }

    /* Phase 9 / Block M — Mobile-Polish: konservative Worttrennung,
       keine mid-word-Breaks. Sublines und Sektions-Titel bekommen
       text-wrap: balance, damit Umbrueche nicht ungluecklich fallen. */
    .hz-scope {
      hyphens: manual;
      overflow-wrap: break-word;
      word-break: normal;
    }
    .hz-scope h1, .hz-scope h2, .hz-scope h3,
    .hz-scope .hz-section__title,
    .hz-scope .hz-section__subline,
    .hz-scope .hz-kicker {
      text-wrap: balance;
    }
    @media (max-width: 640px) {
      .hz-scope p, .hz-scope span, .hz-scope label, .hz-scope dt, .hz-scope dd,
      .hz-scope small, .hz-scope li {
        /* Phase 9 / Block M — `anywhere` aus Phase 8 verbot nichts,
           aber fuehrte mitten im Wort zu Umbruechen. Konservativer: */
        overflow-wrap: break-word;
        word-break: normal;
      }
    }

    /* =========================================================
       PRINT-CSS — PDF-Export via window.print()
       Aktiv wenn body.hz-print-mode gesetzt ist.
       Einzelne Sektionen werden via body.hz-print-*-on freigeschaltet.
       ========================================================= */
    @media print {
      @page {
        size: A4 portrait;
        margin: 18mm 16mm 20mm 16mm;
      }

      /* Komplett ausblenden (Nav, Sticky-Row, Buttons, Modals, etc.) */
      body.hz-print-mode .hz-topbar,
      body.hz-print-mode .hz-exec,
      body.hz-print-mode .hz-footer,
      body.hz-print-mode .hz-modal,
      body.hz-print-mode .hz-save-block,
      body.hz-print-mode [data-hz-print-exclude],
      body.hz-print-mode button,
      body.hz-print-mode .hz-toggle__trigger,
      body.hz-print-mode .hz-diag__controls,
      body.hz-print-mode .hz-diag__points,
      body.hz-print-mode .hz-info,
      body.hz-print-mode summary { display: none !important; }

      /* Auch die offenen details-Blocks auf nur-Inhalt reduzieren */
      body.hz-print-mode details { background: transparent !important; border: 0 !important; box-shadow: none !important; padding: 0 !important; }
      body.hz-print-mode details > *:not(summary) { display: block !important; }

      /* Container-Reset fuer Druck */
      body.hz-print-mode {
        background: #FFFFFF !important;
        color: #1A1A1A !important;
        font-size: 11pt;
        line-height: 1.5;
      }
      body.hz-print-mode .hz-scope { display: block; min-height: 0; }
      body.hz-print-mode .hz-main { padding: 0 !important; }
      body.hz-print-mode .hz-container {
        max-width: 100% !important;
        padding: 0 !important;
      }

      /* Sektionen ohne grosse Farbflaechen, mit Seitenumbruch danach */
      body.hz-print-mode section.hz-section {
        padding: 8mm 0 6mm !important;
        background: #FFFFFF !important;
        break-inside: avoid;
        page-break-inside: avoid;
      }
      body.hz-print-mode section.hz-section + section.hz-section {
        page-break-before: auto;
      }

      /* Headlines dezenter */
      body.hz-print-mode h1 { font-size: 22pt; margin: 0 0 6pt; }
      body.hz-print-mode h2 { font-size: 16pt; margin: 0 0 5pt; color: #1B2A4A !important; }
      body.hz-print-mode h3 { font-size: 12pt; margin: 0 0 4pt; }
      body.hz-print-mode .hz-kicker { font-size: 9pt; letter-spacing: 1.6px; }

      /* KPI-Kacheln kompakt */
      body.hz-print-mode .hz-kpi-card {
        box-shadow: none !important;
        border: 1px solid #E2E5EB !important;
      }

      /* Grid-Sum-Karten duerfen den Seitenumbruch nicht zerreissen */
      body.hz-print-mode .hz-sum-card,
      body.hz-print-mode .hz-kpi-grid,
      body.hz-print-mode .hz-kpi-card { break-inside: avoid; page-break-inside: avoid; }

      /* Canvas wird durch das Screenshot-<img> ersetzt */
      body.hz-print-mode #hz-diag-canvas { display: none !important; }
      body.hz-print-mode .hz-diag__print-img {
        display: block;
        width: 100%;
        max-height: 95mm;
        object-fit: contain;
        border: 1px solid #E2E5EB;
        border-radius: 6px;
        padding: 6px;
        background: #FFFFFF;
      }

      /* Footer pro Seite: Firma links, Seitenzahlen rechts (via CSS Counters) */
      @page { @bottom-left  { content: 'Thermowerk · Heizlastberechnung'; font-family: 'DM Sans', sans-serif; font-size: 8pt; color: #6B7280; }
              @bottom-right { content: 'Seite ' counter(page) ' / ' counter(pages); font-family: 'DM Sans', sans-serif; font-size: 8pt; color: #6B7280; } }

      /* Conditional Parts: blende die Sektion aus, wenn der jeweilige
         Parts-Toggle nicht aktiv ist. Matcht via :not auf body-Klasse. */
      body.hz-print-mode:not(.hz-print-objekt-on) #sektion-1,
      body.hz-print-mode:not(.hz-print-objekt-on) #sektion-2,
      body.hz-print-mode:not(.hz-print-objekt-on) #sektion-3,
      body.hz-print-mode:not(.hz-print-objekt-on) #sektion-4 { display: none !important; }

      body.hz-print-mode:not(.hz-print-resultate-on) #sektion-5,
      body.hz-print-mode:not(.hz-print-resultate-on) #sektion-6 { display: none !important; }

      body.hz-print-mode:not(.hz-print-diagramm-on) #sektion-diagramm { display: none !important; }

      /* Formeln & Rechenwege: standardmaessig versteckt, nur wenn Flag an */
      body.hz-print-mode:not(.hz-print-formeln-on) [data-hz-calc-steps],
      body.hz-print-mode:not(.hz-print-formeln-on) .hz-formel { display: none !important; }

      /* Notizen (Phase 9 / Block L): zwei Body-Klassen schalten Bereichs-
         Notizen und Projekt-Notiz getrennt ein/aus. Beim Druck ist eine
         Notiz sichtbar, wenn die jeweilige Klasse gesetzt ist. Wenn weder
         Bereichs- noch Projekt-Klasse aktiv ist, werden alle Notizen
         ausgeblendet. */
      body.hz-print-mode:not(.hz-print-notizen-bereiche-on):not(.hz-print-notizen-projekt-on) .hz-notes { display: none !important; }
      body.hz-print-mode:not(.hz-print-notizen-bereiche-on) .hz-notes:not([data-hz-note-slot="projekt"]) { display: none !important; }
      body.hz-print-mode:not(.hz-print-notizen-projekt-on) .hz-notes[data-hz-note-slot="projekt"] { display: none !important; }

      /* Grundlagen: Block sichtbar wenn Flag an */
      body.hz-print-mode:not(.hz-print-grundlagen-on) .hz-grundlagen { display: none !important; }

      /* Plausibilitaet: nur exportieren wenn Flag gesetzt (Phase 9 / Block H) */
      body.hz-print-mode:not(.hz-print-plausi-on) [data-hz-plausi] { display: none !important; }
    }
  </style>
</head>

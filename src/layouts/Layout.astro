---
// Basis-Layout für alle Seiten
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Thermowerk – Wärmepumpen & Klimaanlagen | Neftenbach, Zürich",
  description = "WPSM-zertifizierter Fachbetrieb für Luft-Wasser-Wärmepumpen. Persönliche Beratung, fachgerechte Montage und Förderberatung in ZH, SH, TG, AG."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Outfit:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style is:global>
    /* ==========================================
       THERMOWERK – STYLESHEET
       ========================================== */

    /* 1. VARIABLEN */
    :root {
      --navy: #1B2A4A;
      --navy-light: #243658;
      --navy-dark: #111D33;
      --red: #D93025;
      --red-hover: #B71C1C;
      --white: #FFFFFF;
      --off-white: #F7F8FA;
      --light-gray: #EEF0F4;
      --mid-gray: #6B7280;
      --dark: #1A1A1A;
      --border: #E2E5EB;
      --blue-tint: #E8EDF5;
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --header-height: 88px;
      --hero-left-offset: clamp(36px, 9vw, 200px);
    }

    /* 2. RESET & BASIS */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); font-size: 17px; line-height: 1.7; color: var(--dark); background: var(--white); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* 3. LAYOUT */
    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
    .section-padding { padding: 100px 0; }
    .text-center { text-align: center; }

    /* 4. TYPOGRAFIE */
    h1, h2, h3, h4 { font-family: var(--font-heading); font-weight: 700; line-height: 1.2; color: var(--dark); }
    h1 { font-size: clamp(34px, 5vw, 52px); }
    h2 { font-size: clamp(28px, 3.8vw, 40px); margin-bottom: 20px; }
    h3 { font-size: 22px; margin-bottom: 8px; }
    h4 { font-size: 19px; font-weight: 600; }
    .section-subtitle { font-size: 15px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 12px; font-family: var(--font-heading); }

    /* 5. BUTTONS */
    .btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-heading); font-weight: 600; font-size: 16px; padding: 15px 34px; border-radius: 6px; border: none; cursor: pointer; transition: all 0.3s ease; text-decoration: none; }
    .btn-primary { background: var(--red); color: var(--white); }
    .btn-primary:hover { background: var(--red-hover); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(217, 48, 37, 0.3); }
    .btn-outline { background: transparent; color: var(--white); border: 2px solid rgba(255, 255, 255, 0.4); }
    .btn-outline:hover { border-color: var(--white); background: rgba(255, 255, 255, 0.1); }
    .btn-dark { background: var(--navy); color: var(--white); }
    .btn-dark:hover { background: var(--navy-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(27, 42, 74, 0.3); }

    /* 6. HEADER */
    .header { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: rgba(255, 255, 255, 0.97); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); transition: box-shadow 0.3s ease; }
    .header.scrolled { box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08); }
    .header-inner { display: flex; align-items: center; justify-content: space-between; height: var(--header-height); padding: 0 clamp(18px, 4vw, 64px); }
    .logo-img { height: clamp(44px, 6vw, 62px); width: auto; }
    .nav { display: flex; align-items: center; gap: clamp(34px, 6vw, 84px); }
    .nav a { font-family: 'Montserrat', var(--font-heading); font-size: clamp(16px, 1.6vw, 19px); font-weight: 500; letter-spacing: -0.1px; color: var(--dark); transition: color 0.2s; position: relative; }
    .nav a:hover { color: var(--navy); }
    .nav a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: var(--red); transition: width 0.3s ease; }
    .nav a:hover::after { width: 100%; }
    .nav .btn-primary { color: var(--white) !important; font-size: 15px; padding: 12px 28px; }
    .nav .btn-primary::after { display: none; }
    .menu-toggle { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 8px; }
    .menu-toggle span { width: 24px; height: 2px; background: var(--dark); transition: all 0.3s; }

    /* 7. HERO */
    .hero { position: relative; min-height: 90vh; display: flex; align-items: center; background: var(--navy); overflow: hidden; padding-top: var(--header-height); }
    .hero-inner { position: relative; z-index: 2; width: 100%; padding: 0 clamp(18px, 5vw, 80px); min-height: calc(90vh - var(--header-height)); display: flex; align-items: center; }
    .hero-bg { position: absolute; inset: 0; z-index: 1; }
    .hero-bg img { width: 100%; height: 100%; object-fit: cover; object-position: 70% center; opacity: 0.5; }
    .hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, var(--navy) 15%, rgba(27, 42, 74, 0.55) 45%, rgba(27, 42, 74, 0.15) 100%); }
    .hero-content { max-width: 640px; margin-left: var(--hero-left-offset); }
    .hero h1 { color: var(--white); margin-bottom: 8px; font-weight: 800; font-size: clamp(33px, 4.5vw, 52px); letter-spacing: -0.3px; }
    .hero-subtitle { font-family: var(--font-heading); font-size: clamp(26px, 3.2vw, 38px); font-weight: 500; color: rgba(255,255,255,0.85); margin-bottom: 24px; line-height: 1.3; }
    .hero-text { font-size: clamp(18px, 1.8vw, 22px); color: rgba(255, 255, 255, 0.8); margin-bottom: 28px; line-height: 1.65; }
    .hero-buttons { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
    .hero-note { margin-top: 18px; font-size: 14px; color: rgba(255, 255, 255, 0.5); }

    /* 8. ÜBER UNS */
    .about { background: var(--white); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
    .promise-box { background: var(--off-white); border-radius: 12px; padding: 36px; border: 1px solid var(--border); }
    .promise-box h4 { margin-bottom: 20px; color: var(--navy); }
    .promise-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .promise-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 15px; line-height: 1.6; }
    .promise-icon { flex-shrink: 0; width: 24px; height: 24px; background: var(--navy); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 2px; }
    .promise-icon svg { width: 14px; height: 14px; stroke: var(--white); fill: none; stroke-width: 2.5; }

    /* 9. BILD-STREIFEN */
    .img-break { width: 100%; height: 320px; overflow: hidden; position: relative; }
    .img-break .img-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%); display: flex; align-items: center; justify-content: center; color: rgba(255, 255, 255, 0.3); font-family: var(--font-heading); font-size: 14px; letter-spacing: 1px; text-transform: uppercase; }

    /* 10. ABLAUF */
    .steps { background: var(--off-white); }
    .steps-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-top: 48px; }
    .step-card { background: var(--white); border-radius: 12px; padding: 32px 24px; border: 1px solid var(--border); transition: transform 0.3s, box-shadow 0.3s; }
    .step-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06); }
    .step-number { font-family: var(--font-heading); font-size: 48px; font-weight: 800; color: var(--light-gray); line-height: 1; margin-bottom: 16px; }
    .step-card h3 { color: var(--navy); font-size: 18px; margin-bottom: 12px; }
    .step-card p { font-size: 14px; color: var(--mid-gray); line-height: 1.6; }
    .steps-cta { text-align: center; margin-top: 48px; }

    /* 11. WPSM */
    .wpsm { background: var(--white); }
    .wpsm-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center; }
    .wpsm-badge { background: var(--navy); border-radius: 16px; padding: 48px; text-align: center; color: var(--white); position: relative; overflow: hidden; }
    .wpsm-badge::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 30% 70%, rgba(217, 48, 37, 0.15) 0%, transparent 50%); }
    .wpsm-badge-number { font-family: var(--font-heading); font-size: 72px; font-weight: 800; line-height: 1; margin-bottom: 8px; position: relative; }
    .wpsm-badge-text { font-size: 16px; opacity: 0.8; position: relative; line-height: 1.5; }
    .wpsm-badge-label { margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255, 255, 255, 0.15); font-family: var(--font-heading); font-weight: 600; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; position: relative; }

    /* 12. WARUM LUFT-WASSER */
    .why { background: var(--off-white); }
    .why-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; margin-bottom: 48px; }
    .why-hero-img { border-radius: 16px; overflow: hidden; height: 360px; }
    .why-hero-img img { width: 100%; height: 100%; object-fit: cover; }
    .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 40px; }
    .why-card { background: var(--white); border-radius: 12px; padding: 28px 24px; border: 1px solid var(--border); }
    .why-icon { width: 48px; height: 48px; background: var(--blue-tint); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
    .why-icon svg { width: 24px; height: 24px; stroke: var(--navy); fill: none; stroke-width: 1.8; }
    .why-card h4 { margin-bottom: 8px; font-size: 16px; }
    .why-card p { font-size: 14px; color: var(--mid-gray); line-height: 1.6; }

    /* 12a. KLIMAANLAGEN */
    .klima { background: var(--white); }
    .klima-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .klima-img { border-radius: 16px; overflow: hidden; height: 400px; background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%); }
    .klima-img img { width: 100%; height: 100%; object-fit: cover; }
    .klima-features { display: flex; flex-direction: column; gap: 14px; margin-top: 24px; }
    .klima-feature { display: flex; align-items: center; gap: 12px; font-size: 15px; line-height: 1.5; }
    .klima-feature svg { width: 22px; height: 22px; stroke: var(--navy); fill: none; stroke-width: 2; flex-shrink: 0; }

    /* 12b. KOSTENRECHNER */
    .calculator { background: var(--white); }
    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
    .calc-inputs { display: flex; flex-direction: column; gap: 28px; }
    .calc-field label { display: block; font-family: var(--font-heading); font-size: 14px; font-weight: 600; color: var(--dark); margin-bottom: 10px; }
    .calc-slider-row { display: flex; align-items: center; gap: 16px; }
    .calc-slider { flex: 1; -webkit-appearance: none; appearance: none; height: 6px; border-radius: 3px; background: var(--light-gray); outline: none; cursor: pointer; }
    .calc-slider::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 22px; height: 22px; border-radius: 50%; background: var(--navy); cursor: pointer; border: 3px solid var(--white); box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2); }
    .calc-slider::-moz-range-thumb { width: 22px; height: 22px; border-radius: 50%; background: var(--navy); cursor: pointer; border: 3px solid var(--white); box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2); }
    .calc-value { font-family: var(--font-heading); font-weight: 600; font-size: 15px; color: var(--navy); min-width: 110px; text-align: right; white-space: nowrap; }
    .calc-toggle-group { display: flex; gap: 8px; }
    .calc-toggle { flex: 1; padding: 10px 16px; border: 2px solid var(--border); border-radius: 8px; background: var(--white); font-family: var(--font-body); font-size: 14px; color: var(--mid-gray); cursor: pointer; transition: all 0.2s; text-align: center; }
    .calc-toggle:hover { border-color: var(--navy); color: var(--dark); }
    .calc-toggle.active { background: var(--navy); border-color: var(--navy); color: var(--white); }
    .calc-results { background: var(--off-white); border-radius: 16px; padding: 36px; border: 1px solid var(--border); }
    .calc-result-card { text-align: center; margin-bottom: 28px; }
    .calc-result-header { font-family: var(--font-heading); font-size: 14px; font-weight: 600; color: var(--mid-gray); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    .calc-saving { font-family: var(--font-heading); font-size: 48px; font-weight: 800; color: var(--navy); line-height: 1.1; }
    .calc-breakdown { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
    .calc-row { display: flex; justify-content: space-between; align-items: center; }
    .calc-label { font-size: 14px; color: var(--mid-gray); }
    .calc-hint { font-size: 12px; opacity: 0.7; }
    .calc-data { font-family: var(--font-heading); font-weight: 600; font-size: 15px; color: var(--dark); }
    .calc-divider { height: 1px; background: var(--border); margin: 4px 0; }
    .calc-row-highlight .calc-data { color: var(--navy); font-size: 17px; }
    .calc-row-old .calc-data { color: var(--red); font-size: 17px; text-decoration: line-through; opacity: 0.7; }
    .calc-disclaimer { font-size: 12px; color: var(--mid-gray); line-height: 1.5; margin-top: 20px; }

    /* 13. REGION */
    .region { background: var(--navy); color: var(--white); position: relative; overflow: hidden; }
    .region::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px; }
    .region-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; position: relative; }
    .region h2 { color: var(--white); }
    .region p { color: rgba(255, 255, 255, 0.75); margin-bottom: 16px; }
    .region-facts { display: flex; flex-direction: column; gap: 20px; margin: 32px 0; }
    .region-fact { display: flex; align-items: center; gap: 16px; }
    .region-fact-icon { width: 44px; height: 44px; background: rgba(255,255,255,0.08); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .region-fact-icon svg { width: 22px; height: 22px; stroke: var(--white); fill: none; stroke-width: 1.8; }
    .region-fact-text { font-size: 15px; color: rgba(255,255,255,0.85); }
    .region-fact-text strong { color: var(--white); }
    .region-map { background: var(--navy-light); border-radius: 16px; height: 360px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08); }
    .region-map iframe { width: 100%; height: 100%; border: 0; border-radius: 16px; filter: saturate(0.3) brightness(0.8); transition: filter 0.3s; }
    .region-map:hover iframe { filter: saturate(0.6) brightness(0.9); }

    /* 14. KONTAKT */
    .contact { background: var(--white); }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
    .contact-info-item { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 24px; }
    .contact-icon { width: 44px; height: 44px; background: var(--blue-tint); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .contact-icon svg { width: 20px; height: 20px; stroke: var(--navy); fill: none; stroke-width: 1.8; }
    .contact-info-item h4 { margin-bottom: 2px; font-size: 15px; }
    .contact-info-item p { font-size: 15px; color: var(--mid-gray); }
    .contact-info-item a { color: var(--navy); font-weight: 600; font-size: 18px; }
    .contact-hint { margin-top: 32px; padding: 24px; background: var(--blue-tint); border-radius: 12px; }
    .contact-hint p { font-size: 15px; color: var(--navy); }
    .contact-form { background: var(--off-white); border-radius: 16px; padding: 40px; border: 1px solid var(--border); }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 6px; color: var(--dark); font-family: var(--font-heading); }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 12px 16px; border: 1px solid var(--border); border-radius: 8px; font-family: var(--font-body); font-size: 15px; color: var(--dark); background: var(--white); transition: border-color 0.2s, box-shadow 0.2s; }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: var(--navy); box-shadow: 0 0 0 3px rgba(27, 42, 74, 0.1); }
    .form-group textarea { resize: vertical; min-height: 120px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-submit { width: 100%; margin-top: 4px; }
    .form-note { font-size: 13px; color: var(--mid-gray); margin-top: 12px; }

    /* 15. FOOTER */
    .footer { background: var(--navy-dark); color: rgba(255,255,255,0.6); padding: 60px 0 30px; }
    .footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .footer-brand { font-size: 14px; line-height: 1.7; }
    .footer-logo { margin-bottom: 16px; }
    .footer-logo img { height: 36px; width: auto; filter: brightness(0) invert(1); opacity: 0.85; }
    .footer h4 { color: var(--white); font-size: 14px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 16px; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-links a { font-size: 14px; transition: color 0.2s; }
    .footer-links a:hover { color: var(--white); }
    .footer-bottom { padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
    .footer-legal { display: flex; gap: 24px; }
    .footer-legal a:hover { color: var(--white); }

    /* 16. ANIMATIONEN */
    .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    /* 17. RESPONSIVE */
    @media (max-width: 968px) {
      :root { --header-height: 76px; --hero-left-offset: 0px; }
      .about-grid, .wpsm-grid, .contact-grid, .region-grid, .why-hero, .calc-grid, .klima-grid { grid-template-columns: 1fr; }
      .steps-grid, .why-grid { grid-template-columns: 1fr 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .nav { display: none; }
      .nav.open { display: flex; flex-direction: column; position: fixed; inset: var(--header-height) 0 0 0; background: var(--white); padding: 32px 24px; gap: 24px; border-top: 1px solid var(--border); z-index: 999; }
      .nav.open .btn { width: 100%; justify-content: center; }
      .menu-toggle { display: flex; }
      .hero-content { margin-left: 0; }
      .why-hero-img { height: 280px; }
    }
    @media (max-width: 640px) {
      :root { --header-height: 68px; }
      .section-padding { padding: 64px 0; }
      .steps-grid, .why-grid { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; }
      .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
      .hero { min-height: 100svh; }
      .hero-inner { min-height: calc(100svh - var(--header-height)); padding-top: 44px; padding-bottom: 32px; align-items: flex-start; }
      .hero h1 { font-size: 30px; margin-top: -24px; }
      .hero-subtitle { font-size: 23px; padding-top: 8px; margin-bottom: 18px; }
      .hero-text { font-size: 16px; margin-top: 30px; margin-bottom: 104px; line-height: 1.6; max-width: 88%; }
      .hero-bg { top: 35%; bottom: 0; left: 0; right: 0; height: auto; }
      .hero-bg img { object-position: 80% top; opacity: 0.7; }
      .hero-bg::after { background: linear-gradient(180deg, var(--navy) 0%, rgba(27, 42, 74, 0.5) 25%, rgba(27, 42, 74, 0.35) 100%); }
      .hero-content { max-width: 100%; }
      .hero-buttons { flex-direction: column; align-items: flex-start; }
      .hero-note { font-size: 13px; }
      .wpsm-badge { padding: 32px; }
      .wpsm-badge-number { font-size: 56px; }
      .img-break { height: 200px; }
      .calc-saving { font-size: 36px; }
      .calc-toggle-group { flex-direction: column; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>

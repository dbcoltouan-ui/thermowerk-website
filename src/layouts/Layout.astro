---
// Basis-Layout für alle Seiten
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Thermowerk – Wärmepumpen & Klimaanlagen | Neftenbach, Zürich",
  description = "WPSM-zertifizierter Fachbetrieb für Luft-Wasser-Wärmepumpen. Persönliche Beratung, fachgerechte Montage und Förderberatung in ZH, SH, TG, AG."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Outfit:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style is:global>
    /* ==========================================
       THERMOWERK – STYLESHEET
       ========================================== */

    /* 1. VARIABLEN */
    :root {
      --navy: #1B2A4A;
      --navy-light: #243658;
      --navy-dark: #111D33;
      --red: #D93025;
      --red-hover: #B71C1C;
      --white: #FFFFFF;
      --off-white: #F7F8FA;
      --light-gray: #EEF0F4;
      --mid-gray: #6B7280;
      --dark: #1A1A1A;
      --border: #E2E5EB;
      --blue-tint: #E8EDF5;
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --header-height: 88px;
      --hero-left-offset: 0px;
    }

    /* 2. RESET & BASIS */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); font-size: 17px; line-height: 1.7; color: var(--dark); background: var(--white); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* 3. LAYOUT */
    .container { max-width: 1120px; margin: 0 auto; padding: 0 clamp(16px, 3vw, 24px); }
    .section-padding { padding: clamp(60px, 10svh, 100px) 0; }
    .text-center { text-align: center; }

    /* 4. TYPOGRAFIE */
    h1, h2, h3, h4 { font-family: var(--font-heading); font-weight: 700; line-height: 1.2; color: var(--dark); }
    h1 { font-size: clamp(34px, 5vw, 52px); }
    h2 { font-size: clamp(28px, 3.8vw, 40px); margin-bottom: clamp(14px, 2.5svh, 20px); }
    h3 { font-size: clamp(19px, 2.2vw, 22px); margin-bottom: clamp(6px, 1svh, 8px); }
    h4 { font-size: clamp(17px, 1.9vw, 19px); font-weight: 600; }
    .section-subtitle { font-size: clamp(13px, 1.5vw, 15px); font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: clamp(8px, 1.5svh, 12px); font-family: var(--font-heading); }
    .section-subheading { font-family: var(--font-heading); font-size: clamp(20px, 2.5vw, 26px); font-weight: 500; color: var(--mid-gray); line-height: 1.4; margin-bottom: clamp(14px, 2.5svh, 20px); }

    /* 5. BUTTONS */
    .btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-heading); font-weight: 600; font-size: clamp(14px, 1.6vw, 16px); padding: clamp(12px, 1.8svh, 15px) clamp(24px, 3vw, 34px); border-radius: 3px; border: none; cursor: pointer; transition: all 0.3s ease; text-decoration: none; }
    .btn-primary { background: var(--red); color: var(--white); }
    .btn-primary:hover { background: var(--red-hover); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(217, 48, 37, 0.3); }
    .btn-outline { background: transparent; color: var(--white); border: 2px solid rgba(255, 255, 255, 0.4); }
    .btn-outline:hover { border-color: var(--white); background: rgba(255, 255, 255, 0.1); }
    .btn-dark { background: var(--navy); color: var(--white); }
    .btn-dark:hover { background: var(--navy-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(27, 42, 74, 0.3); }
    .btn-outline-dark { background: transparent; color: var(--navy); border: 2px solid var(--navy); }
    .btn-outline-dark:hover { background: var(--navy); color: var(--white); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(27, 42, 74, 0.2); }

    /* 6. HEADER */
    .header { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: #FFFFFF; border-bottom: 1px solid var(--border); transition: box-shadow 0.3s ease; padding-top: env(safe-area-inset-top, 0px); }
    .header.scrolled { box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08); }
    .header-inner { display: flex; align-items: center; justify-content: space-between; height: var(--header-height); max-width: 1120px; margin: 0 auto; padding: 0 24px; }
    .logo-img { height: clamp(34px, 3.5vw, 36px); width: auto; }
    .nav { display: flex; align-items: center; gap: clamp(20px, 3vw, 44px); }
    .nav > a, .nav-dropdown-trigger { font-family: 'Montserrat', var(--font-heading); font-size: 18px; font-weight: 500; letter-spacing: -0.1px; color: var(--dark); transition: color 0.2s; position: relative; cursor: pointer; display: inline-flex; align-items: center; text-decoration: none; }
    .nav > a:hover, .nav-dropdown-trigger:hover { color: var(--navy); }
    .nav > a::after, .nav-dropdown-trigger::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: var(--red); transition: width 0.3s ease; }
    .nav > a:hover::after, .nav-dropdown-trigger:hover::after { width: 100%; }
    .nav .btn-primary { color: var(--white) !important; font-size: 14px; padding: 10px 24px; white-space: nowrap; }
    .nav .btn-primary::after { display: none; }
    .mobile-menu-link { display: none; }
    .mobile-menu-buttons { display: none; }
    .btn-stoerung { display: none; }
    .btn-stoerung::after { display: none !important; }
    .footer-stoerung { display: inline-flex; align-items: center; gap: 6px; color: var(--red) !important; font-weight: 600; border: 1px solid rgba(217, 48, 37, 0.3); padding: 6px 14px; border-radius: 3px; font-size: 13px; transition: all 0.3s ease; }
    .footer-stoerung:hover { background: var(--red); color: var(--white) !important; border-color: var(--red); }
    /* Dropdown */
    .nav-dropdown { position: relative; }
    .nav-dropdown-menu { position: absolute; top: 100%; left: -16px; padding-top: 12px; opacity: 0; visibility: hidden; transform: translateY(4px); transition: all 0.25s ease; z-index: 100; }
    .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
    .nav-dropdown-menu a { display: block; padding: 10px 20px; font-family: 'Montserrat', var(--font-heading); font-size: 14px; font-weight: 500; color: var(--dark); white-space: nowrap; background: var(--white); border: 1px solid var(--border); border-top: none; transition: background 0.2s, color 0.2s; }
    .nav-dropdown-menu a:first-child { border-top: 1px solid var(--border); border-radius: 3px 3px 0 0; }
    .nav-dropdown-menu a:last-child { border-radius: 0 0 3px 3px; }
    .nav-dropdown-menu a::after { display: none; }
    .nav-dropdown-menu a:hover { background: var(--blue-tint); color: var(--navy); }
    .menu-toggle { display: none; flex-direction: column; gap: 6px; cursor: pointer; background: none; border: none; padding: 8px; z-index: 1002; }
    .menu-toggle span { display: block; width: 24px; height: 2px; background: var(--dark); border-radius: 2px; transition: transform 0.3s ease, opacity 0.3s ease; transform-origin: center; }
    .menu-toggle.active span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    .menu-toggle.active span:nth-child(2) { opacity: 0; }
    .menu-toggle.active span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

    /* 7. HERO */
    .hero { position: relative; min-height: 90svh; display: flex; align-items: center; background: var(--navy); overflow: hidden; padding-top: var(--header-height); }
    .hero-inner { position: relative; z-index: 2; width: 100%; max-width: 1120px; margin: 0 auto; padding: 0 24px; min-height: calc(90svh - var(--header-height)); display: flex; align-items: center; }
    .hero-bg { position: absolute; inset: 0; z-index: 1; }
    .hero-bg img { width: 100%; height: 100%; object-fit: cover; object-position: 78% center; opacity: 0.5; }
    .hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, var(--navy) 15%, rgba(27, 42, 74, 0.55) 45%, rgba(27, 42, 74, 0.15) 100%); }
    .hero-content { max-width: 640px; }
    .hero h1 { color: var(--white); margin-bottom: clamp(4px, 1svh, 10px); font-weight: 800; font-size: clamp(33px, 4.5vw, 52px); letter-spacing: -0.3px; }
    .hero-subtitle { font-family: var(--font-heading); font-size: clamp(26px, 3.2vw, 38px); font-weight: 500; color: rgba(255,255,255,0.85); margin-bottom: clamp(16px, 3svh, 28px); line-height: 1.3; }
    .hero-text { font-size: clamp(18px, 1.8vw, 22px); color: rgba(255, 255, 255, 0.8); margin-bottom: clamp(20px, 3.5svh, 32px); line-height: 1.65; }
    .hero-buttons { display: flex; align-items: center; gap: clamp(12px, 1.5vw, 16px); flex-wrap: wrap; }
    .hero-note { margin-top: clamp(12px, 2svh, 20px); font-size: clamp(12px, 1.4vw, 14px); color: rgba(255, 255, 255, 0.5); }

    /* 8. ÜBER UNS (neues Layout mit Bild rechts) */
    .about { background: var(--white); }
    .about-intro { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: clamp(32px, 4vw, 48px); align-items: start; margin-bottom: clamp(32px, 5svh, 48px); }
    .about-intro-text p { font-size: clamp(14px, 1.6vw, 16px); color: var(--mid-gray); line-height: 1.7; }
    .about-claim { font-family: var(--font-heading); font-size: clamp(17px, 2vw, 20px); font-weight: 700; color: var(--dark); margin-top: clamp(16px, 3svh, 24px); }
    .about-intro-img { }
    .img-placeholder-box { background: var(--off-white); border: 2px dashed var(--border); border-radius: 2px; height: 380px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; color: var(--mid-gray); font-size: 14px; font-family: var(--font-heading); }
    .about-usp-heading { margin-bottom: clamp(16px, 3svh, 24px); }
    .about-usp-heading h3 { font-size: clamp(20px, 2.5vw, 24px); color: var(--navy); }
    .about-usp-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(16px, 2.5vw, 24px); margin-bottom: clamp(32px, 5svh, 48px); }
    .about-usp-card { background: var(--off-white); border-radius: 2px; padding: clamp(20px, 3svh, 28px) clamp(18px, 2.5vw, 24px); border: 1px solid var(--border); transition: transform 0.3s, box-shadow 0.3s; }
    .about-usp-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06); }
    .about-usp-icon { width: clamp(40px, 5vw, 48px); height: clamp(40px, 5vw, 48px); background: var(--navy); border-radius: 2px; display: flex; align-items: center; justify-content: center; margin-bottom: clamp(12px, 2svh, 16px); }
    .about-usp-icon svg { width: clamp(20px, 2.5vw, 24px); height: clamp(20px, 2.5vw, 24px); stroke: var(--white); fill: none; stroke-width: 1.8; }
    .about-usp-card h4 { margin-bottom: clamp(6px, 1svh, 8px); font-size: clamp(15px, 1.7vw, 17px); color: var(--navy); }
    .about-usp-card p { font-size: clamp(13px, 1.4vw, 14px); color: var(--mid-gray); line-height: 1.65; }
    .about-closing { max-width: 800px; }
    .about-closing p { font-size: clamp(14px, 1.6vw, 16px); color: var(--mid-gray); line-height: 1.7; }

    /* 9. LEISTUNGEN (Service-Karten – kaeltech-Style mit Bild oben) */
    .services { background: var(--off-white); }
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(20px, 2.5vw, 28px); margin-top: clamp(32px, 5svh, 48px); }
    .service-card { display: flex; flex-direction: column; background: var(--white); border-radius: 2px; overflow: hidden; border: 1px solid var(--border); transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s; text-decoration: none; color: inherit; }
    .service-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08); border-color: var(--navy); }
    .service-card-img { height: 200px; overflow: hidden; background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%); }
    .service-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
    .service-card:hover .service-card-img img { transform: scale(1.05); }
    .service-img-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: rgba(255, 255, 255, 0.35); }
    .service-card-body { padding: clamp(20px, 3svh, 28px) clamp(18px, 2.5vw, 24px); display: flex; flex-direction: column; flex: 1; }
    .service-card h3 { color: var(--navy); font-size: clamp(18px, 2vw, 20px); margin-bottom: clamp(8px, 1.5svh, 12px); }
    .service-card p { font-size: clamp(14px, 1.5vw, 15px); color: var(--mid-gray); line-height: 1.65; flex: 1; }
    .service-link { display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-weight: 600; font-size: clamp(14px, 1.5vw, 15px); color: var(--navy); margin-top: clamp(14px, 2.5svh, 20px); padding: clamp(8px, 1.2svh, 10px) clamp(18px, 2.5vw, 24px); border: 2px solid var(--navy); border-radius: 3px; transition: all 0.3s ease; align-self: center; }
    .service-card:hover .service-link { background: var(--navy); color: var(--white); }

    /* 9a. HERSTELLERLOGOS */
    .logos-bar { background: var(--white); padding: 40px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .logos-track { display: flex; align-items: center; justify-content: center; gap: clamp(32px, 5vw, 64px); flex-wrap: wrap; }
    .logo-placeholder { font-family: var(--font-heading); font-size: 16px; font-weight: 600; color: var(--light-gray); letter-spacing: 1px; text-transform: uppercase; padding: 8px 16px; border: 2px dashed var(--border); border-radius: 2px; white-space: nowrap; }
    .logos-track img { height: 32px; width: auto; filter: grayscale(100%) opacity(0.45); transition: filter 0.3s; }
    .logos-track img:hover { filter: grayscale(0%) opacity(1); }

    /* 10. ABLAUF */
    .steps { background: var(--off-white); }
    .steps-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: clamp(14px, 2vw, 20px); margin-top: clamp(32px, 5svh, 48px); }
    .step-card { background: var(--white); border-radius: 2px; padding: clamp(24px, 3.5svh, 32px) clamp(18px, 2.5vw, 24px); border: 1px solid var(--border); transition: transform 0.3s, box-shadow 0.3s; }
    .step-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06); }
    .step-number { font-family: var(--font-heading); font-size: clamp(36px, 4.5vw, 48px); font-weight: 800; color: var(--light-gray); line-height: 1; margin-bottom: clamp(12px, 2svh, 16px); }
    .step-card h3 { color: var(--navy); font-size: clamp(16px, 1.8vw, 18px); margin-bottom: clamp(8px, 1.5svh, 12px); }
    .step-card p { font-size: clamp(13px, 1.4vw, 14px); color: var(--mid-gray); line-height: 1.6; }
    .steps-cta { text-align: center; margin-top: clamp(32px, 5svh, 48px); }

    /* 11. WPSM */
    .wpsm { background: var(--white); }
    .wpsm-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center; }
    .wpsm-badge { background: var(--navy); border-radius: 2px; padding: 48px; text-align: center; color: var(--white); position: relative; overflow: hidden; }
    .wpsm-badge::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 30% 70%, rgba(217, 48, 37, 0.15) 0%, transparent 50%); }
    .wpsm-badge-number { font-family: var(--font-heading); font-size: 72px; font-weight: 800; line-height: 1; margin-bottom: 8px; position: relative; }
    .wpsm-badge-text { font-size: 16px; opacity: 0.8; position: relative; line-height: 1.5; }
    .wpsm-badge-label { margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255, 255, 255, 0.15); font-family: var(--font-heading); font-weight: 600; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; position: relative; }

    /* 12. WARUM LUFT-WASSER */
    .why { background: var(--off-white); }
    .why-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; margin-bottom: 48px; }
    .why-hero-img { border-radius: 2px; overflow: hidden; height: 360px; }
    .why-hero-img img { width: 100%; height: 100%; object-fit: cover; }
    .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 40px; }
    .why-card { background: var(--white); border-radius: 2px; padding: 28px 24px; border: 1px solid var(--border); }
    .why-icon { width: 48px; height: 48px; background: var(--blue-tint); border-radius: 2px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
    .why-icon svg { width: 24px; height: 24px; stroke: var(--navy); fill: none; stroke-width: 1.8; }
    .why-card h4 { margin-bottom: 8px; font-size: 16px; }
    .why-card p { font-size: 14px; color: var(--mid-gray); line-height: 1.6; }
    .why-cta-row { display: flex; align-items: center; justify-content: space-between; gap: 32px; margin-top: 8px; flex-wrap: wrap; }
    .why-calc-hint { background: var(--blue-tint); border-radius: 2px; padding: 24px 28px; display: flex; align-items: center; gap: 20px; }
    .why-calc-hint p { font-size: 15px; font-weight: 600; color: var(--navy); white-space: nowrap; }

    /* 12a. KLIMAANLAGEN (neues Layout) */
    .klima { background: var(--white); }
    .klima-header { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 48px; align-items: center; margin-bottom: 48px; }
    .klima-header-text p { font-size: 16px; color: var(--mid-gray); line-height: 1.7; margin-top: 16px; }
    .klima-header-img { border-radius: 2px; overflow: hidden; height: 320px; background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%); }
    .klima-header-img img { width: 100%; height: 100%; object-fit: cover; }
    .klima-types-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 40px; }
    .klima-type-card { background: var(--off-white); border-radius: 2px; padding: 28px 24px; border: 1px solid var(--border); transition: transform 0.3s, box-shadow 0.3s; }
    .klima-type-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06); }
    .klima-type-icon { width: 48px; height: 48px; background: var(--blue-tint); border-radius: 2px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
    .klima-type-icon svg { width: 24px; height: 24px; stroke: var(--navy); fill: none; stroke-width: 1.8; }
    .klima-type-card h4 { margin-bottom: 8px; font-size: 17px; color: var(--navy); }
    .klima-type-card p { font-size: 14px; color: var(--mid-gray); line-height: 1.65; }
    .klima-cta { text-align: center; padding-top: 8px; }
    .klima-cta p { font-size: 16px; color: var(--mid-gray); margin-bottom: 20px; }

    /* 12b. KOSTENRECHNER */
    .calculator { background: var(--white); }
    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
    .calc-inputs { display: flex; flex-direction: column; gap: 28px; }
    .calc-field label { display: block; font-family: var(--font-heading); font-size: 14px; font-weight: 600; color: var(--dark); margin-bottom: 10px; }
    .calc-slider-row { display: flex; align-items: center; gap: 16px; }
    .calc-slider { flex: 1; -webkit-appearance: none; appearance: none; height: 6px; border-radius: 3px; background: var(--light-gray); outline: none; cursor: pointer; }
    .calc-slider::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 22px; height: 22px; border-radius: 50%; background: var(--navy); cursor: pointer; border: 3px solid var(--white); box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2); }
    .calc-slider::-moz-range-thumb { width: 22px; height: 22px; border-radius: 50%; background: var(--navy); cursor: pointer; border: 3px solid var(--white); box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2); }
    .calc-value { font-family: var(--font-heading); font-weight: 600; font-size: 15px; color: var(--navy); min-width: 110px; text-align: right; white-space: nowrap; }
    .calc-toggle-group { display: flex; gap: 8px; }
    .calc-toggle { flex: 1; padding: 10px 16px; border: 2px solid var(--border); border-radius: 3px; background: var(--white); font-family: var(--font-body); font-size: 14px; color: var(--mid-gray); cursor: pointer; transition: all 0.2s; text-align: center; }
    .calc-toggle:hover { border-color: var(--navy); color: var(--dark); }
    .calc-toggle.active { background: var(--navy); border-color: var(--navy); color: var(--white); }
    .calc-results { background: var(--off-white); border-radius: 2px; padding: 36px; border: 1px solid var(--border); }
    .calc-result-card { text-align: center; margin-bottom: 28px; }
    .calc-result-header { font-family: var(--font-heading); font-size: 14px; font-weight: 600; color: var(--mid-gray); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    .calc-saving { font-family: var(--font-heading); font-size: 48px; font-weight: 800; color: var(--navy); line-height: 1.1; }
    .calc-breakdown { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
    .calc-row { display: flex; justify-content: space-between; align-items: center; }
    .calc-label { font-size: 14px; color: var(--mid-gray); }
    .calc-hint { font-size: 12px; opacity: 0.7; }
    .calc-data { font-family: var(--font-heading); font-weight: 600; font-size: 15px; color: var(--dark); }
    .calc-divider { height: 1px; background: var(--border); margin: 4px 0; }
    .calc-row-highlight .calc-data { color: var(--navy); font-size: 17px; }
    .calc-row-old .calc-data { color: var(--red); font-size: 17px; text-decoration: line-through; opacity: 0.7; }
    .calc-disclaimer { font-size: 12px; color: var(--mid-gray); line-height: 1.5; margin-top: 20px; }

    /* 13. REGION */
    .region { background: var(--navy); color: var(--white); position: relative; overflow: hidden; }
    .region::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px; }
    .region-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; position: relative; }
    .region h2 { color: var(--white); }
    .region p { color: rgba(255, 255, 255, 0.75); margin-bottom: 16px; }
    .region-facts { display: flex; flex-direction: column; gap: 20px; margin: 32px 0; }
    .region-fact { display: flex; align-items: center; gap: 16px; }
    .region-fact-icon { width: 44px; height: 44px; background: rgba(255,255,255,0.08); border-radius: 2px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .region-fact-icon svg { width: 22px; height: 22px; stroke: var(--white); fill: none; stroke-width: 1.8; }
    .region-fact-text { font-size: 15px; color: rgba(255,255,255,0.85); }
    .region-fact-text strong { color: var(--white); }
    .region-map { background: var(--navy-light); border-radius: 2px; height: 360px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08); }
    .region-map iframe { width: 100%; height: 100%; border: 0; border-radius: 2px; filter: saturate(0.3) brightness(0.8); transition: filter 0.3s; }
    .region-map:hover iframe { filter: saturate(0.6) brightness(0.9); }

    /* 14. KONTAKT */
    .contact { background: var(--white); }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
    .contact-info-item { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 24px; }
    .contact-icon { width: 44px; height: 44px; background: var(--blue-tint); border-radius: 2px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .contact-icon svg { width: 20px; height: 20px; stroke: var(--navy); fill: none; stroke-width: 1.8; }
    .contact-info-item h4 { margin-bottom: 2px; font-size: 15px; }
    .contact-info-item p { font-size: 15px; color: var(--mid-gray); }
    .contact-info-item a { color: var(--navy); font-weight: 600; font-size: 18px; }
    .contact-hint { margin-top: 32px; padding: 24px; background: var(--blue-tint); border-radius: 2px; }
    .contact-hint p { font-size: 15px; color: var(--navy); }
    .contact-form { background: var(--off-white); border-radius: 2px; padding: 40px; border: 1px solid var(--border); }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 6px; color: var(--dark); font-family: var(--font-heading); }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 12px 16px; border: 1px solid var(--border); border-radius: 3px; font-family: var(--font-body); font-size: 15px; color: var(--dark); background: var(--white); transition: border-color 0.2s, box-shadow 0.2s; }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: var(--navy); box-shadow: 0 0 0 3px rgba(27, 42, 74, 0.1); }
    .form-group textarea { resize: vertical; min-height: 120px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-submit { width: 100%; margin-top: 4px; }
    .form-note { font-size: 13px; color: var(--mid-gray); margin-top: 12px; }

    /* 15. FOOTER */
    .footer { background: var(--navy-dark); color: rgba(255,255,255,0.6); padding: 60px 0 30px; }
    .footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .footer-brand { font-size: 14px; line-height: 1.7; }
    .footer-logo { margin-bottom: 16px; }
    .footer-logo img { height: 36px; width: auto; filter: brightness(0) invert(1); opacity: 0.85; }
    .footer h4 { color: var(--white); font-size: 14px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 16px; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-links a { font-size: 14px; transition: color 0.2s; }
    .footer-links a:hover { color: var(--white); }
    .footer-bottom { padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
    .footer-legal { display: flex; gap: 24px; }
    .footer-legal a:hover { color: var(--white); }

    /* 16. ANIMATIONEN */
    .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    /* 17. RESPONSIVE */
    @media (max-width: 968px) {
      :root { --header-height: 76px; }
      /* Mobile: Überschriften zentrieren */
      h2 { text-align: center; }
      .section-subheading { text-align: center; }
      .about-intro, .wpsm-grid, .contact-grid, .region-grid, .why-hero, .calc-grid, .klima-header { grid-template-columns: 1fr; }
      .steps-grid, .why-grid, .klima-types-grid { grid-template-columns: 1fr 1fr; }
      .services-grid { grid-template-columns: 1fr; }
      .about-usp-grid { grid-template-columns: 1fr 1fr; }
      .about-intro-img { order: -1; }
      .why-cta-row { flex-direction: column; align-items: stretch; }
      .why-calc-hint { flex-direction: column; text-align: center; gap: 12px; }
      .why-calc-hint p { white-space: normal; }
      /* Mobile: Hover-Effekte bei Karten entfernen */
      .service-card:hover { transform: none; box-shadow: none; border-color: var(--border); }
      .service-card:hover .service-link { background: transparent; color: var(--navy); }
      .service-card:hover .service-card-img img { transform: none; }
      .service-card-img img { transition: none; }
      .step-card:hover { transform: none; box-shadow: none; }
      .about-usp-card:hover { transform: none; box-shadow: none; }
      .klima-type-card:hover { transform: none; box-shadow: none; }
      /* Mobile: kein Hover auf Buttons */
      .btn-primary:hover { transform: none; box-shadow: none; }
      .btn-dark:hover { transform: none; box-shadow: none; }
      .btn-outline-dark:hover { transform: none; box-shadow: none; }
      .footer-stoerung:hover { background: transparent; color: var(--red) !important; border-color: rgba(217, 48, 37, 0.3); }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .nav { display: none; }
      .nav.open { display: flex; flex-direction: column; align-items: center; justify-content: center; position: fixed; top: 0; left: 0; right: 0; bottom: 0; padding-top: calc(var(--header-height) + env(safe-area-inset-top, 0px) - clamp(48px, 7.5svh, 64px)); padding-left: 24px; padding-right: 24px; padding-bottom: calc(env(safe-area-inset-bottom, 16px) + 16px); gap: clamp(20px, 3.5svh, 32px); background: #FFFFFF; z-index: 999; overflow: hidden; text-align: center; }
      body.menu-open { overflow: hidden; }
      body.menu-open .header { background: #FFFFFF; }
      .nav.open > a { font-size: clamp(18px, 2.5svh, 22px); }
      .nav.open > a::after { display: none; }
      .mobile-menu-link { display: block !important; }
      .nav.open .btn-primary { display: flex; justify-content: center; background: var(--navy); color: var(--white) !important; font-family: var(--font-heading); font-weight: 600; font-size: clamp(15px, 2svh, 17px); padding: clamp(12px, 1.8svh, 16px) 24px; border-radius: 3px; white-space: nowrap; width: 100%; max-width: 240px; }
      .nav.open .btn-primary::after { display: none; }
      .nav.open .btn-stoerung { display: flex; justify-content: center; background: var(--red); color: var(--white) !important; font-family: var(--font-heading); font-weight: 600; font-size: clamp(15px, 2svh, 17px); padding: clamp(12px, 1.8svh, 16px) 24px; border-radius: 3px; border: none; white-space: nowrap; position: absolute; bottom: clamp(20px, 4svh, 36px); left: 50%; transform: translateX(-50%); width: calc(100% - 48px); max-width: 220px; }
      .nav.open .btn-stoerung::after { display: none; }
      .menu-toggle { display: flex; }
      /* Mobile: kein Dropdown, flache Liste — Unterpunkte ausblenden, "Leistungen" ersetzt sie */
      .nav-dropdown { display: none; }
      .nav-dropdown-trigger { display: none !important; }
      .nav-dropdown-menu { display: none; }
      .nav-dropdown-menu a:first-child { border: none; border-radius: 0; }
      .nav-dropdown-menu a:last-child { border-radius: 0; }
      .nav-dropdown-menu a:hover { background: none; }
      .hero-content { }
      .why-hero-img { height: 280px; }

      /* === MOBILE: Image Fade Edges (subtil) === */
      .hero-bg {
        -webkit-mask-image: linear-gradient(to bottom, black 99%, transparent 100%);
        mask-image: linear-gradient(to bottom, black 99%, transparent 100%);
      }
      .why-hero-img {
        -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 2%, black 98%, transparent 100%);
        mask-image: linear-gradient(to bottom, transparent 0%, black 2%, black 98%, transparent 100%);
      }
      .klima-header-img {
        -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 2%, black 98%, transparent 100%);
        mask-image: linear-gradient(to bottom, transparent 0%, black 2%, black 98%, transparent 100%);
      }

      /* === MOBILE: Heatpump & Klima Bilder als Vollbreit-Streifen === */
      .why-hero-img {
        border-radius: 0;
        margin-left: -24px;
        margin-right: -24px;
        width: calc(100% + 48px);
        height: 260px;
      }
      .klima-header-img {
        border-radius: 0;
        margin-left: -24px;
        margin-right: -24px;
        width: calc(100% + 48px);
        height: 260px;
      }

      /* === MOBILE: Parallax Image Setup === */
      .why-hero-img img,
      .klima-header-img img,
      .service-card-img img {
        height: 130% !important;
        will-change: transform;
        transform: translateY(-11.5%);
      }

      /* === MOBILE: Soft Section Transitions (Reihenfolge B) === */
      /* Hero→Services(off-white)→Logos(white)→Wpsm(white)→Steps(off-white)→About(white)→Why(off-white)→Klima(white)→Calc(white)→Region(navy)→Contact(white)→Footer */
      .services { background: linear-gradient(to bottom, var(--navy) 0%, var(--off-white) 3px, var(--off-white) 100%); }
      .wpsm { background: linear-gradient(to bottom, var(--white) 0%, var(--white) 100%); }
      .steps { background: linear-gradient(to bottom, var(--white) 0%, var(--off-white) 4px, var(--off-white) 100%); }
      .about { background: linear-gradient(to bottom, var(--off-white) 0%, var(--white) 4px, var(--white) 100%); }
      .why { background: linear-gradient(to bottom, var(--white) 0%, var(--off-white) 4px, var(--off-white) 100%); }
      .klima { background: linear-gradient(to bottom, var(--off-white) 0%, var(--white) 4px, var(--white) 100%); }
      .region { background: linear-gradient(to bottom, var(--white) 0%, var(--navy) 4px, var(--navy) 100%); }
      .contact { background: linear-gradient(to bottom, var(--navy) 0%, var(--white) 4px, var(--white) 100%); }
      .footer { background: linear-gradient(to bottom, var(--white) 0%, var(--navy-dark) 4px, var(--navy-dark) 100%); }
    }
    @media (max-width: 640px) {
      :root { --header-height: 68px; }
      .section-padding { padding: clamp(44px, 8svh, 64px) 0; }
      .steps-grid, .why-grid, .klima-types-grid, .about-usp-grid { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; }
      .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
      .hero { min-height: 100svh; }
      .hero-inner { min-height: calc(100svh - var(--header-height)); padding-top: clamp(28px, 6svh, 52px); padding-bottom: clamp(20px, 4svh, 40px); align-items: flex-start; }
      .hero h1 { font-size: clamp(26px, 4.5svh, 34px); margin-top: clamp(-20px, -3svh, -10px); }
      .hero-subtitle { font-size: clamp(20px, 3.5svh, 26px); padding-top: clamp(4px, 1svh, 10px); margin-bottom: clamp(12px, 2.5svh, 22px); }
      .hero-text { font-size: clamp(14px, 2.2svh, 17px); margin-top: clamp(16px, 4svh, 36px); margin-bottom: clamp(40px, 12svh, 110px); line-height: 1.6; max-width: 88%; }
      .hero-bg { top: 35%; bottom: 0; left: 0; right: 0; height: auto; }
      .hero-bg img { object-position: 80% top; opacity: 0.7; }
      .hero-bg::after { background: linear-gradient(180deg, var(--navy) 0%, rgba(27, 42, 74, 0.5) 25%, rgba(27, 42, 74, 0.35) 100%); }
      .hero-content { max-width: 100%; }
      .hero-buttons { flex-direction: column; align-items: flex-start; }
      .hero-note { font-size: clamp(11px, 1.8svh, 14px); }
      .wpsm-badge { padding: 32px; }
      .wpsm-badge-number { font-size: 56px; }
      .klima-header-img { height: 200px; }
      .calc-saving { font-size: 36px; }
      .calc-toggle-group { flex-direction: column; }
    }
  </style>

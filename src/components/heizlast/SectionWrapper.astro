---
// Standard-Sektionsrahmen fuer den Heizlast-Rechner.
// Struktur: Label (rot caps) -> Ueberschrift -> optionale Subline -> Inhalt (Slot).
// Abwechselnder Hintergrund wird per `tone="white"|"off"` gesteuert.
// Optionaler <slot name="aside" /> fuer kleine Live-Werte rechts oben.

interface Props {
  /** Sektions-Nummer / Kicker-Text (z.B. "01", "Sektion 1", "Ueberblick") */
  kicker?: string;
  /** Hauptueberschrift */
  title: string;
  /** Optionale erklaerende Unterzeile */
  subline?: string;
  /** Hintergrundton */
  tone?: 'white' | 'off';
  /** HTML-Id fuer Anchor-Links */
  id?: string;
  /** Erste Sektion? Bekommt mehr Abstand oben. */
  first?: boolean;
}

const {
  kicker,
  title,
  subline,
  tone = 'white',
  id,
  first = false,
} = Astro.props;
---
<section
  id={id}
  class={`hz-section${tone === 'off' ? ' hz-section--off' : ''}${first ? ' hz-section--first' : ''}`}
>
  <div class="hz-container">
    <header class="hz-section__head">
      <div class="hz-section__heading">
        <h2 class="hz-section__title">{title}</h2>
        {subline ? <p class="hz-section__subline">{subline}</p> : null}
      </div>
      {Astro.slots.has('aside') ? (
        <aside class="hz-section__aside">
          <slot name="aside" />
        </aside>
      ) : null}
    </header>

    <div class="hz-section__body">
      <slot />
    </div>
  </div>
</section>

<style is:global>
  /* Phase 10 / Paket D5 — Hintergrundfarbe wandert vom Section-Element
     auf den inneren .hz-container. Dadurch ist die Sektion selbst
     transparent (zeigt Body-Grau), und der weiße "Content-Korridor"
     steht als schmalere Fläche sichtbar links und rechts eingefasst. */
  .hz-section {
    padding: var(--hz-gap-section, clamp(56px, 7vw, 96px)) 0;
    background: transparent;
  }
  .hz-section > .hz-container {
    background: var(--hz-white);
    border-radius: var(--hz-radius-lg);
    padding-top: clamp(36px, 5vw, 56px);
    padding-bottom: clamp(36px, 5vw, 56px);
    box-shadow: var(--hz-shadow-sm);
  }
  .hz-section--first {
    padding-top: clamp(24px, 4svh, 48px);
  }
  .hz-section--off > .hz-container { background: var(--hz-off-white); }

  .hz-section__head {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 32px;
    margin-bottom: clamp(28px, 4.5svh, 44px);
    padding-bottom: clamp(12px, 2svh, 18px);
    border-bottom: 1px solid var(--hz-border);
  }
  .hz-section__heading { max-width: 760px; }
  .hz-section__title {
    margin-top: 10px;
  }
  .hz-section__subline {
    margin-top: 12px;
    font-family: var(--hz-font-body);
    font-weight: 400;
    font-size: clamp(16px, 1.6vw, 18px);
    color: var(--hz-mid-gray);
    line-height: 1.6;
    max-width: 640px;
  }
  .hz-section__aside {
    flex-shrink: 0;
  }
  .hz-section__body { }

  @media (max-width: 720px) {
    .hz-section__head {
      flex-direction: column;
      gap: 20px;
      padding-bottom: 14px;
    }
    .hz-section__aside { width: 100%; }
  }
</style>

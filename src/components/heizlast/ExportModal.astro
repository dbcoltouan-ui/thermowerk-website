---
// ExportModal — einheitlicher Export-Dialog (PDF oder JSON).
// - Checkboxen fuer Inhalte der Ausgabe (werden als body-Klassen gespiegelt,
//   damit das Print-CSS die richtigen Sektionen zeigt/ausblendet).
// - Format: PDF (window.print via Print-CSS) oder JSON (Blob-Download).
// - Dateiname vorbelegt aus Projektdaten.
---
<div
  class="hz-modal"
  id="hz-export-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="hz-export-modal-title"
  hidden
>
  <div class="hz-modal__backdrop" data-hz-modal-dismiss></div>
  <div class="hz-modal__card">
    <header class="hz-modal__head">
      <div>
        <p class="hz-kicker">Export</p>
        <h2 class="hz-modal__title" id="hz-export-modal-title">Berechnung exportieren</h2>
      </div>
      <button
        type="button"
        class="hz-modal__close"
        data-hz-modal-dismiss
        aria-label="Schliessen"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </header>

    <section class="hz-modal__body">
      <form class="hz-modal__form" id="hz-export-form" autocomplete="off">
        <!-- Dateiname -->
        <label class="hz-field">
          <span class="hz-field__label">Dateiname</span>
          <input
            type="text"
            id="hz-export-filename"
            class="hz-field__input"
            placeholder="Thermowerk-Heizlast"
          />
        </label>

        <!-- Inhalt -->
        <fieldset class="hz-export__group">
          <legend class="hz-export__legend">Inhalt</legend>
          <div class="hz-export__checks">
            <label class="hz-check">
              <input type="checkbox" data-export-part="cover" checked />
              <span>Executive Summary (Deckblatt)</span>
            </label>
            <label class="hz-check">
              <input type="checkbox" data-export-part="objekt" checked />
              <span>Objektdaten &amp; Eingabewerte</span>
            </label>
            <label class="hz-check">
              <input type="checkbox" data-export-part="resultate" checked />
              <span>Resultate pro Sektion</span>
            </label>
            <label class="hz-check">
              <input type="checkbox" data-export-part="diagramm" checked />
              <span>Leistungsdiagramm</span>
            </label>
            <label class="hz-check">
              <input type="checkbox" data-export-part="formeln" />
              <span>Formeln &amp; Rechenwege</span>
            </label>
            <label class="hz-check">
              <input type="checkbox" data-export-part="grundlagen" checked />
              <span>Berechnungsgrundlagen (FWS&nbsp;/&nbsp;SIA)</span>
            </label>
            <label class="hz-check">
              <input type="checkbox" data-export-part="notizen" checked />
              <span>Notizen (nur mit Export-Flag)</span>
            </label>
          </div>
        </fieldset>

        <!-- Format -->
        <fieldset class="hz-export__group">
          <legend class="hz-export__legend">Format</legend>
          <div class="hz-export__radios">
            <label class="hz-radio">
              <input type="radio" name="hz-export-format" value="pdf" checked />
              <span>PDF &middot; <small class="hz-muted">oeffnet Druckdialog</small></span>
            </label>
            <label class="hz-radio">
              <input type="radio" name="hz-export-format" value="json" />
              <span>JSON &middot; <small class="hz-muted">zum Sichern/Teilen</small></span>
            </label>
          </div>
        </fieldset>

        <div class="hz-modal__error" id="hz-export-error" hidden aria-live="polite"></div>

        <div class="hz-modal__actions">
          <button type="button" class="hz-btn hz-btn-ghost" data-hz-modal-dismiss>Abbrechen</button>
          <button type="submit" class="hz-btn hz-btn-primary" id="hz-export-submit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Exportieren
          </button>
        </div>
      </form>
    </section>
  </div>
</div>

<style is:global>
  .hz-export__group {
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-md);
    padding: 12px 14px 14px;
    margin: 0;
  }
  .hz-export__legend {
    padding: 0 6px;
    font-family: var(--hz-font-heading);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--hz-navy);
  }
  .hz-export__checks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 14px;
    margin-top: 6px;
  }
  @media (max-width: 560px) {
    .hz-export__checks { grid-template-columns: 1fr; }
  }
  .hz-export__radios {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 6px;
  }

  .hz-check, .hz-radio {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    cursor: pointer;
    font-size: 14px;
    line-height: 1.35;
    user-select: none;
  }
  .hz-check input, .hz-radio input {
    margin: 3px 0 0 0;
    width: 16px; height: 16px;
    accent-color: var(--hz-navy);
    flex-shrink: 0;
  }
  .hz-check span, .hz-radio span { color: var(--hz-dark); }
  .hz-check:hover span, .hz-radio:hover span { color: var(--hz-navy); }
</style>

---
// OverrideField — Phase 9 / Block A neu:
// - Feld ist IMMER editierbar und zeigt den aktuellen Wert (User oder Default).
// - data-hz-override="<pfad>" signalisiert den Binding-Pfad im overrides-Record.
// - data-hz-bind="<pfad>" bindet den tatsaechlichen Wert an den State.
// - Reset-Pfeil rechts wird nur bei .is-overridden angezeigt (vom Binding-
//   Layer an den Wrapper gesetzt).
// - Klick auf Reset loescht den Override und schreibt den Default-Wert zurueck
//   ins Feld; der State-Binding-Layer picks den Default dann beim naechsten
//   resolveDefault() auf.

interface Props {
  /** Label ueber dem Feld — Begriff, z.B. "Sperrzeit" */
  label: string;
  /** Symbol + Einheit unter dem Label, z.B. "Qoff · h/d" (Phase 9 / Block G) */
  symbol?: string;
  /** HTML-Id des Inputs (wird auch fuers for=-Label genutzt) */
  id: string;
  /** Pfad im State, den dieses Feld schreibt (z.B. "zuschlaege.toff") */
  bindPath: string;
  /** Pfad im overrides-Record (meist == bindPath, ausser bei Verlusten) */
  overridePath?: string;
  /** Default-Wert (fuer Reset-Fallback, wenn resolveDefault nichts liefert) */
  defaultValue: string | number;
  /** Einheit (z.B. "h", "L", "K") — optional, wenn symbol gesetzt darf leer bleiben */
  unit?: string;
  /** Kurzer erklaerender Hinweis unter dem Feld */
  hint?: string;
  /** Typ des Inputs */
  type?: 'number' | 'text';
  /** Optionaler min / max / step fuer number-Inputs */
  min?: number;
  max?: number;
  step?: number;
  /** Default-Quelle fuer Tooltip ("FWS", "SIA 385/1", ...) */
  source?: string;
}

const {
  label,
  symbol,
  id,
  bindPath,
  overridePath,
  defaultValue,
  unit,
  hint,
  type = 'number',
  min,
  max,
  step,
  source,
} = Astro.props;

const ovrPath = overridePath ?? bindPath;
const bindType = type === 'number' ? 'number' : 'string';
const defaultString = String(defaultValue);
---
<div class="hz-ovr" data-field data-hz-override-field={ovrPath} data-default={defaultString}>
  <div class="hz-ovr__head">
    <label for={id} class="hz-ovr__label">{label}</label>
    {source ? <span class="hz-ovr__source">Standard: {source}</span> : null}
  </div>
  {/* Paket D2 / B — Symbol-Zeile entfernt, Standard-Quelle in .hz-ovr__head */}

  <div class="hz-ovr__control">
    <input
      id={id}
      name={id}
      class="hz-ovr__input"
      type={type}
      value={defaultString}
      min={min}
      max={max}
      step={step}
      data-hz-bind={bindPath}
      data-hz-type={bindType}
      aria-describedby={hint ? `${id}-hint` : undefined}
    />
    {unit ? <span class="hz-ovr__unit">{unit}</span> : null}
    <button
      type="button"
      class="hz-ovr__btn"
      aria-label={`${label} auf Standardwert zuruecksetzen`}
      data-action="reset-override"
    >
      <span class="hz-ovr__icon hz-ovr__icon--reset" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="1 4 1 10 7 10"></polyline>
          <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
        </svg>
      </span>
    </button>
  </div>

  {hint ? <p id={`${id}-hint`} class="hz-ovr__hint">{hint}</p> : null}
</div>

<style is:global>
  .hz-ovr { display: flex; flex-direction: column; gap: 6px; }

  .hz-ovr__head {
    display: flex; align-items: baseline; justify-content: space-between; gap: 12px;
  }
  .hz-ovr__label {
    font-family: var(--hz-font-heading);
    font-weight: 600;
    font-size: 14px;
    color: var(--hz-navy);
  }
  .hz-ovr__source {
    font-size: 12px;
    color: var(--hz-mid-gray);
    letter-spacing: 0.02em;
  }
  .hz-ovr__symbol {
    font-family: var(--hz-font-body);
    font-size: 12px;
    color: var(--hz-mid-gray);
    margin-top: -2px;
    margin-bottom: 2px;
    letter-spacing: 0.01em;
  }

  .hz-ovr__control {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: stretch;
    min-height: 40px;
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-sm);
    background: var(--hz-white);
    transition: border-color var(--hz-transition), box-shadow var(--hz-transition);
    max-width: var(--hz-input-max-number, 240px);
  }
  .hz-ovr__control:focus-within {
    border-color: var(--hz-navy);
    box-shadow: 0 0 0 3px rgba(27, 42, 74, 0.08);
  }

  .hz-ovr__input {
    border: 0;
    outline: 0;
    padding: 10px 14px;
    background: transparent;
    font-family: var(--hz-font-body);
    font-size: 15.5px;
    color: var(--hz-mid-gray);
    min-width: 0;
    width: 100%;
  }
  /* Default-Zustand (kein Override): Wert dezenter dargestellt */
  .hz-ovr__input { color: var(--hz-mid-gray); }
  /* Ueberschrieben: voller Text-Kontrast */
  .hz-ovr.is-overridden .hz-ovr__input { color: var(--hz-dark); font-weight: 600; }

  .hz-ovr__unit {
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    font-family: var(--hz-font-heading);
    font-size: 13px;
    color: var(--hz-mid-gray);
    border-left: 1px solid var(--hz-border);
  }

  /* Reset-Button: im Default-Zustand unsichtbar, aber Platzhalter bleibt
     damit Layout nicht wackelt — per visibility, nicht display. */
  .hz-ovr__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    border: 0;
    border-left: 1px solid var(--hz-border);
    background: var(--hz-off-white);
    color: var(--hz-red);
    visibility: hidden;
    transition: background var(--hz-transition);
  }
  .hz-ovr.is-overridden .hz-ovr__btn { visibility: visible; }
  .hz-ovr__btn:hover { background: var(--hz-red-soft); }
  .hz-ovr__btn:focus-visible { outline: 2px solid var(--hz-navy); outline-offset: -2px; }

  .hz-ovr__hint { font-size: 12.5px; color: var(--hz-mid-gray); line-height: 1.4; }

  @media (max-width: 480px) {
    .hz-ovr__btn { width: 44px; }
  }
</style>

<script is:inline>
  // Delegiertes Verhalten: einmal pro Seite verdrahtet.
  // Erwartet, dass bindings.ts per Store-Subscriber das .is-overridden
  // zeitnah aktualisiert. Dieses Script loescht nur den Override + schreibt
  // den Default-Wert ins Feld + feuert input-Event, damit der State-Layer
  // mitbekommt, dass das Feld auf Default zurueckgesetzt wurde.
  (function () {
    if (window.__hzOvrBound) return;
    window.__hzOvrBound = true;
    document.addEventListener('click', function (ev) {
      const btn = ev.target instanceof Element ? ev.target.closest('[data-action="reset-override"]') : null;
      if (!btn) return;
      const wrapper = btn.closest('[data-hz-override-field]');
      if (!wrapper) return;
      const path = wrapper.getAttribute('data-hz-override-field');
      const input = wrapper.querySelector('.hz-ovr__input');
      if (!input || !path) return;
      // Globalen Hook benutzen (wird in heizlast.astro installiert):
      if (typeof window.__hzClearOverride === 'function') {
        window.__hzClearOverride(path);
      }
      // Default-Wert aus State zurueckholen:
      const def = typeof window.__hzResolveDefault === 'function'
        ? window.__hzResolveDefault(path)
        : wrapper.getAttribute('data-default');
      if (def != null) input.value = String(def);
      input.dispatchEvent(new Event('input', { bubbles: true }));
      input.dispatchEvent(new Event('change', { bubbles: true }));
      input.focus();
    });
  })();
</script>

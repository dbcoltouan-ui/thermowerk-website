---
// OverrideField — Input mit "Ueberschreiben"-Icon (Variante A).
// Verhalten:
//   - Default sichtbar (gegraut), Feld readonly.
//   - Klick auf Stift-Icon -> aria-pressed toggle, Feld editierbar, Icon wird zu Reset-Pfeil.
//   - Reset-Pfeil setzt Wert auf data-default zurueck.
//   - Status wird per CSS-Klasse .is-overridden am Wrapper abgebildet.
//   - Clientseitig via kleines inline JS (einmal pro Seite bootstrappt delegiert).

interface Props {
  /** Label ueber dem Feld */
  label: string;
  /** HTML-Id des Inputs (wird auch fuers for=-Label genutzt) */
  id: string;
  /** Default-Wert (aus Konstanten/FWS) */
  defaultValue: string | number;
  /** Einheit (z.B. "h", "L", "K") */
  unit?: string;
  /** Kurzer erklaerender Hinweis unter dem Feld */
  hint?: string;
  /** Typ des Inputs */
  type?: 'number' | 'text';
  /** Optionaler min / max / step fuer number-Inputs */
  min?: number;
  max?: number;
  step?: number;
  /** Default-Quelle fuer Reset-Tooltip ("FWS", "SIA 385/1", ...) */
  source?: string;
}

const {
  label,
  id,
  defaultValue,
  unit,
  hint,
  type = 'number',
  min,
  max,
  step,
  source,
} = Astro.props;

const defaultString = String(defaultValue);
---
<div class="hz-ovr" data-field data-default={defaultString}>
  <div class="hz-ovr__head">
    <label for={id} class="hz-ovr__label">{label}</label>
    {source ? <span class="hz-ovr__source">Standard: {source}</span> : null}
  </div>

  <div class="hz-ovr__control">
    <input
      id={id}
      name={id}
      class="hz-ovr__input"
      type={type}
      value={defaultString}
      readonly
      min={min}
      max={max}
      step={step}
      aria-describedby={hint ? `${id}-hint` : undefined}
    />
    {unit ? <span class="hz-ovr__unit">{unit}</span> : null}
    <button
      type="button"
      class="hz-ovr__btn"
      aria-pressed="false"
      aria-label={`${label} manuell ueberschreiben`}
      data-action="toggle"
    >
      <span class="hz-ovr__icon hz-ovr__icon--edit" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
          <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
        </svg>
      </span>
      <span class="hz-ovr__icon hz-ovr__icon--reset" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="1 4 1 10 7 10"></polyline>
          <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
        </svg>
      </span>
    </button>
  </div>

  {hint ? <p id={`${id}-hint`} class="hz-ovr__hint">{hint}</p> : null}
</div>

<style is:global>
  .hz-ovr { display: flex; flex-direction: column; gap: 6px; }

  .hz-ovr__head {
    display: flex; align-items: baseline; justify-content: space-between; gap: 12px;
  }
  .hz-ovr__label {
    font-family: var(--hz-font-heading);
    font-weight: 600;
    font-size: 14px;
    color: var(--hz-navy);
  }
  .hz-ovr__source {
    font-size: 12px;
    color: var(--hz-mid-gray);
    letter-spacing: 0.02em;
  }

  .hz-ovr__control {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: stretch;
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-sm);
    background: var(--hz-white);
    transition: border-color var(--hz-transition), box-shadow var(--hz-transition);
  }
  .hz-ovr__control:focus-within {
    border-color: var(--hz-navy);
    box-shadow: 0 0 0 3px rgba(27, 42, 74, 0.08);
  }

  .hz-ovr__input {
    border: 0;
    outline: 0;
    padding: 10px 14px;
    background: transparent;
    font-family: var(--hz-font-body);
    font-size: 15.5px;
    color: var(--hz-mid-gray);
    min-width: 0;
    width: 100%;
  }
  .hz-ovr__input[readonly] { color: var(--hz-mid-gray); cursor: not-allowed; }
  .hz-ovr.is-overridden .hz-ovr__input { color: var(--hz-dark); font-weight: 600; cursor: text; }

  .hz-ovr__unit {
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    font-family: var(--hz-font-heading);
    font-size: 13px;
    color: var(--hz-mid-gray);
    border-left: 1px solid var(--hz-border);
  }

  .hz-ovr__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    border: 0;
    border-left: 1px solid var(--hz-border);
    background: var(--hz-off-white);
    color: var(--hz-mid-gray);
    transition: color var(--hz-transition), background var(--hz-transition);
  }
  .hz-ovr__btn:hover { color: var(--hz-navy); background: var(--hz-light-gray); }
  .hz-ovr__btn:focus-visible { outline: 2px solid var(--hz-navy); outline-offset: -2px; }

  .hz-ovr__icon--reset { display: none; }
  .hz-ovr.is-overridden .hz-ovr__icon--edit { display: none; }
  .hz-ovr.is-overridden .hz-ovr__icon--reset { display: inline-flex; }
  .hz-ovr.is-overridden .hz-ovr__btn { color: var(--hz-red); background: var(--hz-red-soft); }

  .hz-ovr__hint { font-size: 12.5px; color: var(--hz-mid-gray); line-height: 1.4; }

  @media (max-width: 480px) {
    .hz-ovr__btn { width: 44px; }
  }
</style>

<script is:inline>
  // Delegiertes Verhalten: einmal pro Seite verdrahtet.
  (function () {
    if (window.__hzOvrBound) return;
    window.__hzOvrBound = true;
    document.addEventListener('click', function (ev) {
      const btn = ev.target instanceof Element ? ev.target.closest('[data-action="toggle"]') : null;
      if (!btn) return;
      const wrapper = btn.closest('[data-field]');
      if (!wrapper) return;
      const input = wrapper.querySelector('.hz-ovr__input');
      if (!input) return;

      const isOverridden = wrapper.classList.toggle('is-overridden');
      if (isOverridden) {
        input.removeAttribute('readonly');
        btn.setAttribute('aria-pressed', 'true');
        input.focus();
        try { input.select(); } catch (_) {}
      } else {
        const def = wrapper.getAttribute('data-default') ?? '';
        input.value = def;
        input.setAttribute('readonly', '');
        btn.setAttribute('aria-pressed', 'false');
        input.dispatchEvent(new Event('input', { bubbles: true }));
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  })();
</script>

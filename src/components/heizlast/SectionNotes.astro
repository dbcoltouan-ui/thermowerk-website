---
// SectionNotes — aufklappbarer Notiz-Toggle pro Sektion oder fuer das Projekt.
// - Dezent als Ghost-Toggle mit Notizblock-Icon.
// - Beim Aufklappen: Textarea (Freitext).
// - Ab Phase 9 / Block L: keine "Beim Export einbeziehen"-Checkbox mehr
//   (zentral im Export-Modal). Stattdessen kleines Navy-Info-Icon rechts
//   neben dem Label, sichtbar nur wenn die Notiz gefuellt ist.

interface Props {
  /** Schluessel in state.notizen (z. B. "sektion1", "sektion2", "projekt") */
  sectionKey:
    | 'sektion1'
    | 'sektion2'
    | 'sektion3'
    | 'sektion4'
    | 'sektion5'
    | 'sektion6'
    | 'projekt';
  /** Sichtbares Sektions-Kuerzel fuer den Button-Text */
  sectionLabel?: string;
}

const { sectionKey, sectionLabel } = Astro.props;
const label =
  sectionKey === 'projekt'
    ? 'Projekt-Notiz'
    : sectionLabel
      ? `Notizen zu ${sectionLabel}`
      : 'Notizen zu dieser Sektion';
const contentId = `hz-notes-${sectionKey}`;
const textareaId = `hz-notes-${sectionKey}-text`;
---
<div class="hz-notes" data-toggle data-hz-note-slot={sectionKey}>
  <button
    type="button"
    class="hz-notes__btn"
    aria-expanded="false"
    aria-controls={contentId}
    data-action="toggle-module"
  >
    <span class="hz-notes__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="9" y1="13" x2="15" y2="13"></line>
        <line x1="9" y1="17" x2="13" y2="17"></line>
      </svg>
    </span>
    <span class="hz-notes__label">{label}</span>
    <span class="hz-notes__indicator" data-hz-notes-indicator hidden aria-hidden="true" title="Notiz ausgefuellt">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="13"></line>
        <line x1="12" y1="16.5" x2="12.01" y2="16.5"></line>
      </svg>
    </span>
  </button>

  <div id={contentId} class="hz-notes__content" aria-hidden="true" hidden>
    <label class="hz-notes__field-label" for={textareaId}>Freitext</label>
    <textarea
      id={textareaId}
      class="hz-notes__textarea"
      rows="3"
      placeholder="Bemerkungen, Sonderfaelle, Abweichungen von den Defaults …"
      data-hz-bind={`notizen.${sectionKey}.text`}
      data-hz-type="string"
    ></textarea>
  </div>
</div>

<style is:global>
  .hz-notes {
    margin-top: 22px;
    padding-top: 14px;
    border-top: 1px dashed var(--hz-border);
  }
  .hz-notes__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 8px 4px 4px;
    border: 0;
    background: transparent;
    color: var(--hz-mid-gray);
    font-family: var(--hz-font-heading);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.02em;
    transition: color var(--hz-transition);
  }
  .hz-notes__btn:hover { color: var(--hz-navy); }
  .hz-notes__btn:focus-visible { outline: 2px solid var(--hz-navy); outline-offset: 2px; }
  .hz-notes__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: var(--hz-off-white);
    border: 1px solid var(--hz-border);
    color: var(--hz-mid-gray);
  }
  .hz-notes.is-open .hz-notes__icon {
    background: var(--hz-navy);
    border-color: var(--hz-navy);
    color: var(--hz-white);
  }
  /* Paket D2 / F: roter Exclamation-Circle-Indikator, sichtbar
     nur wenn der Text nicht leer ist. */
  .hz-notes__indicator {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: var(--hz-red);
  }
  .hz-notes__indicator[hidden] { display: none; }
  .hz-notes__content {
    margin-top: 12px;
    padding: 14px 16px;
    background: var(--hz-off-white);
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-md);
  }
  .hz-notes__field-label {
    display: block;
    font-family: var(--hz-font-heading);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--hz-mid-gray);
    margin-bottom: 6px;
  }
  .hz-notes__textarea {
    width: 100%;
    min-height: 72px;
    resize: vertical;
    padding: 10px 12px;
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-sm);
    background: var(--hz-white);
    font-family: var(--hz-font-body);
    font-size: 14.5px;
    color: var(--hz-dark);
  }
  .hz-notes__textarea:focus {
    outline: 0;
    border-color: var(--hz-navy);
    box-shadow: 0 0 0 3px rgba(27, 42, 74, 0.08);
  }
</style>

<script is:inline>
  (function () {
    if (window.__hzNotesIndicatorBound) return;
    window.__hzNotesIndicatorBound = true;
    function refresh() {
      document.querySelectorAll('.hz-notes').forEach(function (wrap) {
        var ta = wrap.querySelector('textarea.hz-notes__textarea');
        var indicator = wrap.querySelector('[data-hz-notes-indicator]');
        if (!ta || !indicator) return;
        var has = ta.value && ta.value.trim().length > 0;
        indicator.hidden = !has;
      });
    }
    document.addEventListener('input', function (ev) {
      var t = ev.target;
      if (t && t.classList && t.classList.contains('hz-notes__textarea')) refresh();
    });
    // Nach dem Rehydrieren aus localStorage (Store-Broadcast) ebenfalls refreshen:
    setTimeout(refresh, 100);
    setTimeout(refresh, 800);
  })();

  // Paket D2 / F — dedizierter Notizen-Toggle-Handler (Defense-in-Depth).
  // Der generische Toggle.astro-Handler greift per data-action="toggle-module",
  // aber Notizen sollen auch öffnen, falls der gemeinsame Handler durch andere
  // Listener gestört wird. Guard über eigenes Flag verhindert Doppel-Registrierung.
  (function () {
    if (window.__hzNotesToggleBound) return;
    window.__hzNotesToggleBound = true;
    document.addEventListener('click', function (ev) {
      var el = ev.target instanceof Element ? ev.target.closest('.hz-notes__btn') : null;
      if (!el) return;
      var wrap = el.closest('.hz-notes');
      if (!wrap) return;
      var contentId = el.getAttribute('aria-controls');
      var content = contentId ? document.getElementById(contentId) : wrap.querySelector('.hz-notes__content');
      if (!content) return;
      // Den Ziel-Zustand aus dem aktuellen DOM-Status ableiten.
      var isOpen = wrap.classList.contains('is-open');
      // Nur umschalten, wenn der generische Handler nicht bereits den Zielzustand gesetzt hat.
      // Wir erzwingen Synchronisation: Content.hidden entspricht !isOpen.
      var shouldBeHidden = isOpen ? false : true; // nach dem Click war Handler evtl. schneller
      // Wenn bereits synchron, nichts zu tun. Falls nicht, erzwingen.
      if (content.hasAttribute('hidden') === shouldBeHidden) return;
      // Fallback: erneut togglen, damit der End-Zustand konsistent ist.
      if (isOpen) {
        content.removeAttribute('hidden');
        content.setAttribute('aria-hidden', 'false');
        el.setAttribute('aria-expanded', 'true');
      } else {
        content.setAttribute('hidden', '');
        content.setAttribute('aria-hidden', 'true');
        el.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>

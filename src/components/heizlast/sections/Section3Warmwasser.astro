---
// Section 3 — Warmwasser (M5)
// Paket C / Block B: Content kollabiert wenn Main-Switch OFF.
// F: Kein Kicker, keine Aside-KPIs.
// A: deltaT hat sichtbaren Default (50 K = 60 - 10).

import SectionWrapper from '../SectionWrapper.astro';
import SectionNotes from '../SectionNotes.astro';
import OverrideField from '../OverrideField.astro';
import { WW_STANDARDS, WW_VERLUSTE_DEFAULTS, PHYSIK } from '../../../lib/heizlast/constants.ts';
---
<SectionWrapper
  id="sektion-3"
  title="Warmwasser"
  subline="Zusatzleistung für Trinkwarmwasser nach SIA 385/1 und FWS §8."
>
  <!-- Haupt-Toggle -->
  <label class="hz-switch hz-ww-main" style="margin-bottom: 10px;">
    <input type="checkbox" data-hz-bind="warmwasser.active" data-hz-type="boolean" />
    <span>Aufbereitung mit einbeziehen</span>
  </label>

  <!-- Inhalt: nur sichtbar wenn WW aktiv (body.hz-ww-off steuert via CSS) -->
  <div class="hz-ww-content">
    <div class="hz-block">
      <h3 class="hz-block__heading">Methode</h3>
      <div class="hz-ww-methods">
        <label class="hz-ww-method">
          <input type="radio" name="ww-method" value="personen" data-hz-bind="warmwasser.method" data-hz-type="string" />
          <span>Pro Personeneinheit</span>
          <small>SIA 385/1 / 385/2 Richtwerte</small>
        </label>
        <label class="hz-ww-method">
          <input type="radio" name="ww-method" value="direkt" data-hz-bind="warmwasser.method" data-hz-type="string" />
          <span>Direkt l/d eingeben</span>
          <small>wenn Gesamt-Vw,u bekannt</small>
        </label>
        <label class="hz-ww-method">
          <input type="radio" name="ww-method" value="messung" data-hz-bind="warmwasser.method" data-hz-type="string" />
          <span>Messwert kWh/Tag</span>
          <small>direkt gemessener Qww</small>
        </label>
      </div>
    </div>

    <!-- Personen-Einheiten -->
    <div class="hz-ww-pane" data-ww-pane="personen">
      <h4 class="hz-ww-pane__title">Personen-Einheiten</h4>
      <p class="hz-muted" style="margin-bottom: 10px;">
        Pro Wohneinheit: ANF (anrechenbare Netto-Fläche) und Vw,u (Liter pro Person und Tag).
        Richtwerte für EFH: 40&ndash;55&nbsp;l/P/d.
      </p>
      <div class="hz-pe-header">
        <span>Bezeichnung</span>
        <span>ANF</span>
        <span>Vw,u</span>
        <span></span>
      </div>
      <div id="hz-pe-list" class="hz-pe-list" aria-live="polite">
        <p class="hz-muted hz-pe-empty">Noch keine Einheit erfasst.</p>
      </div>
      <div class="hz-pe-actions">
        <button type="button" class="hz-btn hz-btn-ghost" id="hz-pe-add">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Einheit hinzufügen
        </button>
        <span class="hz-muted" style="font-size: 13px;">
          Richtwerte: {WW_STANDARDS.slice(0, 3).map((w) => `${w.vwu} l/P/d ${w.label.includes('gehoben') ? '(gehoben)' : w.label.includes('mittel') ? '(mittel)' : '(einfach)'}`).join(' · ')}
        </span>
      </div>
    </div>

    <!-- Direkt -->
    <div class="hz-ww-pane" data-ww-pane="direkt">
      <h4 class="hz-ww-pane__title">Direkt-Eingabe</h4>
      <div class="hz-grid-3">
        <label class="hz-field">
          <span class="hz-field__label">Gesamt Vw,u</span>
          <div class="hz-field__input-with-unit">
            <input class="hz-field__input" type="number" step="1" min="0"
              data-hz-bind="warmwasser.direkt.vwuPerTag" data-hz-type="number" />
            <span class="hz-field__unit">l/d</span>
          </div>
        </label>
      </div>
    </div>

    <!-- Messung -->
    <div class="hz-ww-pane" data-ww-pane="messung">
      <h4 class="hz-ww-pane__title">Messwert</h4>
      <div class="hz-grid-3">
        <label class="hz-field">
          <span class="hz-field__label">Qww pro Tag</span>
          <div class="hz-field__input-with-unit">
            <input class="hz-field__input" type="number" step="0.1" min="0"
              data-hz-bind="warmwasser.messung.qwwTagKWh" data-hz-type="number" />
            <span class="hz-field__unit">kWh/d</span>
          </div>
        </label>
      </div>
    </div>

    <!-- Verluste -->
    <div class="hz-block" style="margin-top: 22px;">
      <h3 class="hz-block__heading">Verluste</h3>
      <div class="hz-grid-3">
        <OverrideField
          label="Speicherverluste"
          symbol="fSp · %"
          id="hz-ww-speicher"
          bindPath="warmwasser.speicherProzent"
          overridePath="warmwasser.speicher"
          defaultValue={WW_VERLUSTE_DEFAULTS.speicher}
          unit="%"
          source="FWS §8"
          type="number"
          step={1}
          min={0}
          max={50}
          hint="Stehverluste am Speicher. Typisch 5–15 %."
        />
        <OverrideField
          label="Zirkulationsverluste"
          symbol="fZirk · %"
          id="hz-ww-zirk"
          bindPath="warmwasser.zirkProzent"
          overridePath="warmwasser.zirk"
          defaultValue={WW_VERLUSTE_DEFAULTS.zirk}
          unit="%"
          source="FWS §8"
          type="number"
          step={1}
          min={0}
          max={50}
          hint="Nur bei Zirkulationsleitung. Typisch 0–20 %."
        />
        <OverrideField
          label="Ausstossverluste"
          symbol="fAus · %"
          id="hz-ww-ausstoss"
          bindPath="warmwasser.ausstossProzent"
          overridePath="warmwasser.ausstoss"
          defaultValue={WW_VERLUSTE_DEFAULTS.ausstoss}
          unit="%"
          source="FWS §8"
          type="number"
          step={1}
          min={0}
          max={50}
          hint="Leitungsverluste zur Zapfstelle. Typisch 10–20 %."
        />
      </div>

      <div style="margin-top: 14px; max-width: 320px;">
        <OverrideField
          label="Temperaturhub Warmwasser"
          symbol="ΔT · K"
          id="hz-ww-deltaT"
          bindPath="warmwasser.deltaTOverride"
          overridePath="warmwasser.deltaT"
          defaultValue={50}
          unit="K"
          source="SIA 385/2"
          type="number"
          step={1}
          min={20}
          max={70}
          hint="Temperaturhub = Speicher-Soll minus Kaltwasser-Eintritt (60 °C − 10 °C = 50 K)."
        />
      </div>
    </div>
  </div>

  <SectionNotes sectionKey="sektion3" sectionLabel="Sektion 3 (Warmwasser)" />
</SectionWrapper>

<style is:global>
  .hz-ww-methods {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
  }
  .hz-ww-method {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 12px 14px; border: 1px solid var(--hz-border); border-radius: var(--hz-radius-md);
    background: var(--hz-white); cursor: pointer;
    transition: border-color var(--hz-transition), background var(--hz-transition);
  }
  .hz-ww-method:hover { border-color: var(--hz-navy-light); }
  .hz-ww-method input[type="radio"] { margin-top: 3px; accent-color: var(--hz-navy); }
  .hz-ww-method span { font-family: var(--hz-font-heading); font-weight: 600; color: var(--hz-navy); display: block; }
  .hz-ww-method small { color: var(--hz-mid-gray); font-size: 12.5px; display: block; margin-top: 2px; }
  .hz-ww-method:has(input[type="radio"]:checked) {
    border-color: var(--hz-navy); background: var(--hz-blue-tint);
  }

  .hz-ww-pane {
    margin-top: 18px;
    padding: 16px 18px;
    border: 1px solid var(--hz-border); border-left: 3px solid var(--hz-navy);
    border-radius: var(--hz-radius-md);
    background: var(--hz-off-white);
    display: none;
  }
  .hz-ww-pane.is-active { display: block; }
  .hz-ww-pane__title {
    font-family: var(--hz-font-heading); font-weight: 600; font-size: 15px;
    color: var(--hz-navy); margin: 0 0 8px;
  }

  /* Paket C / Block B: WW-Content versteckt wenn body.hz-ww-off */
  body.hz-ww-off .hz-ww-content {
    display: none;
  }

  /* Personen-Einheiten-Tabelle */
  .hz-pe-header, .hz-pe-row {
    display: grid; grid-template-columns: 1.4fr 1fr 1fr 44px; gap: 10px; align-items: center;
  }
  .hz-pe-header {
    padding: 0 4px 8px; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--hz-mid-gray); font-weight: 600; border-bottom: 1px solid var(--hz-border);
  }
  .hz-pe-row { padding: 8px 4px; border-bottom: 1px dashed var(--hz-border); }
  .hz-pe-row input {
    padding: 8px 10px; border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    background: var(--hz-white);
  }
  .hz-pe-row input:focus { outline: 0; border-color: var(--hz-navy); box-shadow: 0 0 0 3px rgba(27,42,74,0.08); }
  .hz-pe-remove { border: 0; background: transparent; padding: 6px; color: var(--hz-mid-gray); border-radius: var(--hz-radius-sm); }
  .hz-pe-remove:hover { color: var(--hz-red); background: var(--hz-red-soft); }
  .hz-pe-empty { padding: 16px 0; font-style: italic; }
  .hz-pe-actions { display: flex; align-items: center; gap: 16px; margin-top: 12px; flex-wrap: wrap; }

  @media (max-width: 640px) {
    .hz-pe-header { display: none; }
    .hz-pe-row {
      grid-template-columns: 1fr 44px;
      grid-template-areas: 'name remove' 'anzahl anzahl' 'liter liter';
      row-gap: 8px;
      padding: 10px 4px 12px;
    }
    .hz-pe-row > :nth-child(1) { grid-area: name; }
    .hz-pe-row > :nth-child(2) { grid-area: anzahl; }
    .hz-pe-row > :nth-child(3) { grid-area: liter; }
    .hz-pe-row > .hz-pe-remove { grid-area: remove; justify-self: end; }
    .hz-pe-row input { width: 100%; }
    .hz-pe-actions { flex-direction: column; align-items: stretch; }
    .hz-pe-actions > * { width: 100%; }
  }
</style>

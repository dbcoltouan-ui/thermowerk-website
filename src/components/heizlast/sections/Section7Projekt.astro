---
// Section 7 — Projekt (Abschluss)
// Kompakte Gebäude-/Ergebnis-Zusammenfassung + Speichern/Laden-Buttons.
// Die eigentliche Anzeige wird per JS (Subscribe auf heizlastState + heizlastCompute)
// in die `data-hz-sum`-Slots geschrieben (siehe src/pages/heizlast.astro).

import SectionWrapper from '../SectionWrapper.astro';
import InfoBox from '../InfoBox.astro';
import SectionNotes from '../SectionNotes.astro';
---
<SectionWrapper
  id="sektion-6"
  kicker="06 - Projekt"
  title="Zusammenfassung & Projekt speichern"
  subline="Kurzübersicht aller Eingaben und Ergebnisse. Speicherung lokal (Auto-Save) und optional in der Cloud."
>
  <!-- Zusammenfassung: Gebäude -->
  <div class="hz-sum-card">
    <h3 class="hz-sum-card__title">Gebäude &amp; Projekt</h3>
    <dl class="hz-sum-grid">
      <div><dt>Projekt</dt><dd data-hz-sum="projectName">&mdash;</dd></div>
      <div><dt>Kunde</dt><dd data-hz-sum="customerName">&mdash;</dd></div>
      <div><dt>Anschrift</dt><dd data-hz-sum="address">&mdash;</dd></div>
      <div><dt>Status</dt><dd data-hz-sum="status">&mdash;</dd></div>
      <div><dt>Gebäudetyp</dt><dd data-hz-sum="typ">&mdash;</dd></div>
      <div><dt>Lage</dt><dd data-hz-sum="lage">&mdash;</dd></div>
      <div><dt>Bauperiode</dt><dd data-hz-sum="bauperiode">&mdash;</dd></div>
      <div><dt>EBF</dt><dd><span data-hz-sum="ebf">&mdash;</span> m²</dd></div>
      <div><dt>Wohneinheiten</dt><dd data-hz-sum="wohneinheiten">&mdash;</dd></div>
      <div><dt>tvoll</dt><dd><span data-hz-sum="tvoll">&mdash;</span> h/a</dd></div>
    </dl>
  </div>

  <!-- Endergebnis (Phase 9 / Block F) — Qhl + Qw + Qoff + Qas = Qh -->
  <div class="hz-endresult" data-hz-plausi-wrap>
    <h3 class="hz-endresult__title">Wärmepumpenleistung</h3>
    <div class="hz-endresult__rows">
      <div class="hz-endresult__row">
        <span class="hz-endresult__name">Heizlast</span>
        <span class="hz-endresult__code">Qhl</span>
        <span class="hz-endresult__value"><span data-hz-sum="qhl">&mdash;</span></span>
        <span class="hz-endresult__unit">kW</span>
      </div>
      <div class="hz-endresult__op" aria-hidden="true">+</div>
      <div class="hz-endresult__row">
        <span class="hz-endresult__name">Warmwasser</span>
        <span class="hz-endresult__code">Qw</span>
        <span class="hz-endresult__value"><span data-hz-sum="qw">&mdash;</span></span>
        <span class="hz-endresult__unit">kW</span>
      </div>
      <div class="hz-endresult__op" aria-hidden="true">+</div>
      <div class="hz-endresult__row">
        <span class="hz-endresult__name">Sperrzeit</span>
        <span class="hz-endresult__code">Qoff</span>
        <span class="hz-endresult__value"><span data-hz-sum="qoff">&mdash;</span></span>
        <span class="hz-endresult__unit">kW</span>
      </div>
      <div class="hz-endresult__op" aria-hidden="true">+</div>
      <div class="hz-endresult__row">
        <span class="hz-endresult__name">Sonderzuschlag</span>
        <span class="hz-endresult__code">Qas</span>
        <span class="hz-endresult__value"><span data-hz-sum="qas">&mdash;</span></span>
        <span class="hz-endresult__unit">kW</span>
      </div>
      <div class="hz-endresult__op hz-endresult__op--eq" aria-hidden="true">=</div>
      <div class="hz-endresult__row hz-endresult__row--total">
        <span class="hz-endresult__name">Wärmepumpenleistung</span>
        <span class="hz-endresult__code">Qh</span>
        <span class="hz-endresult__value"><span data-hz-sum="qh">&mdash;</span></span>
        <span class="hz-endresult__unit">kW</span>
      </div>
    </div>
    <div class="hz-endresult__secondary">
      <div class="hz-endresult__pair"><span>WW-Speicher</span><strong><span data-hz-sum="wwSpeicher">&mdash;</span> L</strong></div>
      <div class="hz-endresult__pair"><span>Puffer</span><strong><span data-hz-sum="puffer">&mdash;</span> L</strong></div>
    </div>
  </div>

  <!-- Speichern / Laden -->
  <div class="hz-save-block">
    <header class="hz-save-block__head">
      <div>
        <h3 class="hz-save-block__title">Projekt speichern</h3>
        <p class="hz-muted" style="margin: 0;">
          Alle Eingaben werden lokal automatisch gespeichert.
          Angemeldete Benutzer können Projekte zusätzlich in der Cloud ablegen.
        </p>
      </div>
      <span class="hz-save-status" data-hz-save-status role="status" aria-live="polite">
        <span class="hz-save-status__dot" aria-hidden="true"></span>
        <span class="hz-save-status__text" data-hz-save-status-text>Bereit.</span>
      </span>
    </header>

    <div class="hz-save-actions">
      <button type="button" class="hz-btn hz-btn-primary" data-hz-action="save-cloud" disabled>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        In Cloud speichern
      </button>
      <button type="button" class="hz-btn hz-btn-ghost" data-hz-action="save-cloud-new" disabled>
        Als neues Projekt speichern
      </button>
      <button type="button" class="hz-btn hz-btn-ghost" data-hz-action="open-projects" disabled>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Projekte öffnen
      </button>
      <button type="button" class="hz-btn hz-btn-ghost" data-hz-action="login">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        <span data-hz-login-label>Anmelden</span>
      </button>
      <button type="button" class="hz-btn hz-btn-danger-soft" data-hz-action="new-project">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M5 6l1 14a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2l1-14"/></svg>
        Neues Projekt
      </button>
    </div>

    <p class="hz-save-hint hz-muted">
      Letzte lokale Speicherung: <span data-hz-save-local>&mdash;</span> &middot;
      Letzte Cloud-Speicherung: <span data-hz-save-cloud>&mdash;</span>
    </p>
  </div>

  <InfoBox title="Wie werden Projekte gespeichert?" icon="info">
    <p>
      <strong>Lokal</strong>: Alle Eingaben werden automatisch in deinem Browser zwischengespeichert
      (localStorage, Debounce 500&nbsp;ms). So geht nichts verloren, wenn du den Tab schliesst.
    </p>
    <p>
      <strong>Cloud</strong>: Nach der Anmeldung können Projekte namentlich in der Cloud abgelegt,
      wieder geladen und gelöscht werden. Der Status (Arbeit, Offeriert, Bestellt, Abgeschlossen,
      Archiv) hilft beim Überblick über laufende Anfragen.
    </p>
  </InfoBox>

  <SectionNotes sectionKey="sektion7" sectionLabel="Sektion 7 (Projekt)" />
</SectionWrapper>

<style is:global>
  .hz-sum-card {
    padding: 18px 22px;
    background: var(--hz-white);
    border: 1px solid var(--hz-border);
    border-radius: 2px;
    margin-bottom: 16px;
  }
  /* Endergebnis-Karte bekommt einen dezenten roten Top-Akzent */
  .hz-sum-card--accent { border-top: 3px solid var(--hz-red); }
  .hz-sum-card__title {
    font-family: var(--hz-font-heading); font-weight: 700; color: var(--hz-navy);
    margin: 0 0 12px; font-size: 17px;
  }
  .hz-sum-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px 22px;
    margin: 0;
  }
  .hz-sum-grid > div {
    display: flex; flex-direction: column; gap: 2px;
    padding: 6px 0; border-bottom: 1px dashed var(--hz-border);
  }
  .hz-sum-grid dt {
    font-family: var(--hz-font-heading); font-weight: 600; font-size: 11.5px;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--hz-mid-gray);
  }
  .hz-sum-grid dd {
    margin: 0; font-size: 15px; color: var(--hz-dark); font-weight: 500;
  }
  .hz-sum-grid__hero { grid-column: 1 / -1; }
  .hz-sum-grid__hero dt { color: var(--hz-red); }
  .hz-sum-grid__hero dd {
    font-family: var(--hz-font-heading); font-weight: 700;
    font-size: clamp(26px, 3.5vw, 34px); color: var(--hz-navy); line-height: 1.1;
  }

  /* Endergebnis-Karte (Phase 9 / Block F) */
  .hz-endresult {
    padding: 22px 24px 20px;
    background: var(--hz-white);
    border: 1px solid var(--hz-border);
    border-top: 3px solid var(--hz-red);
    border-radius: 2px;
    margin-bottom: 16px;
  }
  .hz-endresult__title {
    font-family: var(--hz-font-heading); font-weight: 700; color: var(--hz-navy);
    margin: 0 0 14px; font-size: 17px;
  }
  .hz-endresult__rows { display: flex; flex-direction: column; }
  .hz-endresult__row {
    display: grid;
    grid-template-columns: 1fr 56px minmax(70px, auto) 36px;
    align-items: baseline;
    gap: 12px;
    padding: 6px 0;
  }
  .hz-endresult__name {
    font-family: var(--hz-font-heading); font-weight: 600;
    font-size: 14.5px; color: var(--hz-dark);
  }
  .hz-endresult__code {
    font-family: var(--hz-font-body);
    font-size: 13px; color: var(--hz-mid-gray);
    font-style: italic;
  }
  .hz-endresult__value {
    font-family: var(--hz-font-heading); font-weight: 700;
    font-size: 18px; color: var(--hz-navy);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .hz-endresult__unit {
    font-size: 13px; color: var(--hz-mid-gray);
    text-align: left;
  }
  .hz-endresult__op {
    font-family: var(--hz-font-heading); font-weight: 700;
    font-size: 16px; color: var(--hz-mid-gray);
    margin-left: calc(100% - 120px);
    padding-left: 4px;
    line-height: 1;
  }
  .hz-endresult__op--eq {
    color: var(--hz-red);
    font-size: 18px;
    margin-top: 4px; margin-bottom: 2px;
  }
  .hz-endresult__row--total {
    margin-top: 6px;
    padding-top: 12px;
    border-top: 1px solid var(--hz-border);
  }
  .hz-endresult__row--total .hz-endresult__name {
    font-size: 15.5px; color: var(--hz-navy);
  }
  .hz-endresult__row--total .hz-endresult__code {
    color: var(--hz-red); font-style: normal; font-weight: 600;
  }
  .hz-endresult__row--total .hz-endresult__value {
    font-size: clamp(24px, 2.8vw, 30px);
    color: var(--hz-red);
  }
  .hz-endresult__row--total .hz-endresult__unit {
    font-size: 14px; color: var(--hz-dark); font-weight: 600;
  }
  .hz-endresult__secondary {
    display: flex; flex-wrap: wrap; gap: 18px;
    margin-top: 14px; padding-top: 12px;
    border-top: 1px dashed var(--hz-border);
  }
  .hz-endresult__pair {
    display: inline-flex; align-items: baseline; gap: 8px;
    font-size: 13.5px; color: var(--hz-mid-gray);
  }
  .hz-endresult__pair strong {
    color: var(--hz-navy); font-weight: 700;
    font-family: var(--hz-font-heading);
    font-variant-numeric: tabular-nums;
  }
  @media (max-width: 520px) {
    .hz-endresult { padding: 16px 16px 14px; }
    .hz-endresult__row {
      grid-template-columns: 1fr 44px minmax(60px, auto) 30px;
      gap: 8px;
    }
    .hz-endresult__op { margin-left: calc(100% - 100px); }
    .hz-endresult__row--total .hz-endresult__value { font-size: 22px; }
  }

  .hz-save-block {
    margin-top: 8px;
    padding: 20px 22px;
    background: var(--hz-off-white);
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-lg);
  }
  .hz-save-block__head {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
    flex-wrap: wrap; margin-bottom: 14px;
  }
  .hz-save-block__title {
    font-family: var(--hz-font-heading); font-weight: 700; color: var(--hz-navy);
    margin: 0 0 4px; font-size: 16px;
  }
  .hz-save-status {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 12px; border-radius: 999px;
    background: var(--hz-white); border: 1px solid var(--hz-border);
    font-size: 12.5px; color: var(--hz-mid-gray);
  }
  .hz-save-status__dot {
    width: 8px; height: 8px; border-radius: 50%; background: var(--hz-mid-gray);
  }
  .hz-save-status[data-tone="ok"] .hz-save-status__dot { background: #2e7d32; }
  .hz-save-status[data-tone="busy"] .hz-save-status__dot { background: #f9a825; animation: hz-pulse 1.2s infinite; }
  .hz-save-status[data-tone="err"] .hz-save-status__dot { background: var(--hz-red); }
  .hz-save-status.is-flash {
    animation: hz-save-flash 1.4s ease-out;
    border-color: #2e7d32;
  }
  @keyframes hz-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
  @keyframes hz-save-flash {
    0%   { box-shadow: 0 0 0 0 rgba(46, 125, 50, 0.45); background: #EAF6EC; }
    40%  { box-shadow: 0 0 0 6px rgba(46, 125, 50, 0);   background: #EAF6EC; }
    100% { box-shadow: 0 0 0 0 rgba(46, 125, 50, 0);     background: var(--hz-white); }
  }

  .hz-save-actions {
    display: flex; flex-wrap: wrap; gap: 10px;
  }
  .hz-btn-danger-soft {
    background: transparent; color: var(--hz-red);
    border: 1px solid var(--hz-red-soft);
  }
  .hz-btn-danger-soft:hover:not([disabled]) {
    background: var(--hz-red-soft);
  }
  .hz-btn[disabled] { opacity: 0.5; pointer-events: none; }
  .hz-save-hint { margin-top: 14px; font-size: 12.5px; }

  @media (max-width: 520px) {
    .hz-sum-card { padding: 14px 16px; }
    .hz-sum-grid { grid-template-columns: 1fr; gap: 6px 0; }
    .hz-save-block { padding: 16px 16px; }
    .hz-save-actions { flex-direction: column; }
    .hz-save-actions > .hz-btn { width: 100%; justify-content: center; }
    .hz-save-block__head { flex-direction: column; gap: 10px; }
  }
</style>

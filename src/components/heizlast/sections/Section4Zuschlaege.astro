---
// Section 4 — Zuschlaege (M6)
// Phase 9 / Block D:
// - Sperrzeit per Ja/Nein-Switch (toff-Feld + FWS-Faktoren nur sichtbar wenn aktiv).
// - Qas = Zuschlag fuer verbundene Systeme (Lueftung, Pool, Solar). Feld immer
//   sichtbar, wird automatisch addiert sobald Wert > 0. Kein Aktiv-Toggle mehr.

import SectionWrapper from '../SectionWrapper.astro';
import InfoBox from '../InfoBox.astro';
import KpiCard from '../KpiCard.astro';
import SectionNotes from '../SectionNotes.astro';
import OverrideField from '../OverrideField.astro';
import { SPERRZEIT_FAKTOREN } from '../../../lib/heizlast/constants.ts';
---
<SectionWrapper
  id="sektion-4"
  kicker="04 - Zuschläge"
  title="Zuschläge"
  subline="Sperrzeit-Aufschlag und Zuschlag für verbundene Systeme (Lüftung, Pool)."
  tone="off"
>
  <slot name="aside" slot="aside">
    <div class="hz-kpi-grid" style="grid-template-columns: 1fr; min-width: 240px;">
      <KpiCard label="Qoff" value="—" unit="kW" caption="Sperrzeit-Zuschlag" data-kpi="qoff" />
    </div>
  </slot>

  <div class="hz-block">
    <div class="hz-block__head">
      <h3 class="hz-block__heading">Sperrzeit</h3>
      <small class="hz-muted">Abschaltung durch den Energieversorger</small>
    </div>

    <label class="hz-switch hz-sperrzeit-switch">
      <input type="checkbox" data-hz-bind="zuschlaege.sperrzeitActive" data-hz-type="boolean" />
      <span>Sperrzeit vorhanden?</span>
    </label>

    <div class="hz-sperrzeit-block" data-hz-sperrzeit-block>
      <div class="hz-grid-3" style="margin-top: 12px;">
        <OverrideField
          label="toff"
          id="hz-toff"
          bindPath="zuschlaege.toff"
          defaultValue={2}
          unit="h/d"
          source="EVU"
          type="number"
          step={1}
          min={0}
          max={8}
          hint="Stunden pro Tag, in denen die WP abgeschaltet wird."
        />
      </div>

      <p class="hz-muted hz-sperrzeit-chips">
        Korrekturfaktor je Sperrzeit (FWS):
        {Object.entries(SPERRZEIT_FAKTOREN).map(([h, f]) => (
          <span class="hz-sperrzeit-chip">{h}&nbsp;h → &times;{f.toFixed(2)}</span>
        ))}
      </p>
    </div>
  </div>

  <div class="hz-block">
    <div class="hz-block__head">
      <h3 class="hz-block__heading">Qas — Verbundene Systeme</h3>
      <small class="hz-muted">Lüftung, Pool, Solar – optional</small>
    </div>

    <label class="hz-field" style="max-width: 280px;">
      <span class="hz-field__label">Zuschlag</span>
      <div class="hz-field__input-with-unit">
        <input class="hz-field__input" type="number" step="0.1" min="0"
          data-hz-bind="zuschlaege.qas" data-hz-type="number" />
        <span class="hz-field__unit">kW</span>
      </div>
      <small class="hz-muted">0 oder leer = kein Zuschlag. Richtwerte: Pool 1–3 kW, grosse Wohnungslüftung 0.3–0.8 kW.</small>
    </label>
  </div>

  <InfoBox title="Sperrzeit-Zuschlag" icon="info">
    <p>
      Zuschlag auf Qhl wegen täglicher Abschaltung der Wärmepumpe durch den Energieversorger (EVU).
      Die wegfallende Heizzeit wird auf die restlichen Betriebsstunden umgelegt — Grundlage ist die FWS-Korrekturtabelle.
    </p>
  </InfoBox>

  <SectionNotes sectionKey="sektion4" sectionLabel="Sektion 4 (Zuschläge)" />
</SectionWrapper>

<style is:global>
  .hz-sperrzeit-switch { margin-bottom: 4px; }

  .hz-sperrzeit-chips { margin-top: 10px; font-size: 13.5px; }

  .hz-sperrzeit-chip {
    display: inline-block;
    margin: 4px 6px 0 0;
    padding: 3px 8px;
    border-radius: 999px;
    background: var(--hz-blue-tint);
    color: var(--hz-navy);
    font-size: 12px;
    font-family: var(--hz-font-heading);
    font-weight: 600;
  }

  .hz-block__head {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 10px;
  }

  /* Sperrzeit-Block nur sichtbar, wenn der Hauptschalter an ist.
     Wird in heizlast.astro per body.hz-sperrzeit-on gesteuert. */
  body:not(.hz-sperrzeit-on) .hz-sperrzeit-block {
    display: none;
  }
</style>

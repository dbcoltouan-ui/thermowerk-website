---
// Section 4 — Zuschlaege (M6)
// - toff: Sperrzeit in Stunden
// - Qas: optionaler Sonder-/Abtauzuschlag

import SectionWrapper from '../SectionWrapper.astro';
import InfoBox from '../InfoBox.astro';
import KpiCard from '../KpiCard.astro';
import Toggle from '../Toggle.astro';
import SectionNotes from '../SectionNotes.astro';
import OverrideField from '../OverrideField.astro';
import { SPERRZEIT_FAKTOREN } from '../../../lib/heizlast/constants.ts';
---
<SectionWrapper
  id="sektion-4"
  kicker="04 - Zuschläge"
  title="Zuschläge"
  subline="Sperrzeit-Aufschlag und optionale Sonderzuschläge (z. B. Abtau-Reserve)."
  tone="off"
>
  <slot name="aside" slot="aside">
    <div class="hz-kpi-grid" style="grid-template-columns: 1fr; min-width: 240px;">
      <KpiCard label="Qoff" value="—" unit="kW" caption="Sperrzeit-Zuschlag" data-kpi="qoff" />
    </div>
  </slot>

  <div class="hz-block">
    <h3 class="hz-block__heading">Sperrzeit (EVU)</h3>
    <div class="hz-grid-3">
      <OverrideField
        label="toff - Sperrstunden pro Tag"
        id="hz-toff"
        bindPath="zuschlaege.toff"
        defaultValue={2}
        unit="h/d"
        source="EVU-Vorgabe"
        type="number"
        step={1}
        min={0}
        max={8}
        hint="0 = keine Sperre. Typisch: 2-4 h (EVU)."
      />
    </div>

    <p class="hz-muted" style="margin-top: 8px; font-size: 13.5px;">
      Korrekturfaktor je Sperrzeit (FWS):
      {Object.entries(SPERRZEIT_FAKTOREN).map(([h, f]) => (
        <span class="hz-sperrzeit-chip">{h}&nbsp;h → &times;{f.toFixed(2)}</span>
      ))}
    </p>
  </div>

  <Toggle label="Zusätzlicher Sonder-/Abtauzuschlag (Qas)" caption="optional" id="hz-m6-qas">
    <label class="hz-field" style="max-width: 280px;">
      <span class="hz-field__label">Qas</span>
      <div class="hz-field__input-with-unit">
        <input class="hz-field__input" type="number" step="0.1" min="0"
          data-hz-bind="zuschlaege.qas" data-hz-type="number" />
        <span class="hz-field__unit">kW</span>
      </div>
      <small class="hz-muted">Wird direkt zu Qh addiert.</small>
    </label>
    <label class="hz-switch" style="margin-top: 10px;">
      <input type="checkbox" data-hz-bind="zuschlaege.qasActive" data-hz-type="boolean" />
      <span>Qas aktiv</span>
    </label>
  </Toggle>

  <InfoBox title="Warum ein Sperrzeit-Zuschlag?" icon="help">
    <p>
      EVU können Wärmepumpen stundenweise abschalten (Lastmanagement).
      In dieser Zeit fehlt Heizleistung — sie muss in den restlichen Stunden nachgeholt werden.
      Der Zuschlag wird als Faktor auf Qhl aufgeschlagen (FWS §4).
    </p>
  </InfoBox>

  <SectionNotes sectionKey="sektion4" sectionLabel="Sektion 4 (Zuschläge)" />
</SectionWrapper>

<style is:global>
  .hz-sperrzeit-chip {
    display: inline-block; margin: 4px 6px 0 0;
    padding: 3px 8px; border-radius: 999px;
    background: var(--hz-blue-tint); color: var(--hz-navy);
    font-size: 12px; font-family: var(--hz-font-heading); font-weight: 600;
  }
</style>

---
// Section 4 — Zuschlaege (M6)
// Paket C / Block G: Zwei klare Blöcke.
//   Block 1: Sperrzeit (Ja/Nein + toff). Chips-Liste entfernt (kein Korrekturfaktor-Text).
//   Block 2: Verbundene Systeme — Pool (kW) und Lüftung (kW), Summe → qas.
// F: Kein Kicker, keine Aside-KPIs, keine InfoBox.

import SectionWrapper from '../SectionWrapper.astro';
import SectionNotes from '../SectionNotes.astro';
import OverrideField from '../OverrideField.astro';
---
<SectionWrapper
  id="sektion-4"
  title="Zuschläge"
  subline="Sperrzeit durch den Energieversorger und verbundene Systeme."
  tone="off"
>

  <!-- Block 1: Sperrzeit -->
  <div class="hz-block">
    <h3 class="hz-block__heading">Sperrzeit — Abschaltung durch den Energieversorger</h3>

    <label class="hz-switch hz-sperrzeit-switch">
      <input type="checkbox" data-hz-bind="zuschlaege.sperrzeitActive" data-hz-type="boolean" />
      <span>Sperrzeit vorhanden?</span>
    </label>

    <div class="hz-sperrzeit-block" data-hz-sperrzeit-block>
      <div class="hz-grid-3" style="margin-top: 12px;">
        <OverrideField
          label="Sperrzeit"
          symbol="toff · h/d"
          id="hz-toff"
          bindPath="zuschlaege.toff"
          defaultValue={2}
          unit="h/d"
          source="EVU"
          type="number"
          step={1}
          min={0}
          max={8}
          hint="Stunden pro Tag, in denen die WP abgeschaltet wird."
        />
      </div>
    </div>
  </div>

  <!-- Block 2: Verbundene Systeme (Qas) -->
  <div class="hz-block" style="margin-top: 24px;">
    <h3 class="hz-block__heading">Verbundene Systeme (optional)</h3>
    <p class="hz-muted" style="font-size: 13.5px; margin-bottom: 14px;">
      Systeme, die mit der Wärmepumpe mitversorgt werden. Leer oder 0 = kein Zuschlag.
    </p>
    <div class="hz-grid-3">
      <label class="hz-field">
        <span class="hz-field__label">Pool</span>
        <div class="hz-field__input-with-unit">
          <input class="hz-field__input" type="number" step="0.1" min="0"
            data-hz-bind="zuschlaege.qasPool" data-hz-type="number"
            placeholder="0" />
          <span class="hz-field__unit">kW</span>
        </div>
        <small class="hz-muted">Richtwert 1–3 kW</small>
      </label>
      <label class="hz-field">
        <span class="hz-field__label">Wohnungslüftung</span>
        <div class="hz-field__input-with-unit">
          <input class="hz-field__input" type="number" step="0.1" min="0"
            data-hz-bind="zuschlaege.qasLueftung" data-hz-type="number"
            placeholder="0" />
          <span class="hz-field__unit">kW</span>
        </div>
        <small class="hz-muted">Richtwert 0.3–0.8 kW</small>
      </label>
      <div class="hz-field">
        <span class="hz-field__label">Qas (Summe)</span>
        <div class="hz-qas-sum">
          <span class="hz-qas-sum__val" data-kpi="qas">—</span>
          <span class="hz-qas-sum__unit">kW</span>
        </div>
        <small class="hz-muted">wird automatisch in Qh addiert sobald &gt; 0</small>
      </div>
    </div>
  </div>

  <SectionNotes sectionKey="sektion4" sectionLabel="Sektion 4 (Zuschläge)" />
</SectionWrapper>

<style is:global>
  .hz-sperrzeit-switch { margin-bottom: 4px; }

  .hz-block__head {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 10px;
  }

  /* Sperrzeit-Block nur sichtbar, wenn der Hauptschalter an ist. */
  body:not(.hz-sperrzeit-on) .hz-sperrzeit-block {
    display: none;
  }

  /* Qas-Summen-Anzeige */
  .hz-qas-sum {
    display: inline-flex; align-items: baseline; gap: 6px;
    padding: 10px 14px;
    border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    background: var(--hz-off-white);
  }
  .hz-qas-sum__val {
    font-family: var(--hz-font-heading); font-weight: 700;
    font-size: 18px; color: var(--hz-navy);
  }
  .hz-qas-sum__unit { font-size: 13px; color: var(--hz-mid-gray); }
</style>

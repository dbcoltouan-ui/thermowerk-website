---
// Section 1 — Projekt-Kopf + Gebaeude & Standort (M1)
// Paket C: Wohneinheiten entfernt (I), EBF-Helfer umgebaut (H),
//          InfoBox "Abkuerzungen" entfernt (F), kein Kicker mehr (F via SectionWrapper).

import SectionWrapper from '../SectionWrapper.astro';
import Toggle from '../Toggle.astro';
import SectionNotes from '../SectionNotes.astro';
import OverrideField from '../OverrideField.astro';
import { VOLLASTSTUNDEN, BAUPERIODEN } from '../../../lib/heizlast/constants.ts';
---
<SectionWrapper
  id="sektion-1"
  title="Projekt & Gebäudedaten"
  subline="Projekt-Eckdaten und Stammdaten des Gebäudes als Grundlage der Berechnung."
  first
>

  <!-- Projekt-Block (Paket D / J: 4-Spalten-Layout) -->
  <div class="hz-proj">
    <div class="hz-proj__title-row">
      <h3 class="hz-proj__heading">Projekt</h3>
      <p class="hz-proj__hint hz-muted">Projekt-Bezeichnung und Anschrift.</p>
    </div>
    <div class="hz-grid-4">
      <label class="hz-field" data-size="sm">
        <span class="hz-field__label">Projektname</span>
        <input
          class="hz-field__input"
          type="text"
          placeholder="z. B. EFH Meier"
          data-hz-bind="projectName"
          data-hz-type="string"
        />
      </label>
      <label class="hz-field" data-size="sm">
        <span class="hz-field__label">Anschrift</span>
        <input
          class="hz-field__input"
          type="text"
          placeholder="Strasse, PLZ Ort"
          data-hz-bind="address"
          data-hz-type="string"
        />
      </label>
      <label class="hz-field" data-size="sm">
        <span class="hz-field__label">Kunde</span>
        <input
          class="hz-field__input"
          type="text"
          placeholder="Bauherrschaft"
          data-hz-bind="customerName"
          data-hz-type="string"
        />
      </label>
      <label class="hz-field" data-size="sm">
        <span class="hz-field__label">Status</span>
        <select class="hz-field__input" data-hz-bind="status" data-hz-type="string">
          <option value="arbeit">In Arbeit</option>
          <option value="offeriert">Offeriert</option>
          <option value="bestellt">Bestellt</option>
          <option value="abgeschlossen">Abgeschlossen</option>
          <option value="archiv">Archiv</option>
        </select>
      </label>
    </div>
  </div>

  <!-- Gebaeudedaten (Paket D / J: Zeile 1 = Typ/Lage/Bauperiode/EBF, Zeile 2 = Profil/tvoll) -->
  <div class="hz-block">
    <h3 class="hz-block__heading">Gebäude &amp; Standort</h3>

    <!-- Zeile 1: 4 Spalten -->
    <div class="hz-grid-4">
      <label class="hz-field" data-size="sm">
        <span class="hz-field__label">Gebäudetyp</span>
        <select class="hz-field__input" data-hz-bind="gebaeude.typ" data-hz-type="string">
          <option value="efh">Einfamilienhaus (EFH)</option>
          <option value="mfh">Mehrfamilienhaus (MFH)</option>
          <option value="buero">Büro / Gewerbe</option>
        </select>
      </label>
      <label class="hz-field" data-size="sm">
        <span class="hz-field__label">Lage</span>
        <select class="hz-field__input" data-hz-bind="gebaeude.lage" data-hz-type="string">
          <option value="mittelland">Mittelland (≤ 800 m ü. M.)</option>
          <option value="hoehe">Ab 800 m ü. M.</option>
        </select>
      </label>
      <label class="hz-field" data-size="sm">
        <span class="hz-field__label">Bauperiode</span>
        <select class="hz-field__input" data-hz-bind="gebaeude.bauperiode" data-hz-type="string">
          {BAUPERIODEN.map((b) => (
            <option value={b.id}>{b.label}</option>
          ))}
        </select>
      </label>

      <!-- EBF + Zimmer-Helfer -->
      <div>
        <label class="hz-field">
          <span class="hz-field__label">EBF</span>
          <div class="hz-field__input-with-unit">
            <input
              class="hz-field__input"
              id="hz-ebf-input"
              type="number"
              step="1"
              min="10"
              data-hz-bind="gebaeude.ebf"
              data-hz-type="number"
            />
            <span class="hz-field__unit">m²</span>
          </div>
        </label>

        <!-- Zimmer / Flächen-Helfer (direkt unter EBF) -->
        <details class="hz-raum-details" id="hz-raum-details">
          <summary class="hz-raum-summary">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            Zimmer / Flächen
          </summary>

          <div class="hz-raum-body">
            <div class="hz-raum-header">
              <span>Bezeichnung</span>
              <span>Länge (m)</span>
              <span>Breite (m)</span>
              <span>Fläche (m²)</span>
              <span>Unbeheizt</span>
              <span></span>
            </div>
            <div id="hz-raum-list" class="hz-raum-list" aria-live="polite">
              <p class="hz-muted hz-raum-empty">Noch keine Zimmer erfasst.</p>
            </div>
            <div class="hz-raum-footer">
              <button type="button" class="hz-btn hz-btn-ghost hz-btn--sm" id="hz-raum-add">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Zimmer hinzufügen
              </button>
              <span class="hz-raum-sum-line">
                <span class="hz-muted">Netto-EBF:</span>
                <strong id="hz-raum-sum-value">0.0</strong> m²
                <span class="hz-muted" id="hz-raum-sum-detail"></span>
              </span>
            </div>
          </div>
        </details>
      </div>
    </div>

    <!-- Zeile 2: Nutzungsprofil + tvoll (max-content Columns) -->
    <div class="hz-grid-2" style="margin-top: 14px;">
      <label class="hz-field" data-size="md">
        <span class="hz-field__label">Nutzungsprofil (tvoll)</span>
        <select class="hz-field__input" data-hz-bind="gebaeude.tvollProfil" data-hz-type="string">
          {VOLLASTSTUNDEN.filter((r) => r.lage === 'mittelland').map((r) => (
            <option value={r.gebaeudetyp}>{
              r.gebaeudetyp === 'wohnen_mitWW' ? 'Wohngebäude mit WW'
              : r.gebaeudetyp === 'wohnen_ohneWW' ? 'Wohngebäude ohne WW'
              : 'Gewerbe / Wochenend-Absenkung'
            }</option>
          ))}
        </select>
      </label>

      <!-- tvoll mit Auto-Default + Override (Phase 9 / Block A + B) -->
      <OverrideField
        label="Vollbetriebsstunden tvoll"
        symbol="h/a"
        id="hz-tvoll"
        bindPath="gebaeude.tvollOverride"
        overridePath="gebaeude.tvoll"
        defaultValue={2300}
        unit="h/a"
        source="FWS"
        type="number"
        step={50}
        min={1000}
        max={3500}
        hint="Richtwert aus Profil + Lage. Wird automatisch angepasst."
      />
    </div>
  </div>

  <SectionNotes sectionKey="sektion1" sectionLabel="Sektion 1 (Projekt &amp; Gebäude)" />
</SectionWrapper>

<style is:global>
  /* Projekt-Block (Phase 8: Blue-tint statt Navy) */
  .hz-proj {
    margin-bottom: clamp(24px, 4vh, 36px);
    padding: clamp(16px, 3vw, 22px);
    background: var(--hz-blue-tint);
    color: var(--hz-dark);
    border: 1px solid var(--hz-blue-tint-strong);
    border-radius: var(--hz-radius-lg);
  }
  .hz-proj__title-row {
    display: flex; align-items: baseline; justify-content: flex-start; gap: 16px; /* H: kein space-between */
    margin-bottom: 14px; flex-wrap: wrap;
  }
  .hz-proj__heading {
    font-family: var(--hz-font-heading);
    font-weight: 600; font-size: 14px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--hz-navy);
    margin: 0;
  }
  .hz-proj__hint { color: var(--hz-mid-gray); font-size: 13px; margin: 0; }
  .hz-proj .hz-field__label { color: var(--hz-navy); }
  .hz-proj .hz-field__input {
    background: var(--hz-white);
    border-color: var(--hz-blue-tint-strong);
    color: var(--hz-dark);
  }
  .hz-proj .hz-field__input::placeholder { color: var(--hz-mid-gray); }
  .hz-proj .hz-field__input:focus {
    background: var(--hz-white);
    border-color: var(--hz-navy);
    box-shadow: 0 0 0 3px rgba(27,42,74,0.12);
  }

  /* Gebaeude-Block */
  .hz-block { margin-top: clamp(18px, 3vh, 26px); }
  .hz-block__heading {
    font-family: var(--hz-font-heading);
    font-weight: 600; font-size: 14px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--hz-navy); margin: 0 0 14px;
  }

  /* Input-Felder (generisch) — Basisregeln hier; .hz-scope-Regeln in HeizlastLayout
     haben hoehere Spezifitaet und definieren max-content-Verhalten. */
  .hz-grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, max-content)); gap: 14px 18px; justify-content: start; }
  .hz-grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, max-content)); gap: 14px 18px; justify-content: start; }
  .hz-grid-3 + .hz-grid-3 { margin-top: 14px; }

  .hz-field { display: flex; flex-direction: column; gap: 6px; }
  .hz-field__label {
    font-family: var(--hz-font-heading);
    font-weight: 600; font-size: 14px; color: var(--hz-navy);
  }
  .hz-field__input {
    padding: 10px 14px;
    border: 1px solid var(--hz-border); background: var(--hz-white);
    border-radius: var(--hz-radius-sm);
    font-family: var(--hz-font-body); font-size: 15.5px; color: var(--hz-dark);
    transition: border-color var(--hz-transition), box-shadow var(--hz-transition);
  }
  .hz-field__input:focus {
    outline: 0; border-color: var(--hz-navy);
    box-shadow: 0 0 0 3px rgba(27,42,74,0.08);
  }
  .hz-field__input-with-unit {
    display: flex; align-items: stretch;
    border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    background: var(--hz-white);
    overflow: hidden;
  }
  .hz-field__input-with-unit:focus-within {
    border-color: var(--hz-navy); box-shadow: 0 0 0 3px rgba(27,42,74,0.08);
  }
  .hz-field__input-with-unit .hz-field__input {
    border: 0; border-radius: 0; flex: 1 1 auto;
  }
  .hz-field__input-with-unit .hz-field__input:focus { box-shadow: none; }
  .hz-field__unit {
    display: inline-flex; align-items: center; padding: 0 12px;
    border-left: 1px solid var(--hz-border);
    font-family: var(--hz-font-heading); font-size: 13px; color: var(--hz-mid-gray);
    background: var(--hz-off-white);
  }

  /* Zimmer-Helfer (Paket C / H) — als <details> direkt unter EBF */
  .hz-raum-details {
    margin-top: 8px;
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-sm);
    background: var(--hz-off-white);
    overflow: hidden;
  }
  .hz-raum-summary {
    display: flex; align-items: center; gap: 7px;
    padding: 8px 12px;
    cursor: pointer;
    font-family: var(--hz-font-heading); font-weight: 600; font-size: 13.5px;
    color: var(--hz-navy);
    list-style: none;
    user-select: none;
  }
  .hz-raum-summary::-webkit-details-marker { display: none; }
  .hz-raum-summary:hover { background: var(--hz-blue-tint); }
  .hz-raum-body {
    padding: 10px 12px 12px;
    border-top: 1px solid var(--hz-border);
    background: var(--hz-white);
  }

  .hz-raum-header, .hz-raum-row {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1.1fr 64px 40px;
    gap: 8px;
    align-items: center;
  }
  .hz-raum-header {
    padding: 0 4px 6px;
    font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--hz-mid-gray); font-weight: 600;
    border-bottom: 1px solid var(--hz-border);
  }
  .hz-raum-row {
    padding: 7px 4px;
    border-bottom: 1px dashed var(--hz-border);
  }
  .hz-raum-row input[type="text"], .hz-raum-row input[type="number"] {
    padding: 7px 9px;
    border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    background: var(--hz-white);
    font-family: var(--hz-font-body); font-size: 14px;
    width: 100%; min-width: 0;
  }
  .hz-raum-row input:focus { outline: 0; border-color: var(--hz-navy); box-shadow: 0 0 0 3px rgba(27,42,74,0.08); }
  /* Wenn flaecheDirekt gesetzt ist, L/B visuell gedämpft */
  .hz-raum-row[data-direkt="true"] input[data-raum-field="laenge"],
  .hz-raum-row[data-direkt="true"] input[data-raum-field="breite"] {
    opacity: 0.4; background: var(--hz-off-white);
  }
  /* Unbeheizt-Zeile: leichter grauer Hintergrund */
  .hz-raum-row[data-beheizt="false"] { background: rgba(200, 200, 210, 0.10); }
  /* hz-raum-flaeche: desktop hidden (flaecheDirekt input is col 4),
     only shown on mobile via grid-area below */
  .hz-raum-row .hz-raum-flaeche { display: none; }
  .hz-raum-row .hz-raum-flaeche.is-derived { color: var(--hz-mid-gray); font-weight: 400; }
  .hz-raum-unbeheizt {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    font-size: 12px; color: var(--hz-mid-gray);
  }
  .hz-raum-unbeheizt input[type="checkbox"] { width: 15px; height: 15px; accent-color: var(--hz-navy); }
  .hz-raum-remove {
    border: 0; background: transparent; padding: 5px;
    color: var(--hz-mid-gray); border-radius: var(--hz-radius-sm);
  }
  .hz-raum-remove:hover { color: var(--hz-red); background: var(--hz-red-soft); }
  .hz-raum-empty { padding: 12px 0; font-style: italic; font-size: 13.5px; }
  .hz-raum-list { margin: 4px 0; }

  .hz-raum-footer {
    display: flex; align-items: center; justify-content: flex-start; gap: 12px; /* H: kompakt */
    margin-top: 10px; flex-wrap: wrap;
  }
  .hz-raum-sum-line {
    font-size: 13.5px; color: var(--hz-navy);
    display: inline-flex; align-items: baseline; gap: 5px;
  }
  .hz-raum-sum-line strong { font-family: var(--hz-font-heading); font-size: 15px; }

  .hz-btn--sm { font-size: 13.5px; padding: 7px 14px; }

  /* Mobile-Anpassungen Zimmer-Tabelle */
  @media (max-width: 640px) {
    .hz-raum-header { display: none; }
    .hz-raum-row {
      grid-template-columns: 1fr 1fr 40px;
      grid-template-areas:
        "name name remove"
        "laenge breite unbeheizt"
        "flaeche flaeche flaeche";
      gap: 6px;
    }
    .hz-raum-row input[data-raum-field="name"] { grid-area: name; }
    .hz-raum-row input[data-raum-field="laenge"] { grid-area: laenge; }
    .hz-raum-row input[data-raum-field="breite"] { grid-area: breite; }
    .hz-raum-row input[data-raum-field="flaecheDirekt"] { display: none; }
    .hz-raum-row .hz-raum-flaeche { display: block; grid-area: flaeche; text-align: left; font-family: var(--hz-font-heading); font-weight: 600; color: var(--hz-navy); font-size: 13.5px; }
    .hz-raum-row .hz-raum-unbeheizt { grid-area: unbeheizt; justify-content: flex-end; }
    .hz-raum-row .hz-raum-remove { grid-area: remove; }
  }
</style>

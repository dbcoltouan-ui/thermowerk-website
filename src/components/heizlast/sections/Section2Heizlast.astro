---
// Section 2 - Heizlast-Berechnung (M2 + M4 + M3)
// Paket C / Block D: Kompaktes Radio-Umschalten (Verbrauch / Betriebsstunden / Override).
//   Nur die gewählte Methode sichtbar. "Diese Methode verwenden"-Switches entfernt.
//   Messung in Betriebsstunden-Block integriert.
//   Bauperiode ist immer Fallback (Anzeige unter Methoden-Block).
//   FWS-InfoBox entfernt (F). Aside-KPIs entfernt (F).
//   Sanierung: kein "Sanierungsabzug aktiv"-Toggle (E), Auto bei Einträgen.

import SectionWrapper from '../SectionWrapper.astro';
import SectionNotes from '../SectionNotes.astro';
import { BRENNWERTE, WIRKUNGSGRADE, SANIERUNGS_MASSNAHMEN, BAUPERIODEN } from '../../../lib/heizlast/constants.ts';
---
<SectionWrapper
  id="sektion-2"
  title="Heizlast-Berechnung"
  subline="Methode auswählen und Daten eingeben. Bauperiode läuft immer als Fallback."
  tone="off"
>

  <!-- Methoden-Umschalter: Radio-Leiste oben -->
  <div class="hz-method-tabs" id="hz-method-tabs">
    <label class="hz-method-tab">
      <input type="radio" name="hz-method-radio" value="verbrauch" id="hz-mrt-verbrauch" />
      <span>Verbrauch</span>
    </label>
    <label class="hz-method-tab">
      <input type="radio" name="hz-method-radio" value="bstd" id="hz-mrt-bstd" />
      <span>Betriebsstunden</span>
    </label>
    <label class="hz-method-tab">
      <input type="radio" name="hz-method-radio" value="override" id="hz-mrt-override" />
      <span>Direkteingabe Qhl</span>
    </label>
  </div>

  <!-- Methoden-Panel: Verbrauch (Default) -->
  <div class="hz-method-panel" id="hz-mp-verbrauch" data-method-panel="verbrauch">
    <p class="hz-muted hz-method__intro">Letzte Jahresverbräuche eines Heizkessels in Qn umrechnen.</p>
    <div class="hz-grid-3">
      <label class="hz-field">
        <span class="hz-field__label">Energieträger</span>
        <select class="hz-field__input" data-hz-bind="heizlast.verbrauch.energietraeger" data-hz-type="string">
          {Object.entries(BRENNWERTE).map(([id, b]) => (
            <option value={id}>{b.label}</option>
          ))}
        </select>
      </label>
      <label class="hz-field">
        <span class="hz-field__label">Verbrauch Ba</span>
        <input class="hz-field__input" type="number" step="1" min="0"
          data-hz-bind="heizlast.verbrauch.ba" data-hz-type="number" />
        <small class="hz-muted">Einheit je nach Energieträger (l/a, m³/a, kg/a, rm/a, kWh/a)</small>
      </label>
      <label class="hz-field">
        <span class="hz-field__label">Wirkungsgrad η</span>
        <select class="hz-field__input" data-hz-bind="heizlast.verbrauch.etaWirkungsgradId" data-hz-type="string">
          {WIRKUNGSGRADE.map((w) => (
            <option value={w.id}>{w.label} (η {w.default.toFixed(2)})</option>
          ))}
        </select>
      </label>
    </div>
    <div class="hz-grid-3" style="margin-top: 10px;">
      <label class="hz-field">
        <span class="hz-field__label">η manuell (optional)</span>
        <input class="hz-field__input" type="number" step="0.01" min="0.3" max="1.0"
          placeholder="Leer = Default"
          data-hz-bind="heizlast.verbrauch.etaOverride" data-hz-type="number" />
      </label>
      <label class="hz-field">
        <span class="hz-field__label">WW im Verbrauch enthalten?</span>
        <div class="hz-switch">
          <label><input type="checkbox" data-hz-bind="heizlast.verbrauch.inklWW" data-hz-type="boolean" /> <span>Ja, inkl. WW</span></label>
        </div>
      </label>
      <label class="hz-field">
        <span class="hz-field__label">WW-Tagesverbrauch Vw,u</span>
        <div class="hz-field__input-with-unit">
          <input class="hz-field__input" type="number" step="1" min="0"
            data-hz-bind="heizlast.verbrauch.vwuAbzug" data-hz-type="number" />
          <span class="hz-field__unit">l/d</span>
        </div>
        <small class="hz-muted">wird abgezogen wenn WW im Verbrauch enthalten ist</small>
      </label>
    </div>

    <!-- Verbrauch-Perioden -->
    <div class="hz-perioden-block" style="margin-top: 16px;">
      <p class="hz-perioden-block__heading">Messperioden <span class="hz-badge hz-badge--optional">optional</span></p>
      <p class="hz-muted" style="font-size: 12.5px; margin-bottom: 8px;">
        Mehrere Jahre eintragen → Rechner bildet gewichtetes Jahresäquivalent. Leer = Einzelwert Ba oben.
      </p>
      <div class="hz-perioden-list" id="hz-vp-list" aria-live="polite">
        <p class="hz-muted hz-perioden-empty" style="font-style: italic; font-size: 13px;">Kein Perioden-Eintrag — Einzelwert aus Ba wird verwendet.</p>
      </div>
      <div class="hz-perioden-controls">
        <button type="button" class="hz-btn hz-btn-ghost" id="hz-vp-add">+ Periode hinzufügen</button>
      </div>
      <div class="hz-perioden-info" id="hz-vp-info"></div>
    </div>
  </div>

  <!-- Methoden-Panel: Betriebsstunden (inkl. Direktmessung als Alternative) -->
  <div class="hz-method-panel" id="hz-mp-bstd" data-method-panel="bstd" hidden>
    <p class="hz-muted hz-method__intro">Aus Laufzeit und Nennleistung des bestehenden Kessels — oder Jahreswert direkt.</p>
    <div class="hz-grid-3">
      <label class="hz-field">
        <span class="hz-field__label">Betriebsstunden gesamt</span>
        <div class="hz-field__input-with-unit">
          <input class="hz-field__input" type="number" step="10" min="0"
            data-hz-bind="heizlast.bstd.stundenGesamt" data-hz-type="number" />
          <span class="hz-field__unit">h</span>
        </div>
      </label>
      <label class="hz-field">
        <span class="hz-field__label">über wie viele Jahre?</span>
        <input class="hz-field__input" type="number" step="1" min="1"
          data-hz-bind="heizlast.bstd.jahre" data-hz-type="number" />
      </label>
      <label class="hz-field">
        <span class="hz-field__label">Nennleistung Qh_WP</span>
        <div class="hz-field__input-with-unit">
          <input class="hz-field__input" type="number" step="0.1" min="0"
            data-hz-bind="heizlast.bstd.qhWP" data-hz-type="number" />
          <span class="hz-field__unit">kW</span>
        </div>
      </label>
    </div>
    <!-- Betriebsstunden-Perioden -->
    <div class="hz-perioden-block" style="margin-top: 14px;">
      <p class="hz-perioden-block__heading">Betriebsstunden-Perioden <span class="hz-badge hz-badge--optional">optional</span></p>
      <p class="hz-muted" style="font-size: 12.5px; margin-bottom: 8px;">
        Stundenzähler-Abschnitte eintragen (Differenz, nicht kumuliert). Leer = Einzelwerte oben.
      </p>
      <div class="hz-perioden-list" id="hz-bp-list" aria-live="polite">
        <p class="hz-muted hz-perioden-empty" style="font-style: italic; font-size: 13px;">Kein Perioden-Eintrag — Einzelwerte werden verwendet.</p>
      </div>
      <div class="hz-perioden-controls">
        <button type="button" class="hz-btn hz-btn-ghost" id="hz-bp-add">+ Periode hinzufügen</button>
      </div>
      <div class="hz-perioden-info" id="hz-bp-info"></div>
    </div>

    <div class="hz-method-alt" style="margin-top: 14px;">
      <p class="hz-muted" style="font-size: 13px; margin-bottom: 8px;">Alternative: Direktmessung (Wärmezähler / Kessel-Protokoll)</p>
      <div class="hz-grid-3">
        <label class="hz-field">
          <span class="hz-field__label">Qn pro Jahr (Messwert)</span>
          <div class="hz-field__input-with-unit">
            <input class="hz-field__input" type="number" step="100" min="0"
              data-hz-bind="heizlast.messung.qnPerJahr" data-hz-type="number" />
            <span class="hz-field__unit">kWh/a</span>
          </div>
          <small class="hz-muted">Wenn gesetzt, wird Messwert gegenüber Betriebsstunden bevorzugt.</small>
        </label>
      </div>

      <!-- Messung-Perioden -->
      <div class="hz-perioden-block" style="margin-top: 12px;">
        <p class="hz-perioden-block__heading">Messperioden (Wärmezähler) <span class="hz-badge hz-badge--optional">optional</span></p>
        <p class="hz-muted" style="font-size: 12.5px; margin-bottom: 8px;">
          Absolutwerte in kWh pro Periode. Leer = Jahreswert oben.
        </p>
        <div class="hz-perioden-list" id="hz-mp-list" aria-live="polite">
          <p class="hz-muted hz-perioden-empty" style="font-style: italic; font-size: 13px;">Kein Perioden-Eintrag — Jahreswert wird verwendet.</p>
        </div>
        <div class="hz-perioden-controls">
          <button type="button" class="hz-btn hz-btn-ghost" id="hz-mp-add">+ Periode hinzufügen</button>
        </div>
        <div class="hz-perioden-info" id="hz-mp-info"></div>
      </div>
    </div>
  </div>

  <!-- Methoden-Panel: Override -->
  <div class="hz-method-panel" id="hz-mp-override" data-method-panel="override" hidden>
    <p class="hz-muted hz-method__intro">Wenn bereits ein Qhl-Wert extern berechnet wurde (z. B. SIA 384/1).</p>
    <div class="hz-grid-3">
      <label class="hz-field">
        <span class="hz-field__label">Qhl</span>
        <div class="hz-field__input-with-unit">
          <input class="hz-field__input" type="number" step="0.1" min="0"
            data-hz-bind="heizlast.override.qhl" data-hz-type="number" />
          <span class="hz-field__unit">kW</span>
        </div>
      </label>
    </div>
  </div>

  <!-- Plausibilisierung: Pauschale nach Bauperiode (Anzeige, keine Rechnung) -->
  <div class="hz-bauperiode-info" style="margin-top: 18px;">
    <p class="hz-muted" style="font-size: 13px;">
      <strong>Plausibilisierung:</strong> Richtwert aus Bauperiode (Fallback wenn keine Methode ein Ergebnis liefert) —
      Typ + Bauperiode aus Sektion 1. Kein eigener Input nötig.
    </p>
    <div id="hz-plausi-info" class="hz-plausi-row"></div>
  </div>

  <!-- M4: Sanierungen -->
  <div class="hz-block" style="margin-top: 22px;">
    <h3 class="hz-block__heading">Durchgeführte oder geplante Sanierungen</h3>
    <div class="hz-san__list" id="hz-san-list" aria-live="polite">
      <p class="hz-muted hz-san__empty">Noch keine Massnahme gewählt.</p>
    </div>
    <div class="hz-san__controls">
      <label class="hz-field" style="flex: 1 1 260px;">
        <span class="hz-field__label">Massnahme hinzufügen</span>
        <select class="hz-field__input" id="hz-san-select">
          <option value="">— auswählen —</option>
          {SANIERUNGS_MASSNAHMEN.map((m) => (
            <option value={m.id} data-default={m.default} data-label={m.label}>{m.label} ({m.default} %)</option>
          ))}
        </select>
      </label>
      <button type="button" class="hz-btn hz-btn-ghost" id="hz-san-add">Hinzufügen</button>
    </div>
    <p class="hz-muted" style="margin-top: 8px; font-size: 13px;">
      Qhl wird multiplikativ reduziert, sobald mindestens eine Massnahme eingetragen ist.
      <br />
      <strong>Vergangene Sanierungen</strong> (mit Datum): werden bei Perioden-Messungen automatisch aus dem Messwert herausgerechnet.
      <strong>Geplante Sanierungen</strong>: klassischer multiplikativer Abzug am Schluss.
    </p>
  </div>

  <SectionNotes sectionKey="sektion2" sectionLabel="Sektion 2 (Heizlast)" />
</SectionWrapper>

<style is:global>
  /* Methoden-Radio-Leiste */
  .hz-method-tabs {
    display: flex; gap: 0; margin-bottom: 18px;
    border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    overflow: hidden;
    flex-wrap: wrap;
  }
  .hz-method-tab {
    flex: 1 1 auto;
    display: flex; align-items: center; justify-content: center;
    padding: 10px 16px;
    cursor: pointer;
    font-family: var(--hz-font-heading); font-weight: 600; font-size: 14px;
    color: var(--hz-mid-gray);
    background: var(--hz-white);
    border-right: 1px solid var(--hz-border);
    transition: background var(--hz-transition), color var(--hz-transition);
  }
  .hz-method-tab:last-child { border-right: 0; }
  .hz-method-tab input[type="radio"] { display: none; }
  .hz-method-tab:has(input:checked) {
    background: var(--hz-navy);
    color: var(--hz-white);
  }
  .hz-method-tab:hover:not(:has(input:checked)) { background: var(--hz-blue-tint); color: var(--hz-navy); }

  .hz-method-panel {
    padding: 16px 18px;
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-sm);
    background: var(--hz-white);
  }
  .hz-method__intro { margin-bottom: 14px; font-size: 14px; }
  .hz-method-alt {
    border-top: 1px dashed var(--hz-border);
    padding-top: 12px;
  }

  .hz-bauperiode-info {
    padding: 12px 14px;
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius-sm);
    background: var(--hz-off-white);
  }
  .hz-plausi-row {
    font-size: 13px; color: var(--hz-navy); font-family: var(--hz-font-heading); font-weight: 600;
  }

  .hz-switch { display: inline-flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--hz-mid-gray); }
  .hz-switch input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--hz-navy); }

  /* Sanierung */
  .hz-san__list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
  .hz-san__empty { padding: 6px 0; font-style: italic; font-size: 13.5px; }
  .hz-san__row {
    display: grid; grid-template-columns: 1fr 120px 44px; gap: 10px; align-items: center;
    padding: 8px 10px; border: 1px solid var(--hz-border); border-radius: 2px;
    background: var(--hz-white);
  }
  @media (max-width: 640px) {
    .hz-san__row {
      grid-template-columns: 1fr 44px;
      grid-template-areas: 'label remove' 'input input';
      row-gap: 8px;
    }
    .hz-san__row > .hz-san__row-label { grid-area: label; }
    .hz-san__row > .hz-san__remove { grid-area: remove; justify-self: end; }
    .hz-san__row > .hz-field__input-with-unit { grid-area: input; }
    .hz-san__controls { flex-direction: column; align-items: stretch; }
    .hz-san__controls > * { width: 100%; }
    .hz-method-tab { padding: 9px 10px; font-size: 13px; }
  }
  .hz-san__row-label { font-family: var(--hz-font-heading); font-weight: 600; color: var(--hz-navy); font-size: 14px; }
  .hz-san__row input[type="number"] {
    padding: 6px 8px; border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    font-family: var(--hz-font-body); font-size: 14px;
  }
  .hz-san__row input[type="number"]:focus { outline: 0; border-color: var(--hz-navy); }
  .hz-san__remove {
    border: 0; background: transparent; padding: 6px; color: var(--hz-mid-gray); border-radius: var(--hz-radius-sm);
  }
  .hz-san__remove:hover { color: var(--hz-red); background: var(--hz-red-soft); }
  .hz-san__controls { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; }

  /* Perioden-Block */
  .hz-perioden-block {
    padding: 12px 14px;
    border: 1px dashed var(--hz-border);
    border-radius: var(--hz-radius-sm);
    background: var(--hz-off-white);
  }
  .hz-perioden-block__heading {
    font-family: var(--hz-font-heading); font-weight: 600; font-size: 13.5px;
    color: var(--hz-navy); margin-bottom: 4px;
    display: flex; align-items: center; gap: 6px;
  }
  .hz-badge {
    display: inline-flex; align-items: center;
    padding: 1px 7px; border-radius: 12px; font-size: 11px; font-weight: 500;
    font-family: var(--hz-font-body);
  }
  .hz-badge--optional { background: var(--hz-blue-tint); color: var(--hz-navy); }

  .hz-perioden-list { display: flex; flex-direction: column; gap: 6px; margin-bottom: 8px; }

  .hz-perioden-row {
    display: grid;
    grid-template-columns: 130px 130px 110px 50px 44px;
    gap: 6px; align-items: center;
    padding: 6px 8px; border: 1px solid var(--hz-border); border-radius: 2px;
    background: var(--hz-white);
  }
  .hz-perioden-row input[type="date"],
  .hz-perioden-row input[type="number"] {
    padding: 5px 7px; border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    font-family: var(--hz-font-body); font-size: 13px; width: 100%;
    box-sizing: border-box;
  }
  .hz-perioden-row input:focus { outline: 0; border-color: var(--hz-navy); }
  .hz-perioden-tage { font-size: 12px; color: var(--hz-mid-gray); text-align: right; }
  .hz-perioden-row-label { font-size: 12px; color: var(--hz-mid-gray); }

  .hz-perioden-controls { display: flex; gap: 10px; align-items: center; }

  .hz-perioden-info {
    margin-top: 6px; font-size: 12.5px; color: var(--hz-navy);
    font-family: var(--hz-font-heading); font-weight: 600;
  }
  .hz-perioden-info.warn { color: var(--hz-red); }

  /* Sanierungen — erweiterte Zeile mit Datum + Zeitpunkt */
  .hz-san__row {
    grid-template-columns: 1fr 120px 130px 110px 44px;
  }
  .hz-san__row input[type="date"] {
    padding: 5px 7px; border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    font-family: var(--hz-font-body); font-size: 13px; width: 100%;
    box-sizing: border-box;
  }
  .hz-san__row select[data-san-field="zeitpunkt"] {
    padding: 5px 7px; border: 1px solid var(--hz-border); border-radius: var(--hz-radius-sm);
    font-family: var(--hz-font-body); font-size: 13px; width: 100%;
    box-sizing: border-box; background: var(--hz-white);
  }
  @media (max-width: 640px) {
    .hz-perioden-row {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        'von  bis'
        'wert tage'
        'rm   rm';
    }
    .hz-perioden-row > *:last-child { grid-area: rm; justify-self: end; }
    .hz-san__row {
      grid-template-columns: 1fr 44px;
      grid-template-areas: 'label remove' 'pct pct' 'datum datum' 'zp zp';
    }
    .hz-san__row > .hz-san__row-label { grid-area: label; }
    .hz-san__row > .hz-san__remove { grid-area: remove; justify-self: end; }
  }
</style>

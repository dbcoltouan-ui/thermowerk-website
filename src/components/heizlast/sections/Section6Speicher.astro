---
// Section 6 — Speicher (M8 + M9)
// Paket C:
//   C: WW-Speicher folgt warmwasser.active automatisch (kein eigener Toggle).
//      Puffer: Ja/Nein-Toggle wie Sperrzeit-Pattern. Bei Nein: Block versteckt.
//   F: Kein Kicker, keine Aside-KPIs, keine InfoBox.

import SectionWrapper from '../SectionWrapper.astro';
import SectionNotes from '../SectionNotes.astro';
import OverrideField from '../OverrideField.astro';
import { WW_SPEICHER_DEFAULTS } from '../../../lib/heizlast/constants.ts';
---
<SectionWrapper
  id="sektion-5"
  title="Speicher-Dimensionierung"
  subline="WW-Speicher nach FWS §10/11 und Heizungs-Pufferspeicher nach SWKI BT 102-01 / VDI 4645."
  tone="off"
>
  <div class="hz-storage-grid">
    <!-- WW-Speicher: folgt warmwasser.active (body.hz-ww-off versteckt den Block) -->
    <div class="hz-storage-card hz-ww-storage">
      <header class="hz-storage-card__head">
        <div>
          <h3 class="hz-storage-card__title">WW-Speicher</h3>
          <p class="hz-muted" style="margin: 0; font-size: 13px;">Trinkwarmwasser — Pufferung gegen Spitzenlast.</p>
        </div>
      </header>

      <div class="hz-grid-2">
        <OverrideField
          label="Speicher-Solltemperatur"
          symbol="Taus · °C"
          id="hz-ww-t-aus"
          bindPath="speicher.wwTStoAus"
          overridePath="speicher.wwTAustritt"
          defaultValue={WW_SPEICHER_DEFAULTS.tAustritt}
          unit="°C"
          source="FWS §10"
          type="number"
          step={1}
          min={40}
          max={80}
          hint="Legionellen-Hygiene: mind. 55 °C. Standard: 60 °C."
        />
        <OverrideField
          label="Kaltwasser-Eintrittstemperatur"
          symbol="Tein · °C"
          id="hz-ww-t-ein"
          bindPath="speicher.wwTStoEinOverride"
          overridePath="speicher.wwTEintritt"
          defaultValue={WW_SPEICHER_DEFAULTS.tEintritt}
          unit="°C"
          source="SIA 385/2"
          type="number"
          step={1}
          min={5}
          max={20}
          hint="Referenzwert Kaltwasser: 10 °C."
        />
      </div>

      <p class="hz-storage-recommendation hz-muted">
        Berechnungswert <strong><span data-hz-sum="wwSpeicherRoh">—</span> L</strong>
        &middot; Empfehlung <strong class="hz-rec-value"><span data-hz-sum="wwSpeicher">—</span> L</strong>
        <small>(marktübliche Staffelung)</small>
      </p>
    </div>

    <!-- Puffer: Ja/Nein-Toggle (Paket C) -->
    <div class="hz-storage-card">
      <header class="hz-storage-card__head">
        <div>
          <h3 class="hz-storage-card__title">Heizungs-Puffer</h3>
          <p class="hz-muted" style="margin: 0; font-size: 13px;">Entkoppelung und Reserve für Abtau / Taktung.</p>
        </div>
      </header>

      <label class="hz-switch hz-puffer-switch">
        <input type="checkbox" data-hz-bind="speicher.pufferActive" data-hz-type="boolean" />
        <span>Pufferspeicher berechnen?</span>
      </label>

      <div class="hz-puffer-block">
        <label class="hz-field" style="margin: 12px 0;">
          <span class="hz-field__label">Methode</span>
          <select class="hz-field__input" data-hz-bind="speicher.pufferMethod" data-hz-type="string">
            <option value="abtau">Abtau (L/W mit Prozessumkehr) — Standard CH</option>
            <option value="takt">Taktung (Mindestlaufzeit)</option>
            <option value="sperrzeit">Sperrzeit-Reserve (EVU-gesperrte Anlagen)</option>
            <option value="err">Erfahrungswert (l/kW-Band)</option>
          </select>
          <small class="hz-muted">
            In CH am häufigsten: <strong>Abtau</strong> (Luft-Wasser-WP).
            Für EVU-gesperrte Anlagen <strong>Sperrzeit-Reserve</strong>.
          </small>
        </label>

        <div class="hz-grid-2">
          <label class="hz-field">
            <span class="hz-field__label">t Abtau</span>
            <div class="hz-field__input-with-unit">
              <input class="hz-field__input" type="number" step="1" min="2" max="15"
                data-hz-bind="speicher.pufferTAbtauMin" data-hz-type="number" />
              <span class="hz-field__unit">min</span>
            </div>
          </label>
          <label class="hz-field">
            <span class="hz-field__label">t Takt</span>
            <div class="hz-field__input-with-unit">
              <input class="hz-field__input" type="number" step="1" min="2" max="20"
                data-hz-bind="speicher.pufferTTaktMin" data-hz-type="number" />
              <span class="hz-field__unit">min</span>
            </div>
          </label>
          <label class="hz-field">
            <span class="hz-field__label">ΔT Puffer</span>
            <div class="hz-field__input-with-unit">
              <input class="hz-field__input" type="number" step="1" min="3" max="10"
                data-hz-bind="speicher.pufferDeltaT" data-hz-type="number" />
              <span class="hz-field__unit">K</span>
            </div>
          </label>
        </div>

        <p class="hz-storage-recommendation hz-muted">
          Berechnungswert <strong><span data-hz-sum="pufferRoh">—</span> L</strong>
          &middot; Empfehlung <strong class="hz-rec-value"><span data-hz-sum="puffer">—</span> L</strong>
          <small>(marktübliche Staffelung)</small>
        </p>
      </div>
    </div>
  </div>

  <SectionNotes sectionKey="sektion6" sectionLabel="Sektion 6 (Speicher)" />
</SectionWrapper>

<style is:global>
  .hz-storage-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px;
  }
  @media (max-width: 780px) { .hz-storage-grid { grid-template-columns: 1fr; } }

  .hz-storage-card {
    padding: 20px 22px;
    background: var(--hz-white);
    border: 1px solid var(--hz-border);
    border-radius: 2px;
  }
  .hz-storage-card__head {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
    margin-bottom: 14px;
  }
  .hz-storage-card__title {
    font-family: var(--hz-font-heading); font-weight: 700; color: var(--hz-navy);
    margin: 0; font-size: 18px;
  }

  /* WW-Speicher folgt warmwasser.active */
  body.hz-ww-off .hz-ww-storage { display: none; }

  /* Puffer-Switch und Block */
  .hz-puffer-switch { margin-bottom: 4px; }
  /* Puffer-Block nur sichtbar wenn aktiv (body.hz-puffer-on) */
  body:not(.hz-puffer-on) .hz-puffer-block { display: none; }

  .hz-storage-recommendation {
    margin: 12px 0 0; padding: 10px 12px;
    border: 1px dashed var(--hz-border); border-radius: var(--hz-radius-md);
    font-size: 13.5px; line-height: 1.5;
    background: var(--hz-off-white);
  }
  .hz-storage-recommendation strong { color: var(--hz-navy); font-weight: 700; }
  .hz-storage-recommendation .hz-rec-value { color: var(--hz-red); }
  .hz-storage-recommendation small { display: block; margin-top: 2px; font-size: 12px; color: var(--hz-mid-gray); }
</style>

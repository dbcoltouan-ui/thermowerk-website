---
// Section 6 — Speicher (M8 + M9 nebeneinander)
// Zwei gleichwertige Karten: WW-Speicher | Heizungs-Puffer.
// Beide haben eigenen Aktiv-Schalter und eigene Parameter.

import SectionWrapper from '../SectionWrapper.astro';
import InfoBox from '../InfoBox.astro';
import KpiCard from '../KpiCard.astro';
import SectionNotes from '../SectionNotes.astro';
---
<SectionWrapper
  id="sektion-6"
  kicker="06 - Speicher"
  title="Speicher-Dimensionierung"
  subline="WW-Speicher nach FWS §10/11 und Heizungs-Pufferspeicher nach SWKI BT 102-01 / VDI 4645."
  tone="off"
>
  <slot name="aside" slot="aside">
    <div class="hz-kpi-grid" style="grid-template-columns: 1fr 1fr; min-width: 320px;">
      <KpiCard label="WW-Speicher" value="—" unit="L" data-kpi="wwSpeicher" />
      <KpiCard label="Puffer" value="—" unit="L" data-kpi="puffer" />
    </div>
  </slot>

  <div class="hz-storage-grid">
    <!-- WW-Speicher -->
    <div class="hz-storage-card">
      <header class="hz-storage-card__head">
        <div>
          <h3 class="hz-storage-card__title">WW-Speicher</h3>
          <p class="hz-muted" style="margin: 0; font-size: 13px;">Trinkwarmwasser — Pufferung gegen Spitzenlast.</p>
        </div>
        <label class="hz-switch">
          <input type="checkbox" data-hz-bind="speicher.wwActive" data-hz-type="boolean" />
          <span>aktiv</span>
        </label>
      </header>

      <div class="hz-grid-2">
        <label class="hz-field">
          <span class="hz-field__label">Speicher-Austrittstemperatur</span>
          <div class="hz-field__input-with-unit">
            <input class="hz-field__input" type="number" step="1" min="40" max="80"
              data-hz-bind="speicher.wwTStoAus" data-hz-type="number" />
            <span class="hz-field__unit">°C</span>
          </div>
        </label>
        <label class="hz-field">
          <span class="hz-field__label">Eintritt (Kaltwasser) — Override</span>
          <div class="hz-field__input-with-unit">
            <input class="hz-field__input" type="number" step="1" min="5" max="20"
              placeholder="10 (SIA 385/2)"
              data-hz-bind="speicher.wwTStoEinOverride" data-hz-type="number" />
            <span class="hz-field__unit">°C</span>
          </div>
        </label>
      </div>

      <fieldset class="hz-radio-group">
        <legend>Rundung</legend>
        <label><input type="radio" name="ww-round" value="5"
          data-hz-bind="speicher.wwRundungLiter" data-hz-type="number" /> 5-L-Schritte</label>
        <label><input type="radio" name="ww-round" value="10"
          data-hz-bind="speicher.wwRundungLiter" data-hz-type="number" /> 10-L-Schritte</label>
      </fieldset>
    </div>

    <!-- Puffer -->
    <div class="hz-storage-card">
      <header class="hz-storage-card__head">
        <div>
          <h3 class="hz-storage-card__title">Heizungs-Puffer</h3>
          <p class="hz-muted" style="margin: 0; font-size: 13px;">Entkoppelung und Reserve für Abtau / Taktung.</p>
        </div>
        <label class="hz-switch">
          <input type="checkbox" data-hz-bind="speicher.pufferActive" data-hz-type="boolean" />
          <span>aktiv</span>
        </label>
      </header>

      <label class="hz-field" style="margin-bottom: 12px;">
        <span class="hz-field__label">Methode</span>
        <select class="hz-field__input" data-hz-bind="speicher.pufferMethod" data-hz-type="string">
          <option value="abtau">Abtau (L/W mit Prozessumkehr)</option>
          <option value="takt">Taktung (Mindestlaufzeit)</option>
          <option value="err">Erfahrungswert (l/kW-Band)</option>
          <option value="sperrzeit">Sperrzeit-Reserve</option>
        </select>
      </label>

      <div class="hz-grid-2">
        <label class="hz-field">
          <span class="hz-field__label">t Abtau</span>
          <div class="hz-field__input-with-unit">
            <input class="hz-field__input" type="number" step="1" min="2" max="15"
              data-hz-bind="speicher.pufferTAbtauMin" data-hz-type="number" />
            <span class="hz-field__unit">min</span>
          </div>
        </label>
        <label class="hz-field">
          <span class="hz-field__label">t Takt</span>
          <div class="hz-field__input-with-unit">
            <input class="hz-field__input" type="number" step="1" min="2" max="20"
              data-hz-bind="speicher.pufferTTaktMin" data-hz-type="number" />
            <span class="hz-field__unit">min</span>
          </div>
        </label>
        <label class="hz-field">
          <span class="hz-field__label">ΔT Puffer</span>
          <div class="hz-field__input-with-unit">
            <input class="hz-field__input" type="number" step="1" min="3" max="10"
              data-hz-bind="speicher.pufferDeltaT" data-hz-type="number" />
            <span class="hz-field__unit">K</span>
          </div>
        </label>
      </div>

      <fieldset class="hz-radio-group">
        <legend>Rundung</legend>
        <label><input type="radio" name="puffer-round" value="5"
          data-hz-bind="speicher.pufferRundungLiter" data-hz-type="number" /> 5-L-Schritte</label>
        <label><input type="radio" name="puffer-round" value="10"
          data-hz-bind="speicher.pufferRundungLiter" data-hz-type="number" /> 10-L-Schritte</label>
      </fieldset>
    </div>
  </div>

  <InfoBox title="Referenzen" icon="book">
    <p><strong>WW-Speicher</strong>: FWS Modul 3 §10 / §11 (SIA 385/2 für Nutzwarmwasser-Bedarf).</p>
    <p><strong>Heizungs-Puffer</strong>: SWKI BT 102-01, VDI 4645, sowie Hersteller-Empfehlungen.
       Das <em>Erfahrungswert-Band</em> 15–25 l/kW (L/W mit Abtau) stammt aus SWKI.</p>
  </InfoBox>

  <SectionNotes sectionKey="sektion6" sectionLabel="Sektion 6 (Speicher)" />
</SectionWrapper>

<style is:global>
  .hz-storage-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px;
  }
  @media (max-width: 780px) { .hz-storage-grid { grid-template-columns: 1fr; } }

  .hz-storage-card {
    padding: 20px 22px;
    background: var(--hz-white);
    border: 1px solid var(--hz-border);
    border-radius: 2px;
  }
  .hz-storage-card__head {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
    margin-bottom: 16px;
  }
  .hz-storage-card__title {
    font-family: var(--hz-font-heading); font-weight: 700; color: var(--hz-navy);
    margin: 0; font-size: 18px;
  }

  .hz-radio-group {
    border: 0; padding: 0; margin: 12px 0 0;
    display: flex; gap: 14px; flex-wrap: wrap;
  }
  .hz-radio-group legend {
    font-family: var(--hz-font-heading); font-weight: 600; font-size: 13px;
    color: var(--hz-mid-gray); letter-spacing: 0.05em; text-transform: uppercase;
    margin-bottom: 6px;
  }
  .hz-radio-group label { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: var(--hz-dark); }
  .hz-radio-group input[type="radio"] { accent-color: var(--hz-navy); }
</style>

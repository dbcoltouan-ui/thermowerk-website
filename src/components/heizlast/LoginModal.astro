---
// LoginModal — Anmeldung per Passwort (Heizlast-Cloud).
// Wird durch uiState.authModalOpen sichtbar (siehe heizlast.astro Wire-up).
// POST /api/heizlast-auth setzt HttpOnly-Cookie; DELETE /api/heizlast-auth meldet ab.
---
<div
  class="hz-modal"
  id="hz-login-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="hz-login-modal-title"
  hidden
>
  <div class="hz-modal__backdrop" data-hz-modal-dismiss></div>
  <div class="hz-modal__card hz-modal__card--narrow">
    <header class="hz-modal__head">
      <div>
        <p class="hz-kicker">Cloud-Zugang</p>
        <h2 class="hz-modal__title" id="hz-login-modal-title">Anmelden</h2>
      </div>
      <button
        type="button"
        class="hz-modal__close"
        data-hz-modal-dismiss
        aria-label="Schliessen"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </header>

    <!-- Anmelde-Ansicht -->
    <section class="hz-modal__body" data-hz-login-view="signin">
      <p class="hz-modal__lead">
        Das Passwort schaltet die Cloud-Funktionen frei: Projekte speichern,
        laden und loeschen. Ohne Anmeldung funktioniert der Rechner lokal wie gewohnt.
      </p>

      <form class="hz-modal__form" id="hz-login-form" autocomplete="off">
        <label class="hz-field">
          <span class="hz-field__label">Passwort</span>
          <input
            type="password"
            id="hz-login-password"
            class="hz-field__input"
            required
            autocomplete="current-password"
            placeholder="Cloud-Passwort"
          />
        </label>

        <div class="hz-modal__error" id="hz-login-error" hidden aria-live="polite"></div>

        <div class="hz-modal__actions">
          <button
            type="button"
            class="hz-btn hz-btn-ghost"
            data-hz-modal-dismiss
          >Abbrechen</button>
          <button
            type="submit"
            class="hz-btn hz-btn-primary"
            id="hz-login-submit"
          >Anmelden</button>
        </div>
      </form>
    </section>

    <!-- Abmelde-Ansicht (wird eingeblendet, wenn bereits authentifiziert) -->
    <section class="hz-modal__body" data-hz-login-view="signout" hidden>
      <p class="hz-modal__lead">
        Sie sind angemeldet. Cloud-Projekte koennen gespeichert, geladen und
        geloescht werden. Beim Abmelden wird der Auth-Cookie geloescht; lokal
        gespeicherte Eingaben bleiben erhalten.
      </p>

      <div class="hz-modal__error" id="hz-logout-error" hidden aria-live="polite"></div>

      <div class="hz-modal__actions">
        <button
          type="button"
          class="hz-btn hz-btn-ghost"
          data-hz-modal-dismiss
        >Schliessen</button>
        <button
          type="button"
          class="hz-btn hz-btn-danger-soft"
          id="hz-logout-submit"
        >Abmelden</button>
      </div>
    </section>
  </div>
</div>

<style is:global>
  /* ----- Basis-Modal (wird auch von ProjectsModal + ExportModal verwendet) ----- */
  .hz-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .hz-modal[hidden] { display: none !important; }
  .hz-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 29, 51, 0.55);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    animation: hz-modal-fade-in 160ms ease-out;
  }
  .hz-modal__card {
    position: relative;
    background: var(--hz-white);
    border-radius: var(--hz-radius-lg);
    box-shadow: var(--hz-shadow-hero);
    max-width: 640px;
    width: 100%;
    max-height: calc(100vh - 40px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    animation: hz-modal-card-in 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hz-modal__card--narrow { max-width: 460px; }
  .hz-modal__card--wide   { max-width: 880px; }

  @keyframes hz-modal-fade-in {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes hz-modal-card-in {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hz-modal__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 22px 24px 14px;
    border-bottom: 1px solid var(--hz-border);
  }
  .hz-modal__head .hz-kicker { margin: 0 0 4px; }
  .hz-modal__title {
    font-family: var(--hz-font-heading);
    font-weight: 700;
    color: var(--hz-navy);
    font-size: clamp(20px, 2.4vw, 24px);
    margin: 0;
    line-height: 1.2;
  }
  .hz-modal__close {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 50%;
    background: transparent; border: 1px solid var(--hz-border);
    color: var(--hz-mid-gray);
    transition: all var(--hz-transition);
    flex-shrink: 0;
  }
  .hz-modal__close:hover {
    color: var(--hz-navy);
    border-color: var(--hz-navy);
    background: var(--hz-off-white);
  }

  .hz-modal__body {
    padding: 18px 24px 22px;
    overflow-y: auto;
    flex: 1 1 auto;
  }
  .hz-modal__lead {
    margin: 0 0 16px;
    color: var(--hz-mid-gray);
    font-size: 14.5px;
    line-height: 1.55;
  }

  .hz-modal__form { display: flex; flex-direction: column; gap: 14px; }
  .hz-modal__form .hz-field { display: flex; flex-direction: column; gap: 6px; }
  .hz-modal__form .hz-field__label {
    font-family: var(--hz-font-heading);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--hz-navy);
  }
  .hz-modal__form .hz-field__input {
    padding: 10px 12px;
    border-radius: var(--hz-radius-sm);
    border: 1.5px solid var(--hz-border);
    background: var(--hz-white);
    font-size: 15px;
    transition: border-color var(--hz-transition), box-shadow var(--hz-transition);
  }
  .hz-modal__form .hz-field__input:focus {
    outline: none;
    border-color: var(--hz-navy);
    box-shadow: 0 0 0 3px rgba(27, 42, 74, 0.12);
  }

  .hz-modal__error {
    background: var(--hz-red-soft);
    color: #7a1d16;
    border: 1px solid rgba(217, 48, 37, 0.35);
    border-radius: var(--hz-radius-sm);
    padding: 10px 12px;
    font-size: 13.5px;
  }

  .hz-modal__actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding-top: 6px;
    flex-wrap: wrap;
  }

  @media (max-width: 560px) {
    .hz-modal { padding: 12px; }
    .hz-modal__head { padding: 18px 18px 12px; }
    .hz-modal__body { padding: 14px 18px 18px; }
    .hz-modal__actions .hz-btn { flex: 1 1 auto; }
  }

  /* Body-Scroll-Lock wenn Modal offen */
  body.hz-modal-open { overflow: hidden; }
</style>

---
// InfoBox — dezent-klappbares Info-Panel (Variante A).
// - Trigger: Zeile mit Info-Icon, Titel, Chevron rechts.
// - Inhalt: klappt sauber auf (max-height Transition), zweispaltig moeglich via .hz-info__grid.
// - Blue-tint Hintergrund (#E8EDF5), dunkler Border bei Fokus.
// - Funktioniert rein mit <details>, daher auch ohne JS zugaenglich.

interface Props {
  /** Titel der Info-Box */
  title: string;
  /** Optionaler Untertitel neben dem Titel, z.B. "FWS-Referenz" */
  subtitle?: string;
  /** Standardmaessig geschlossen; true = initial offen */
  open?: boolean;
  /** Icon-Variante: 'info' (Standard), 'book' (Norm/Referenz), 'help' (Fragezeichen) */
  icon?: 'info' | 'book' | 'help';
}

const { title, subtitle, open = false, icon = 'info' } = Astro.props;
---
<details class="hz-info" open={open}>
  <summary class="hz-info__summary" aria-label={`Info: ${title}`}>
    <span class="hz-info__icon" aria-hidden="true">
      {icon === 'info' && (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
      )}
      {icon === 'book' && (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
        </svg>
      )}
      {icon === 'help' && (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
      )}
    </span>
    <span class="hz-info__labels">
      <span class="hz-info__title">{title}</span>
      {subtitle ? <span class="hz-info__subtitle">{subtitle}</span> : null}
    </span>
    <span class="hz-info__chevron" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </span>
  </summary>

  <div class="hz-info__content">
    <slot />
  </div>
</details>

<style is:global>
  .hz-info {
    background: var(--hz-blue-tint);
    border: 1px solid var(--hz-blue-tint-strong);
    border-radius: var(--hz-radius-md);
    overflow: hidden;
    transition: border-color var(--hz-transition), box-shadow var(--hz-transition);
  }
  .hz-info + .hz-info { margin-top: 12px; }

  .hz-info__summary {
    list-style: none;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    cursor: pointer;
    user-select: none;
  }
  .hz-info__summary::-webkit-details-marker { display: none; }
  .hz-info__summary:focus-visible {
    outline: 2px solid var(--hz-navy);
    outline-offset: 2px;
    border-radius: var(--hz-radius-md);
  }

  .hz-info__icon {
    color: var(--hz-navy);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: var(--hz-white);
    border: 1px solid var(--hz-blue-tint-strong);
    border-radius: 999px;
  }
  .hz-info__labels { display: flex; flex-direction: column; min-width: 0; }
  .hz-info__title {
    font-family: var(--hz-font-heading);
    font-weight: 600;
    color: var(--hz-navy);
    font-size: 15.5px;
    line-height: 1.3;
  }
  .hz-info__subtitle {
    font-size: 13px;
    color: var(--hz-mid-gray);
    margin-top: 2px;
  }
  .hz-info__chevron {
    color: var(--hz-mid-gray);
    transition: transform var(--hz-transition), color var(--hz-transition);
    display: inline-flex;
  }
  .hz-info[open] .hz-info__chevron {
    transform: rotate(180deg);
    color: var(--hz-navy);
  }
  .hz-info[open] {
    border-color: var(--hz-navy-light);
    box-shadow: var(--hz-shadow-sm);
  }

  .hz-info__content {
    padding: 4px 16px 18px 54px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--hz-dark);
  }
  .hz-info__content p { margin-bottom: 10px; }
  .hz-info__content p:last-child { margin-bottom: 0; }
  .hz-info__content strong { color: var(--hz-navy); font-weight: 600; }
  .hz-info__content a { color: var(--hz-navy); border-bottom: 1px solid var(--hz-navy-light); }

  /* zweispaltiges Grid fuer "Abkuerzungen erklaert" */
  .hz-info__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px 20px;
    margin-top: 8px;
  }
  .hz-info__grid dt {
    font-family: var(--hz-font-heading);
    font-weight: 600;
    color: var(--hz-navy);
    font-size: 13.5px;
    letter-spacing: 0.02em;
  }
  .hz-info__grid dd {
    color: var(--hz-mid-gray);
    font-size: 14px;
    margin-left: 0;
    margin-bottom: 4px;
  }

  @media (max-width: 560px) {
    .hz-info__content { padding-left: 16px; }
  }
</style>

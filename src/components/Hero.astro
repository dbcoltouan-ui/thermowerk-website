---
// Hero-Section – dunkler Overlay-Stil mit gestaffelter H1
---
<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/img/hero-desktop.jpeg" alt="Wärmepumpe Beratung vor Ort" class="hero-img-desktop">
    <img src="/img/hero-mobile.jpeg" alt="Wärmepumpe Service" class="hero-img-mobile">
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <div class="hero-content">
      <h1 class="fade-up">Ihre Wärmepumpe.<br><span class="h1-step2">Ihre Klimaanlage.</span><br><span class="h1-step3">Unser Handwerk.</span></h1>
      <div class="hero-box">
        <p class="hero-subtitle fade-up">Mit kompletter Förderabwicklung.</p>
        <p class="hero-text fade-up">WPSM-zertifiziert. Von der Beratung bis zur Förderabwicklung — alles aus einer Hand.</p>
        <div class="hero-buttons fade-up">
          <a href="#contact" class="btn btn-primary">Beratung anfragen</a>
          <a href="#calculator" class="btn btn-outline-dark">Kostenrechner</a>
        </div>
      </div>
    </div>
  </div>
</section>

---
// Section 2 v2 — Heizlast
// Port aus Mockup (Zeilen ~1951–2253). Vier exklusive Methoden (M1..M4)
// via <details name="heizlast-method">, darunter Addon-Block Sanierung
// und Plausi-Quercheck.
//
// State-Bindings:
//   - M1: heizlast.verbrauch.{energietraeger, ba, inklWW, vwuAbzug, perioden[]}
//   - M2: heizlast.messung.perioden[]
//   - M3: heizlast.bstd.perioden[]
//   - M4: heizlast.override.qhl
//   - Addon: heizlast.sanierungActive, heizlast.sanierungMassnahmen[]
//
// Perioden-Listen werden im Glue-JS von heizlast.astro gerendert (Event-Delegation).
// Die methodsEnabled-Flags werden aus dem "toggle"-Event der <details> gespiegelt.

import SectionWrapper from '../SectionWrapper.astro';
import Method from '../Method.astro';
import Notes from '../Notes.astro';
import Plausi from '../Plausi.astro';
import OverrideField from '../OverrideField.astro';
import { BRENNWERTE, SANIERUNGS_MASSNAHMEN } from '../../../lib/heizlast/constants.ts';

const brennwerteArr = Object.entries(BRENNWERTE).map(([id, b]) => ({ id, label: b.label, einheit: b.verbrauchEinheit }));
---
<SectionWrapper
  anchor="sektion-2"
  title="Heizlast"
  intro="Empfohlen ist der <strong>Brennstoffverbrauch</strong> über mindestens eine Heizperiode. Wer andere Daten hat (Zählermessung, Betriebsstunden, oder einen Wert aus einer externen Berechnung), klappt die entsprechende Karte auf — die geöffnete Methode wird verwendet, alle anderen schliessen automatisch. Eingetragene Daten bleiben erhalten und werden bei erneutem Öffnen wieder gezeigt."
>

  <div class="methods">

    {/* M1 — Brennstoffverbrauch */}
    <Method
      method="verbrauch"
      num="M1"
      title="Brennstoffverbrauch"
      badge="empfohlen"
      status={'<span data-hz-sum="verbrauchPerioden">– Perioden</span> · <strong>Q<sub>hl</sub> = <span data-kpi="qhlVerbrauch">–</span> kW</strong>'}
      openDefault={true}
    >
      {/* WW im Verbrauch enthalten? */}
      <div class="ww-incl" data-on="true">
        <label class="switch">
          <input type="checkbox" data-hz-bind="heizlast.verbrauch.inklWW" data-hz-type="boolean" />
          <span class="switch__track"></span>
          <span><strong>Warmwasser ist im Verbrauch enthalten</strong> — aus der Heizlast herausrechnen</span>
        </label>
        <div class="ww-incl__body">
          <div class="grid grid--2">
            <div class="field">
              <label class="field__label" for="f-vwuAbzug">
                Warmwasser-Abzug
                <span class="symbol">V<sub>wu</sub></span>
                <span class="chip">Standard · 200 L / Tag</span>
              </label>
              <div class="input-group">
                <input class="input" id="f-vwuAbzug" type="number" data-hz-bind="heizlast.verbrauch.vwuAbzug" data-hz-type="number" />
                <span class="input-group__unit">L / Tag</span>
              </div>
              <p class="field__hint">
                Tagesbedarf für Warmwasser, wird aus der gemessenen Brennstoffmenge
                rausgerechnet.
              </p>
            </div>
            <div class="field">
              <label class="field__label">
                Wirkung auf <span class="symbol">Q<sub>hl</sub></span>
              </label>
              <div class="inline-result" style="margin-top: 0;">
                <span>Abzug entspricht</span>
                <span><span class="inline-result__value" data-hz-sum="vwuAbzugWirkung">–</span><span class="inline-result__unit">kW</span></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="periods" data-hz-periods="verbrauch">
        <div class="periods__head period-consumption">
          <span>Von</span><span>Bis</span><span>Brennstoff</span><span>Menge</span><span></span>
        </div>
        <div class="periods__list" data-hz-periods-list="verbrauch"></div>
      </div>
      <button class="periods__add" type="button" data-hz-action="add-period" data-period-kind="verbrauch">
        <svg class="icon--sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Periode hinzufügen
      </button>

      <div class="inline-result">
        <span>Mittlere Heizlast über <span data-hz-sum="verbrauchPerioden">–</span></span>
        <span><span class="inline-result__value" data-kpi="qhlVerbrauch">–</span><span class="inline-result__unit">kW</span></span>
      </div>

      {/* Verstecktes Template fuer Glue-JS, damit Label-Array nicht im Script dupliziert wird */}
      <template data-hz-brennwerte>
        {brennwerteArr.map((b) => (
          <option value={b.id} data-einheit={b.einheit}>{b.label}</option>
        ))}
      </template>
    </Method>

    {/* M2 — Zaehlermessung */}
    <Method
      method="messung"
      num="M2"
      title="Zählermessung"
      status={'<span data-hz-sum="messungPerioden">keine Perioden</span>'}
    >
      <div class="periods" data-hz-periods="messung">
        <div class="periods__head period-meter">
          <span>Von</span><span>Bis</span><span>Stand Anfang</span><span>Stand Ende</span><span></span>
        </div>
        <div class="periods__list" data-hz-periods-list="messung"></div>
      </div>
      <button class="periods__add" type="button" data-hz-action="add-period" data-period-kind="messung">
        <svg class="icon--sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Periode hinzufügen
      </button>
    </Method>

    {/* M3 — Betriebsstunden */}
    <Method
      method="bstd"
      num="M3"
      title="Betriebsstunden"
      status={'<span data-hz-sum="bstdPerioden">keine Perioden</span>'}
    >
      <div class="periods" data-hz-periods="bstd">
        <div class="periods__head period-bstd">
          <span>Von</span><span>Bis</span><span>Nennleistung</span><span>Betriebsstunden</span><span></span>
        </div>
        <div class="periods__list" data-hz-periods-list="bstd"></div>
      </div>
      <button class="periods__add" type="button" data-hz-action="add-period" data-period-kind="bstd">
        <svg class="icon--sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Periode hinzufügen
      </button>
    </Method>

    {/* M4 — Direkteingabe / Override */}
    <Method
      method="override"
      num="M4"
      title="Direkteingabe"
      status={'<span data-hz-sum="overrideStatus">nicht verwendet</span>'}
    >
      <div class="grid grid--2">
        <div class="field">
          <label class="field__label" for="f-qhl-direct">Heizlast <span class="symbol">Q<sub>hl</sub></span></label>
          <div class="input-group">
            <input class="input" id="f-qhl-direct" type="number" placeholder="z. B. 12.5" step="0.1" data-hz-bind="heizlast.override.qhl" data-hz-type="number" />
            <span class="input-group__unit">kW</span>
          </div>
          <p class="field__hint">
            Direkter Zahlenwert — z. B. aus einer externen Berechnung übernommen.
          </p>
        </div>
      </div>
    </Method>

  </div>

  {/* Sanierungs-Massnahmen — Addon */}
  <details class="addon" open data-hz-addon="sanierung">
    <summary class="addon__head">
      <svg class="addon__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
      <span class="addon__title">Sanierungs-Massnahmen</span>
      <span class="addon__status" data-hz-sum="sanierungStatus">keine Massnahmen</span>
    </summary>
    <div class="addon__body">
      {/* Addon-Gate ueber verstecktes Checkbox */}
      <input type="checkbox" hidden data-hz-bind="heizlast.sanierungActive" data-hz-type="boolean" data-hz-addon-input />

      <p class="addon__intro">
        Jede Massnahme reduziert die berechnete Heizlast prozentual.
        Mehrere Massnahmen werden multiplikativ kombiniert.
        Bereits umgesetzte Massnahmen werden bei Verbrauchsmethoden rückgerechnet.
      </p>

      <div class="measures">
        <div class="periods__head" style="grid-template-columns: 1.4fr 110px 1fr 32px;">
          <span>Massnahme</span><span>Einsparung</span><span>Zeitpunkt</span><span></span>
        </div>
        <div class="measures__list" data-hz-sanierung-list></div>
      </div>
      <button class="periods__add" type="button" data-hz-action="add-sanierung">
        <svg class="icon--sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Massnahme hinzufügen
      </button>

      <div class="inline-result">
        <span>Kombinierte Einsparung</span>
        <span><span class="inline-result__value" data-hz-sum="sanierungDelta">0</span><span class="inline-result__unit">%</span></span>
      </div>

      <template data-hz-sanierungen-template>
        {SANIERUNGS_MASSNAHMEN.map((m) => (
          <option value={m.id} data-default={m.default}>{m.label}</option>
        ))}
      </template>
    </div>
  </details>

  <Plausi />

  <Notes
    sectionKey="sektion2"
    label="Notiz zur Heizlast"
    placeholder="Freitext zu Rechenmethode, Quellen, Annahmen."
  />

</SectionWrapper>

---
// Section 1 v2 — Projekt & Gebaeude
// Port aus mockups/section-1.html (Zeilen 1682–1946).
// Nutzt das neue Token-Set (--ink-*, --accent), Komponenten-Primitives
// aus heizlast-v2/ und die bestehenden State-Pfade aus lib/heizlast.

import SectionWrapper from '../SectionWrapper.astro';
import Notes from '../Notes.astro';
import OverrideField from '../OverrideField.astro';
import { BAUPERIODEN } from '../../../lib/heizlast/constants.ts';

// Gebaeudetypen — Labels inline (gibt keine Konstante dafuer).
const GEBAEUDETYPEN: Array<{ id: 'efh' | 'mfh' | 'buero'; label: string }> = [
  { id: 'efh',   label: 'Einfamilienhaus (EFH)' },
  { id: 'mfh',   label: 'Mehrfamilienhaus (MFH)' },
  { id: 'buero', label: 'Bürogebäude' },
];

// Lage — Labels inline.
const LAGEN: Array<{ id: 'mittelland' | 'hoehe'; label: string }> = [
  { id: 'mittelland', label: 'Mittelland (≤ 800 m ü. M.)' },
  { id: 'hoehe',      label: 'Höhenlage (> 800 m ü. M.)' },
];

// Tvoll-Profile — Labels inline.
const TVOLL_PROFILE: Array<{ id: 'wohnen_ohneWW' | 'wohnen_mitWW' | 'gewerbe_absenkung'; label: string }> = [
  { id: 'wohnen_ohneWW',     label: 'Wohngebäude ohne Warmwasser' },
  { id: 'wohnen_mitWW',      label: 'Wohngebäude mit Warmwasser' },
  { id: 'gewerbe_absenkung', label: 'Gewerbe mit Nachtabsenkung' },
];
---
<SectionWrapper anchor="sektion-1" title="Projekt & Gebäude">

  {/* ============ Projekt ============ */}
  <div class="block">
    <div class="block__head">
      <h2 class="block__title">Projekt</h2>
    </div>

    <div class="grid grid--2">
      <div class="field">
        <label class="field__label" for="f-projectName">Projektname</label>
        <input class="input" id="f-projectName" type="text" data-hz-bind="projectName" data-hz-type="string" />
      </div>
      <div class="field">
        <label class="field__label" for="f-customer">Kunde</label>
        <input class="input" id="f-customer" type="text" data-hz-bind="customerName" data-hz-type="string" />
      </div>
      <div class="field">
        <label class="field__label" for="f-address">Anschrift</label>
        <input class="input" id="f-address" type="text" data-hz-bind="address" data-hz-type="string" />
      </div>
      <div class="field">
        <label class="field__label" for="f-status">Status</label>
        <select class="select" id="f-status" data-hz-bind="status" data-hz-type="string">
          <option value="arbeit">In Arbeit</option>
          <option value="offeriert">Offeriert</option>
          <option value="bestellt">Bestellt</option>
          <option value="abgeschlossen">Abgeschlossen</option>
          <option value="archiv">Archiv</option>
        </select>
      </div>
    </div>
  </div>

  {/* ============ Gebaeude ============ */}
  <div class="block">
    <div class="block__head">
      <h2 class="block__title">Gebäude & Standort</h2>
      <span class="block__hint">Grundlage für Richtwerte und Plausibilisierung.</span>
    </div>

    {/* Reihe 1: Typ | Lage | Bauperiode */}
    <div class="grid grid--3">
      <div class="field">
        <label class="field__label" for="f-typ">Gebäudetyp</label>
        <select class="select" id="f-typ" data-hz-bind="gebaeude.typ" data-hz-type="string">
          {GEBAEUDETYPEN.map((t) => (
            <option value={t.id}>{t.label}</option>
          ))}
        </select>
      </div>
      <div class="field">
        <label class="field__label" for="f-lage">Lage</label>
        <select class="select" id="f-lage" data-hz-bind="gebaeude.lage" data-hz-type="string">
          {LAGEN.map((l) => (
            <option value={l.id}>{l.label}</option>
          ))}
        </select>
      </div>
      <div class="field">
        <label class="field__label" for="f-bauperiode">Bauperiode</label>
        <select class="select" id="f-bauperiode" data-hz-bind="gebaeude.bauperiode" data-hz-type="string">
          {BAUPERIODEN.map((b) => (
            <option value={b.id}>{b.label}</option>
          ))}
        </select>
      </div>
    </div>

    {/* Reihe 2: EBF + Zimmer-Helfer-Button */}
    <div class="grid grid--2" style="margin-top: var(--s-5);">
      <div class="field">
        <label class="field__label" for="f-ebf">
          Energiebezugsfläche
          <span class="symbol">EBF</span>
        </label>
        <div class="ebf__row">
          <div class="input-group">
            <input class="input" id="f-ebf" type="number" step="1" min="1" max="10000" data-hz-bind="gebaeude.ebf" data-hz-type="number" />
            <span class="input-group__unit">m²</span>
          </div>
          <button
            class="link-btn"
            type="button"
            aria-expanded="false"
            data-hz-action="toggle-zimmer"
          >
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="1" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="12" y1="3" x2="12" y2="21" />
            </svg>
            Zimmer / Flächen
          </button>
        </div>
        <p class="field__hint">
          Fläche manuell eintragen oder aus der Zimmerliste berechnen lassen.
        </p>
      </div>
      <div class="field" aria-hidden="true"></div>
    </div>

    {/* Zimmer-Panel — wird via display:none gesteuert (CSS-Klasse .is-hidden) */}
    <div class="zimmer is-hidden" role="region" aria-label="Zimmer-Helfer" data-hz-zimmer-panel>
      <div class="zimmer__head">
        <h3 class="zimmer__title">Zimmer / Flächen</h3>
        <span class="zimmer__meta" data-hz-zimmer-meta>0 Räume</span>
      </div>

      <table class="z-table">
        <thead>
          <tr>
            <th>Bezeichnung</th>
            <th class="col-num">Länge (m)</th>
            <th class="col-num">Breite (m)</th>
            <th class="col-num-direct">Direkt (m²)</th>
            <th class="col-area">Fläche</th>
            <th class="col-chk">Beheizt</th>
            <th class="col-act" aria-label="Aktion"></th>
          </tr>
        </thead>
        <tbody data-hz-raum-list></tbody>
      </table>

      <button class="zimmer__add" type="button" data-hz-action="add-raum">
        <svg class="icon--sm" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19" />
          <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Zimmer hinzufügen
      </button>

      <div class="zimmer__foot">
        <div class="zimmer__sum">
          <span>Beheizt: <strong data-hz-zimmer-sum="beheizt">0.0 m²</strong></span>
          <span class="sep">·</span>
          <span>Unbeheizt: <strong data-hz-zimmer-sum="unbeheizt">0.0 m²</strong></span>
          <span class="sep">·</span>
          <span>Netto-EBF: <strong data-hz-zimmer-sum="netto">0.0 m²</strong></span>
        </div>
        <div class="zimmer__actions">
          <button class="btn" type="button" data-hz-action="close-zimmer">Schliessen</button>
          <button class="btn btn--dark" type="button" data-hz-action="apply-zimmer">In EBF übernehmen</button>
        </div>
      </div>
    </div>

    {/* Reihe 3: Nutzungsprofil | Vollbetriebsstunden */}
    <div class="grid grid--2" style="margin-top: var(--s-7);">
      <div class="field">
        <label class="field__label" for="f-profil">Nutzungsprofil</label>
        <select class="select" id="f-profil" data-hz-bind="gebaeude.tvollProfil" data-hz-type="string">
          {TVOLL_PROFILE.map((p) => (
            <option value={p.id}>{p.label}</option>
          ))}
        </select>
        <p class="field__hint">
          Bestimmt zusammen mit der Lage den Richtwert für die Vollbetriebsstunden.
        </p>
      </div>

      <OverrideField
        id="f-tvoll"
        label="Vollbetriebsstunden"
        symbol="t<sub>voll</sub>"
        chip="Standard · FWS"
        unit="h / a"
        bindPath="gebaeude.tvollOverride"
        overridePath="gebaeude.tvoll"
        step="10"
        min={500}
        max={3500}
        hint="Wird aus Nutzungsprofil und Lage vorbelegt. Beim Überschreiben erscheint ein Reset-Pfeil, der den Standardwert wiederherstellt."
      />
    </div>
  </div>

  {/* ============ Notes ============ */}
  <Notes
    sectionKey="sektion1"
    label="Notiz zu Projekt & Gebäude"
    placeholder="Freitext für diese Sektion. Wird auf Wunsch in den PDF-Export übernommen."
  />

</SectionWrapper>

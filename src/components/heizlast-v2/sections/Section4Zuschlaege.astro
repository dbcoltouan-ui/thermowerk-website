---
// Section 4 v2 — Zuschlaege
// Port aus Mockup (Zeilen ~2485–2595).
// Gate steuert zuschlaege.sperrzeitActive. Qas-Block ist immer sichtbar —
// wenn Pool+Lueftung=0, ist qas = 0.

import SectionWrapper from '../SectionWrapper.astro';
import Gate from '../Gate.astro';
import Notes from '../Notes.astro';
import OverrideField from '../OverrideField.astro';
---
<SectionWrapper
  anchor="sektion-4"
  title="Zuschläge"
  intro="Sperrzeiten des EVU und weitere angeschlossene Verbraucher (Pool, Lüftung, Trockner) werden hier aufgeschlagen. Beide Blöcke sind optional — der Toggle ist gleichzeitig die <strong>Ja/Nein-Frage</strong>."
>

  <Gate
    id="gate-sperrzeit"
    bindPath="zuschlaege.sperrzeitActive"
    title="EVU-Sperrzeit vorhanden"
    meta={'Q<sub>off</sub> = <span data-kpi="qoff">0</span> kW'}
    intro="Das Elektrizitätswerk sperrt die Wärmepumpe zu Spitzenzeiten. Der Ausfall-Zuschlag kompensiert die fehlende Laufzeit."
  >
    <div class="grid grid--2">
      <OverrideField
        id="f-toff"
        label="Sperrzeit pro Tag"
        symbol="t<sub>off</sub>"
        chip="Standard · 2 h"
        unit="h / Tag"
        bindPath="zuschlaege.toff"
        step="1"
        hint="Üblich in CH: 2 h für EVU-gesperrte Anlagen (Tagtarif), 3 h für stark regulierte Netze."
      />
      <div class="field">
        <label class="field__label">Sperrzeit-Fenster</label>
        <select class="select" disabled>
          <option selected>zusammenhängend (z. B. 11–13 Uhr)</option>
          <option>zwei kurze Blöcke</option>
          <option>drei kurze Blöcke</option>
        </select>
        <p class="field__hint">
          Nur informativ — fliesst nicht in den Rechenwert ein.
        </p>
      </div>
    </div>
    <div class="inline-result">
      <span>Sperrzeit-Zuschlag <span class="symbol">Q<sub>off</sub></span></span>
      <span><span class="inline-result__value" data-kpi="qoff">0</span><span class="inline-result__unit">kW</span></span>
    </div>
  </Gate>

  {/* Qas: verbundene Systeme */}
  <div class="block" style="margin-top: var(--s-7);">
    <div class="block__head">
      <h2 class="block__title">Verbundene Systeme</h2>
      <span class="chip">optional</span>
    </div>
    <p class="section__intro" style="margin-top: 0;">
      Zusätzliche Verbraucher, die dieselbe Wärmepumpe bedient.
      Wert <strong>0</strong> heisst „keine weiteren Systeme".
    </p>
    <div class="grid grid--2">
      <div class="field">
        <label class="field__label" for="f-qas-pool">
          Pool / Whirlpool
          <span class="symbol">Q<sub>as,Pool</sub></span>
        </label>
        <div class="input-group">
          <input class="input" id="f-qas-pool" type="number" step="0.1" data-hz-bind="zuschlaege.qasPool" data-hz-type="number" />
          <span class="input-group__unit">kW</span>
        </div>
        <p class="field__hint">Richtwert: Pool 1 – 3 kW.</p>
      </div>
      <div class="field">
        <label class="field__label" for="f-qas-lueftung">
          Lüftungsanlage (WRG)
          <span class="symbol">Q<sub>as,Lüft</sub></span>
        </label>
        <div class="input-group">
          <input class="input" id="f-qas-lueftung" type="number" step="0.1" data-hz-bind="zuschlaege.qasLueftung" data-hz-type="number" />
          <span class="input-group__unit">kW</span>
        </div>
        <p class="field__hint">Richtwert: Lüftung mit WRG 0.3 – 0.8 kW.</p>
      </div>
    </div>
    <div class="inline-result">
      <span>Summe verbundene Systeme <span class="symbol">Q<sub>as</sub></span></span>
      <span><span class="inline-result__value" data-kpi="qas">0</span><span class="inline-result__unit">kW</span></span>
    </div>
  </div>

  <Notes
    sectionKey="sektion4"
    label="Notiz zu Zuschlägen"
    placeholder="EVU-Vorgaben, Details zu Pool/Lüftung, weitere Verbraucher."
  />

</SectionWrapper>

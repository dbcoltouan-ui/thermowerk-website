---
// Section 6 v2 — Projekt + Endergebnis + Save-Actions
// Port aus Mockup (Zeilen ~2866-2990).
// Key/Value-Summary mit data-hz-sum-Slots, hero Qh-Block, Save-Buttons,
// Projekt-Notiz (Notes-Komponente).

import SectionWrapper from '../SectionWrapper.astro';
import Notes from '../Notes.astro';
---
<SectionWrapper
  anchor="sektion-6"
  title="Projekt & Ergebnis"
  intro="Alle Eingaben im Überblick. Darunter der <strong>Auslegungswert Q<sub>h</sub></strong>, mit dem die Wärmepumpe dimensioniert wird. Speichern, neues Projekt anlegen oder als PDF / JSON exportieren."
>

  <div class="summary">

    {/* Key/Value Summary */}
    <div class="summary__grid">
      <div class="summary__row">
        <span class="summary__label">Projektname</span>
        <span class="summary__value" data-hz-sum="projectName">–</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Status</span>
        <span class="summary__value"><span class="status-badge" data-hz-sum="projectStatus" data-status="arbeit">In Arbeit</span></span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Kunde</span>
        <span class="summary__value" data-hz-sum="customerName">–</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Adresse</span>
        <span class="summary__value" data-hz-sum="address">–</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Gebäude-Typ · Lage</span>
        <span class="summary__value" data-hz-sum="gebaeudeTypLage">–</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Bauperiode · EBF</span>
        <span class="summary__value" data-hz-sum="bauperiodeEbf">–</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">t<sub>voll</sub></span>
        <span class="summary__value"><span data-hz-sum="tvoll">–</span> h / a</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Methode Heizlast</span>
        <span class="summary__value" data-hz-sum="methode">–</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Q<sub>hl</sub> (korrigiert)</span>
        <span class="summary__value"><span data-kpi="qhlKorr">–</span> kW</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Q<sub>w</sub> (Warmwasser)</span>
        <span class="summary__value"><span data-kpi="qw">–</span> kW</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Q<sub>off</sub> (Sperrzeit)</span>
        <span class="summary__value"><span data-kpi="qoff">0</span> kW</span>
      </div>
      <div class="summary__row">
        <span class="summary__label">Q<sub>as</sub> (verb. Systeme)</span>
        <span class="summary__value"><span data-kpi="qas">0</span> kW</span>
      </div>
    </div>

    {/* Hero-Ergebnis */}
    <div class="result-hero">
      <div class="result-hero__main">
        <span class="result-hero__kicker">Auslegungswert</span>
        <span class="result-hero__value"><span data-kpi="qh">–</span><span class="result-hero__unit">kW</span></span>
        <span class="result-hero__caption">Q<sub>h</sub> = Q<sub>hl</sub> + Q<sub>w</sub> + Q<sub>off</sub> + Q<sub>as</sub></span>
      </div>
      <div class="result-hero__stat" data-hz-plausi>
        <span class="result-hero__stat-label">Spez. Leistung</span>
        <span class="result-hero__stat-value"><span data-kpi="plausi">–</span><span class="result-hero__stat-unit">W / m²</span></span>
      </div>
      <div class="result-hero__stat">
        <span class="result-hero__stat-label">WW-Speicher</span>
        <span class="result-hero__stat-value"><span data-kpi="wwSpeicher">–</span><span class="result-hero__stat-unit">L</span></span>
      </div>
      <div class="result-hero__stat">
        <span class="result-hero__stat-label">Heizungspuffer</span>
        <span class="result-hero__stat-value"><span data-kpi="puffer">–</span><span class="result-hero__stat-unit">L</span></span>
      </div>
    </div>

    {/* Save / Export */}
    <div class="save-actions">
      <button class="btn btn--primary" type="button" data-hz-action="save-cloud" data-hz-auth-only disabled>
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        <span>Speichern</span>
      </button>
      <button class="btn" type="button" data-hz-action="save-cloud-new" data-hz-auth-only disabled>
        Als neues Projekt speichern
      </button>
      <button class="btn" type="button" data-hz-action="open-projects" data-hz-auth-only disabled>
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        <span>Projekte öffnen</span>
      </button>
      <button class="btn" type="button" data-hz-action="export">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <span>Exportieren</span>
      </button>
      <button class="btn btn--ghost" type="button" data-hz-action="new-project">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        <span>Neues Projekt</span>
      </button>
      <span class="save-status" data-hz-save-status data-tone="idle" role="status" aria-live="polite">
        <span class="save-status__dot"></span>
        <span data-hz-save-label>Zuletzt lokal gespeichert</span>
      </span>
    </div>

  </div>

  <Notes
    sectionKey="projekt"
    label="Projekt-Notiz"
    placeholder="Freitext zur Gesamtauslegung, Offert-Relevante Hinweise, nächste Schritte."
    openDefault={true}
  />

</SectionWrapper>

<style is:global>
  /* Save-Status Pill (Mockup-kompatibel) */
  .save-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--fs-sm);
    color: var(--ink-500);
    margin-left: auto;
  }
  .save-status__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ink-300);
    flex-shrink: 0;
  }
  .save-status[data-tone="ok"] .save-status__dot { background: #4CA366; }
  .save-status[data-tone="busy"] .save-status__dot { background: #e0a500; animation: hz-pulse 1s infinite; }
  .save-status[data-tone="err"] .save-status__dot { background: var(--accent); }

  @keyframes hz-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Cloud-only-Buttons bei nicht-auth ausblenden */
  body:not(.is-auth) [data-hz-auth-only] { display: none !important; }
</style>

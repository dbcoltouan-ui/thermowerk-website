---
// Plausi v2 — collapsible Plausibilitaets-Quercheck.
// Port aus Mockup .plausi. Rein Anzeige — Werte werden via data-kpi="…" und
// data-hz-sum="…" im Script (heizlast.astro) gefuellt.

interface Props {
  openDefault?: boolean;
}

const { openDefault = true } = Astro.props;
---
<details class="plausi" open={openDefault} data-hz-plausi>
  <summary class="plausi__head">
    <svg class="plausi__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6" />
    </svg>
    <span class="plausi__title">Plausi-Quercheck</span>
    <span class="plausi__summary">
      <span class="plausi__dot" data-ampel="gruen" aria-hidden="true" data-hz-plausi-dot></span>
      <span data-hz-sum="plausiSummary">– W / m² · – kW</span>
    </span>
  </summary>
  <div class="plausi__body">
    <div class="plausi__grid">
      <div class="plausi__card">
        <span class="plausi__card-label">Spezifische Heizleistung</span>
        <span class="plausi__card-value">
          <span class="plausi__dot" data-ampel="gruen" aria-hidden="true" data-hz-plausi-dot></span>
          <span class="plausi__card-number" data-kpi="plausi">–</span>
          <span class="plausi__card-unit">W / m²</span>
        </span>
        <span class="plausi__card-range" data-hz-sum="plausiBand">Richtband wird ermittelt …</span>
      </div>
      <div class="plausi__card">
        <span class="plausi__card-label">Bauperioden-Richtwert</span>
        <span class="plausi__card-value">
          <span class="plausi__card-number" data-hz-sum="plausiRichtwert">–</span>
          <span class="plausi__card-unit">kW</span>
        </span>
        <span class="plausi__card-range" data-hz-sum="plausiMeta">–</span>
      </div>
    </div>
    <p class="plausi__note">
      Reiner Gegencheck zur gewählten Methode — beeinflusst das Ergebnis nicht.
      Im PDF-Export optional abwählbar.
    </p>
  </div>
</details>

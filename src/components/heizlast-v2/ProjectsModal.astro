---
// ProjectsModal v2 — Cloud-Projekt-Liste.
// Port aus Mockup (Zeilen ~3145-3252).
// Wide-Variante. Vier Zustaende via [data-hz-projects-state="loading|empty|error|list"].
// Liste wird per Glue-JS (heizlast.astro) gerendert; Row-Actions Laden/Loeschen.
---
<div
  class="modal-backdrop"
  id="hz-projects-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="hz-projects-modal-title"
  hidden
>
  <div class="modal modal--wide" data-hz-modal-stop>
    <div class="modal__head">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
      </svg>
      <span class="modal__title" id="hz-projects-modal-title">Projekte</span>
      <button class="modal__close" type="button" data-hz-modal-dismiss aria-label="Schliessen">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="modal__body" data-hz-projects-state="loading">
      <div class="projects-toolbar">
        <span class="projects-count" id="hz-projects-count">Lade …</span>
        <button class="btn btn--ghost" type="button" id="hz-projects-refresh" style="margin-left: auto;">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"/>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
          </svg>
          <span>Aktualisieren</span>
        </button>
      </div>

      {/* Loading */}
      <div class="projects-state projects-state--loading" data-projects-state="loading">
        <p class="section__intro">Projekte werden geladen …</p>
      </div>

      {/* Empty */}
      <div class="projects-state projects-state--empty" data-projects-state="empty" hidden>
        <p class="section__intro">Noch keine Cloud-Projekte gespeichert. Speichern Sie zuerst ein Projekt unten.</p>
      </div>

      {/* Error */}
      <div class="projects-state projects-state--error" data-projects-state="error" hidden>
        <div class="modal__error" id="hz-projects-error">Projekte konnten nicht geladen werden.</div>
      </div>

      {/* List */}
      <div class="projects-list" id="hz-projects-list" data-projects-state="list" hidden>
        {/* per Glue-JS gefuellt */}
      </div>
    </div>
  </div>
</div>

<style is:global>
  .projects-state { padding: var(--s-5) 0; }
  .projects-state .section__intro { margin: 0; }

  [data-hz-projects-state="loading"] [data-projects-state="loading"] { display: block; }
  [data-hz-projects-state="loading"] [data-projects-state]:not([data-projects-state="loading"]) { display: none !important; }

  [data-hz-projects-state="empty"] [data-projects-state="empty"] { display: block; }
  [data-hz-projects-state="empty"] [data-projects-state]:not([data-projects-state="empty"]) { display: none !important; }

  [data-hz-projects-state="error"] [data-projects-state="error"] { display: block; }
  [data-hz-projects-state="error"] [data-projects-state]:not([data-projects-state="error"]) { display: none !important; }

  [data-hz-projects-state="list"] [data-projects-state="list"] { display: grid; }
  [data-hz-projects-state="list"] [data-projects-state]:not([data-projects-state="list"]) { display: none !important; }
</style>

---
// PrintCover v2 — Deckblatt fuer PDF-Export.
// Port aus Mockup (Zeilen ~3010-3070).
// Nur sichtbar im Print-Modus (body.hz-print-mode) bzw. wenn Mockup-Preview aktiv.
// Alle dynamischen Werte werden per [data-print-slot="..."] vom Export-Glue gefuellt.
---
<div class="print-cover" id="hz-print-cover" hidden>
  <div class="print-cover__top">
    <div class="print-cover__brand">
      <span class="print-cover__brand-mark"></span>
      <span class="print-cover__brand-name">THERMOWERK</span>
    </div>
    <div class="print-cover__date">
      <span data-print-slot="date">–</span><br/>
      <span style="color: var(--ink-400);">Erstellt mit dem Heizlast-Rechner</span>
    </div>
  </div>

  <p class="print-cover__kicker">Auslegung</p>
  <h1 class="print-cover__title">Wärmepumpen-Dimensionierung</h1>
  <p class="print-cover__subtitle">
    Projekt <strong data-print-slot="projectName">–</strong> ·
    Kunde <strong data-print-slot="customerName">–</strong> ·
    <span data-print-slot="address">–</span>
  </p>

  <div class="print-cover__grid">
    <div class="print-cover__cell">
      <span class="print-cover__cell-label">Gebäude-Typ</span>
      <span class="print-cover__cell-value" data-print-slot="gebaeudeTyp">–</span>
    </div>
    <div class="print-cover__cell">
      <span class="print-cover__cell-label">Bauperiode · EBF</span>
      <span class="print-cover__cell-value" data-print-slot="bauperiodeEbf">–</span>
    </div>
    <div class="print-cover__cell">
      <span class="print-cover__cell-label">Klimaregion</span>
      <span class="print-cover__cell-value" data-print-slot="klimaregion">–</span>
    </div>
    <div class="print-cover__cell">
      <span class="print-cover__cell-label">Vollbetriebsstunden</span>
      <span class="print-cover__cell-value"><span data-print-slot="tvoll">–</span> h / a</span>
    </div>
  </div>

  <div class="print-cover__kpis">
    <div class="print-cover__kpi print-cover__kpi--hero">
      <span class="print-cover__kpi-label">Q<sub>h</sub> — Auslegung</span>
      <span class="print-cover__kpi-value"><span data-print-slot="qh">–</span><span class="print-cover__kpi-unit">kW</span></span>
    </div>
    <div class="print-cover__kpi">
      <span class="print-cover__kpi-label">Q<sub>hl</sub> korr.</span>
      <span class="print-cover__kpi-value"><span data-print-slot="qhlKorr">–</span><span class="print-cover__kpi-unit">kW</span></span>
    </div>
    <div class="print-cover__kpi">
      <span class="print-cover__kpi-label">WW-Speicher</span>
      <span class="print-cover__kpi-value"><span data-print-slot="wwSpeicher">–</span><span class="print-cover__kpi-unit">L</span></span>
    </div>
    <div class="print-cover__kpi">
      <span class="print-cover__kpi-label">Heizungspuffer</span>
      <span class="print-cover__kpi-value"><span data-print-slot="puffer">–</span><span class="print-cover__kpi-unit">L</span></span>
    </div>
  </div>

  <div class="print-cover__footer">
    <span>Rechenbasis: FWS Wärmepumpensystem-Modul 3 · SIA 384/2</span>
    <span>Seite 1</span>
  </div>
</div>

<style is:global>
  /* Deckblatt nur im Print-Modus zeigen */
  body.hz-print-mode .print-cover { display: flex !important; flex-direction: column; }
</style>

---
// ExportModal v2 — Dateiname + Inhalt-Checkboxen + Format-Radio.
// Port aus Mockup (Zeilen ~3103-3143).
// Submit fuehrt runExport() aus (siehe lib/heizlast/export.ts).
---
<div
  class="modal-backdrop"
  id="hz-export-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="hz-export-modal-title"
  hidden
>
  <div class="modal" data-hz-modal-stop>
    <div class="modal__head">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      <span class="modal__title" id="hz-export-modal-title">Projekt exportieren</span>
      <button class="modal__close" type="button" data-hz-modal-dismiss aria-label="Schliessen">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="modal__body">
      <form id="hz-export-form">
        <div class="field">
          <label class="field__label" for="f-export-name">Dateiname</label>
          <input class="input" id="f-export-name" type="text" name="filename" />
        </div>

        <fieldset class="export-fieldset">
          <legend>Inhalt</legend>
          <div class="export-options">
            <label class="export-option"><input type="checkbox" name="part-cover" checked /><span>Deckblatt</span></label>
            <label class="export-option"><input type="checkbox" name="part-objekt" checked /><span>Objekt &amp; Gebäude</span></label>
            <label class="export-option"><input type="checkbox" name="part-resultate" checked /><span>Resultate</span></label>
            <label class="export-option"><input type="checkbox" name="part-diagramm" checked /><span>Leistungsdiagramm</span></label>
            <label class="export-option"><input type="checkbox" name="part-plausi" /><span>Plausi-Quercheck</span></label>
            <label class="export-option"><input type="checkbox" name="part-formeln" /><span>Formeln &amp; Rechenweg</span></label>
            <label class="export-option"><input type="checkbox" name="part-notizenBereiche" checked /><span>Notizen aus Sektionen</span></label>
            <label class="export-option"><input type="checkbox" name="part-notizenProjekt" checked /><span>Projekt-Notiz</span></label>
          </div>
        </fieldset>

        <fieldset class="export-fieldset" style="margin-bottom: 0;">
          <legend>Format</legend>
          <div class="export-formats">
            <label class="export-format"><input type="radio" name="export-fmt" value="pdf" checked /><span>PDF — für Offerte &amp; Druck</span></label>
            <label class="export-format"><input type="radio" name="export-fmt" value="json" /><span>JSON — Rohdaten für Archiv</span></label>
          </div>
        </fieldset>
      </form>
    </div>

    <div class="modal__foot">
      <button class="btn btn--ghost" type="button" data-hz-modal-dismiss>Abbrechen</button>
      <button class="btn btn--primary" type="submit" form="hz-export-form" id="hz-export-submit">Exportieren</button>
    </div>
  </div>
</div>

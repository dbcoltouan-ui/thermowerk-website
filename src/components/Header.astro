---
// Header mit Navigation und Mobile-Menü – aktualisierte Links

const { nav } = Astro.props;

const ctaText = nav?.ctaButtonText || 'Beratung anfragen';
const ctaLink = nav?.ctaButtonLink || '#contact';
const stoerungText = nav?.stoerungText || 'Störung melden';
const stoerungLink = nav?.stoerungLink || 'tel:+41765040368';

const defaultItems = [
  { label: 'Leistungen', href: '#services', mobileOnly: false, children: [
    { label: 'Wärmepumpen', href: '#why' },
    { label: 'Klimaanlagen', href: '#klima' },
  ]},
  { label: 'Über Uns', href: '#about' },
  { label: 'Förderung', href: '#wpsm' },
  { label: 'Kostenrechner', href: '#calculator' },
];
const items = nav?.items?.length ? nav.items : defaultItems;
---
<header class="header" id="header">
  <div class="header-inner">
    <a href="/#hero">
      <img src="/img/logo.png" alt="Thermowerk" class="logo-img">
    </a>
    <button class="menu-toggle" id="menuToggle" aria-label="Menü öffnen">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="nav" id="mainNav">
      {items.map((item) => (
        <>
          {item.children && item.children.length > 0 ? (
            <div class="nav-dropdown">
              <a href={item.href} class="nav-dropdown-trigger">{item.label} <svg width="10" height="6" viewBox="0 0 10 6" fill="none" style="margin-left:4px;"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
              <div class="nav-dropdown-menu">
                {item.children.map((child) => (
                  <a href={child.href}>{child.label}</a>
                ))}
              </div>
            </div>
          ) : null}
          {item.children && item.children.length > 0 ? (
            <a href={item.href} class="mobile-menu-link">{item.label}</a>
          ) : null}
          {!item.children || item.children.length === 0 ? (
            <a href={item.href}>{item.label}</a>
          ) : null}
        </>
      ))}
      <a href={ctaLink} class="btn btn-primary">{ctaText}</a>
      <a href={stoerungLink} class="btn btn-stoerung mobile-only">{stoerungText}</a>
    </nav>
  </div>
</header>
